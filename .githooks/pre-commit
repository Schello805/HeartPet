#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

cd "$REPO_DIR"
echo "HeartPet Pre-Commit: Starte Prüfrunde ..."

echo "1/5 Tests"
node --test tests/app-routes.test.js

echo "2/5 Browser-E2E"
npm run test:e2e

echo "3/5 Tierakten-Ansicht"
node scripts/render-animal-show-check.js

echo "4/5 Syntax src/app.js"
node --check src/app.js

echo "5/5 Syntax public/js/app.js"
node --check public/js/app.js

echo "HeartPet Pre-Commit: alles gruen."
