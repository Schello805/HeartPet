<% const selectedAnimalState = typeof selectedAnimal !== 'undefined' ? selectedAnimal : null; %>
<% const selectedAnimalViewState = typeof selectedAnimalView !== 'undefined' ? selectedAnimalView : null; %>
<% const sectionState = typeof animalSection !== 'undefined' ? animalSection : { key: 'active' }; %>

<section
  class="animals-detail-panel"
  data-animal-workspace-panel
  data-animal-id="<%= selectedAnimalState ? selectedAnimalState.id : '' %>"
  data-animal-name="<%= selectedAnimalState ? selectedAnimalState.name : '' %>"
  data-animal-species="<%= selectedAnimalState ? (selectedAnimalState.species_name || 'Tier') : '' %>"
  data-animal-status="<%= selectedAnimalState ? selectedAnimalState.status : '' %>"
  data-animal-next-type="<%= selectedAnimalState?.next_term?.type || 'Offen' %>"
  data-animal-next-label="<%= selectedAnimalState?.next_term?.displayLabel || 'Noch kein Termin hinterlegt' %>"
>
  <% if (selectedAnimalState && selectedAnimalViewState) { %>
    <section class="card border-0 mb-3">
      <div class="card-body p-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div>
            <div class="text-uppercase small fw-semibold text-body-secondary mb-2">Ausgewähltes Tier</div>
            <h2 class="h3 mb-1"><%= selectedAnimalState.name %></h2>
            <p class="text-body-secondary mb-0">Hier startet die Akte mit den wichtigsten Stammdaten, offenen Punkten und direkten Aktionen.</p>
          </div>
          <span class="badge text-bg-secondary-subtle border"><%= selectedAnimalState.species_name || 'Tier' %></span>
        </div>
      </div>
    </section>
    <%- include('./animal-show', { pageTitle: selectedAnimalState.name, embedded: true, ...selectedAnimalViewState }) %>
  <% } else { %>
    <section class="card border-0">
      <div class="card-body p-4">
        <h2 class="h4 mb-2">
          <%= sectionState.key === 'history'
            ? 'Historie'
            : sectionState.key === 'resting'
              ? 'Ruhestätte'
              : 'Tier auswählen' %>
        </h2>
        <p class="fw-semibold mb-1"><%= sectionState.key === 'active' ? 'Noch kein Tier ausgewählt' : 'Noch keine Auswahl' %></p>
        <p class="text-body-secondary mb-0">
          <%= sectionState.key === 'history'
            ? 'Sobald vermittelte oder verkaufte Tiere vorhanden sind, kannst du sie oben aus der Liste wählen und ihre Akten weiter einsehen.'
            : sectionState.key === 'resting'
              ? 'Sobald verstorbene Tiere vorhanden sind, erscheinen sie hier in der Ruhestätte und können weiter würdevoll eingesehen werden.'
              : 'Wähle oben ein Tier aus der Liste, um die Akte direkt darunter zu öffnen.' %>
        </p>
      </div>
    </section>
  <% } %>
</section>
