<%- include('../partials/top', { pageTitle }) %>

<section class="drawer-fragment card border-0 bg-body-tertiary" data-drawer-fragment="animal-form" data-drawer-title="<%= animal ? 'Tier bearbeiten' : 'Neues Tier anlegen' %>">
  <div class="card-body">
    <h2 class="h4 mb-4"><%= animal ? 'Tier bearbeiten' : 'Neues Tier anlegen' %></h2>

    <form method="post" action="<%= animal ? `/animals/${animal.id}/update` : '/animals' %>" class="vstack gap-4" data-drawer-form="animal">
      <input type="hidden" name="return_to" value="<%= typeof returnTo !== 'undefined' ? returnTo : '/animals' %>" />

      <section class="card border bg-body">
        <div class="card-body">
          <div class="mb-3">
            <h3 class="h5 mb-1">Stammdaten</h3>
            <p class="text-body-secondary mb-0">Pflicht sind nur Name und Tierart. Du kannst eine vorhandene Tierart auswählen oder einfach eine neue eingeben.</p>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="animal-name">Name</label>
              <input class="form-control" id="animal-name" type="text" name="name" required value="<%= animal?.name || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="animal-species">Tierart</label>
              <input
                class="form-control"
                id="animal-species"
                type="text"
                name="species_name"
                required
                list="species-suggestions"
                data-species-autocomplete="true"
                autocomplete="off"
                value="<%= animal?.species_name || '' %>"
                placeholder="Vorhandene Tierart wählen oder neue eingeben"
                title="Beginne zu tippen. Bestehende Tierarten werden vorgeschlagen. Wenn die Tierart noch nicht existiert, wird sie beim Speichern automatisch angelegt."
              />
              <datalist id="species-suggestions">
                <% species.forEach((item) => { %>
                  <option value="<%= item.name %>"></option>
                <% }) %>
              </datalist>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="animal-sex">Geschlecht</label>
              <select class="form-select" id="animal-sex" name="sex">
                <option value="">Unbekannt</option>
                <option value="Weiblich" <%= animal?.sex === 'Weiblich' ? 'selected' : '' %>>Weiblich</option>
                <option value="Männlich" <%= animal?.sex === 'Männlich' ? 'selected' : '' %>>Männlich</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="animal-status">Status</label>
              <select class="form-select" id="animal-status" name="status">
                <% ['Aktiv', 'Vermittelt', 'Verkauft', 'Verstorben'].forEach((status) => { %>
                  <option value="<%= status %>" <%= (animal?.status || 'Aktiv') === status ? 'selected' : '' %>><%= status %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="animal-birth-date">Geburtsdatum</label>
              <input class="form-control" id="animal-birth-date" type="date" name="birth_date" value="<%= animal?.birth_date || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="animal-intake-date">Aufnahmedatum</label>
              <input class="form-control" id="animal-intake-date" type="date" name="intake_date" value="<%= animal?.intake_date || '' %>" />
            </div>
          </div>
        </div>
      </section>

      <section class="card border bg-body">
        <div class="card-body">
          <div class="mb-3">
            <h3 class="h5 mb-1">Merkmale und Herkunft</h3>
            <p class="text-body-secondary mb-0">Diese Angaben helfen dir später beim Wiederfinden, Filtern und Einordnen der Akte.</p>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="animal-source">Herkunft</label>
              <input class="form-control" id="animal-source" type="text" name="source" value="<%= animal?.source || '' %>" placeholder="Züchter, Fundtier, Vorbesitzer" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="animal-breed">Rasse / Unterart</label>
              <input class="form-control" id="animal-breed" type="text" name="breed" value="<%= animal?.breed || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="animal-color">Farbe</label>
              <input class="form-control" id="animal-color" type="text" name="color" value="<%= animal?.color || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="animal-weight">Gewicht in kg</label>
              <input class="form-control" id="animal-weight" type="number" step="0.01" name="weight_kg" value="<%= animal?.weight_kg || '' %>" />
            </div>
            <div class="col-12">
              <label class="form-label" for="animal-chip">Mikrochip / Kennzeichen</label>
              <input class="form-control" id="animal-chip" type="text" name="microchip_number" value="<%= animal?.microchip_number || '' %>" />
            </div>
          </div>
        </div>
      </section>

      <section class="card border bg-body">
        <div class="card-body">
          <div class="mb-3">
            <h3 class="h5 mb-1">Betreuung und Hinweise</h3>
            <p class="text-body-secondary mb-0">Hier legst du fest, ob dieses Tier einen eigenen Tierarzt nutzt und welche allgemeinen Hinweise in der Akte stehen sollen.</p>
          </div>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label" for="animal-vet">Tierarzt für dieses Tier</label>
              <select class="form-select" id="animal-vet" name="veterinarian_id" title="Wenn du hier nichts auswählst, verwendet HeartPet automatisch den Standardtierarzt der hinterlegten Tierart.">
                <option value="">Standard je Tierart verwenden</option>
                <% veterinarians.forEach((item) => { %>
                  <option value="<%= item.id %>" <%= String(animal?.veterinarian_id || '') === String(item.id) ? 'selected' : '' %>><%= item.name %><%= item.city ? ` (${item.city})` : '' %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label" for="animal-notes">Allgemeine Notizen</label>
              <textarea class="form-control" id="animal-notes" name="notes" rows="5"><%= animal?.notes || '' %></textarea>
            </div>
          </div>
        </div>
      </section>

      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 pt-2 border-top">
        <p class="text-body-secondary small mb-0">Typische Inhalte für Notizen sind Besonderheiten im Verhalten, Haltungsdetails, bisherige Erfahrungen oder Hinweise für andere Nutzer.</p>
        <div class="d-flex flex-wrap gap-2">
          <button type="submit" class="btn btn-success"><%= animal ? 'Änderungen speichern' : 'Tier anlegen' %></button>
          <% if (animal) { %>
            <a href="/animals/<%= animal.id %>" class="btn btn-outline-secondary">Zurück zur Akte</a>
          <% } %>
        </div>
      </div>
    </form>
  </div>
</section>

<%- include('../partials/bottom') %>
