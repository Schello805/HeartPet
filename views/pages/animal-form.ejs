<%- include('../partials/top', { pageTitle }) %>

<section class="panel">
  <div class="panel-head">
    <h2><%= animal ? 'Tier bearbeiten' : 'Neues Tier anlegen' %></h2>
  </div>

  <form method="post" action="<%= animal ? `/animals/${animal.id}/update` : '/animals' %>" class="form-grid">
    <label>
      <span>Name</span>
      <input type="text" name="name" required value="<%= animal?.name || '' %>" />
    </label>
    <label>
      <span>Tierart</span>
      <select name="species_id">
        <option value="">Bitte wählen</option>
        <% species.forEach((item) => { %>
          <option value="<%= item.id %>" <%= String(animal?.species_id || '') === String(item.id) ? 'selected' : '' %>><%= item.name %></option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>Geschlecht</span>
      <select name="sex">
        <option value="">Unbekannt</option>
        <option value="Weiblich" <%= animal?.sex === 'Weiblich' ? 'selected' : '' %>>Weiblich</option>
        <option value="Männlich" <%= animal?.sex === 'Männlich' ? 'selected' : '' %>>Männlich</option>
      </select>
    </label>
    <label>
      <span>Status</span>
      <select name="status">
        <% ['Aktiv', 'Vermittelt', 'Verkauft', 'Verstorben'].forEach((status) => { %>
          <option value="<%= status %>" <%= (animal?.status || 'Aktiv') === status ? 'selected' : '' %>><%= status %></option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>Geburtsdatum</span>
      <input type="date" name="birth_date" value="<%= animal?.birth_date || '' %>" />
    </label>
    <label>
      <span>Aufnahmedatum</span>
      <input type="date" name="intake_date" value="<%= animal?.intake_date || '' %>" />
    </label>
    <label>
      <span>Herkunft</span>
      <input type="text" name="source" value="<%= animal?.source || '' %>" placeholder="Züchter, Fundtier, Vorbesitzer" />
    </label>
    <label>
      <span>Rasse / Unterart</span>
      <input type="text" name="breed" value="<%= animal?.breed || '' %>" />
    </label>
    <label>
      <span>Farbe</span>
      <input type="text" name="color" value="<%= animal?.color || '' %>" />
    </label>
    <label>
      <span>Gewicht in kg</span>
      <input type="number" step="0.01" name="weight_kg" value="<%= animal?.weight_kg || '' %>" />
    </label>
    <label>
      <span>Mikrochip / Kennzeichen</span>
      <input type="text" name="microchip_number" value="<%= animal?.microchip_number || '' %>" />
    </label>
    <label>
      <span>Tierarzt für dieses Tier</span>
      <select name="veterinarian_id">
        <option value="">Standard je Tierart verwenden</option>
        <% veterinarians.forEach((item) => { %>
          <option value="<%= item.id %>" <%= String(animal?.veterinarian_id || '') === String(item.id) ? 'selected' : '' %>><%= item.name %></option>
        <% }) %>
      </select>
    </label>
    <label class="full-width">
      <span>Allgemeine Notizen</span>
      <textarea name="notes" rows="5"><%= animal?.notes || '' %></textarea>
    </label>
    <div class="full-width form-actions">
      <button type="submit" class="button"><%= animal ? 'Änderungen speichern' : 'Tier anlegen' %></button>
      <% if (animal) { %>
        <a href="/animals/<%= animal.id %>" class="button button-secondary">Zurück zur Akte</a>
      <% } %>
    </div>
  </form>
</section>

<%- include('../partials/bottom') %>
