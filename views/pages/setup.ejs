<!DOCTYPE html>
<html lang="de">
  <head>
    <% const resolvedAppLogoUrl = typeof appLogoUrl !== 'undefined' && appLogoUrl ? appLogoUrl : '/static/images/logo-heartpet.png'; %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | HeartPet</title>
    <link rel="icon" type="image/png" sizes="any" href="<%= resolvedAppLogoUrl %>" />
    <link rel="shortcut icon" type="image/png" href="<%= resolvedAppLogoUrl %>" />
    <link rel="apple-touch-icon" href="<%= resolvedAppLogoUrl %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous" />
    <link rel="stylesheet" href="/static/css/app.css" />
  </head>
  <body class="login-body bootstrap-app">
    <section class="login-panel setup-panel card">
      <div class="brand-lockup">
        <img class="brand-logo brand-logo-login" src="<%= resolvedAppLogoUrl %>" alt="HeartPet Logo" />
        <div>
          <h1>HeartPet einrichten</h1>
          <p>Lege zuerst den Administrator, einen Tierarzt und das erste Tier an. Danach landest du direkt in der normalen Oberfläche.</p>
        </div>
      </div>

      <% if (flash) { %>
        <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
      <% } %>

      <form method="post" action="/setup" class="form-shell">
        <section class="form-section">
          <div class="form-section-header">
            <strong>Einrichtung in drei Schritten</strong>
            <p class="compact-note">Du legst hier nur die Grunddaten an, die du für den Start wirklich brauchst. Alles Weitere kannst du danach in Ruhe in der normalen Oberfläche ergänzen.</p>
          </div>
        </section>

        <details class="accordion-item" open>
          <summary>1. Administrator</summary>
          <div class="accordion-content">
            <div class="form-grid">
              <label>
                <span>Name</span>
                <input class="form-control" type="text" name="admin_name" required />
              </label>
              <label>
                <span>E-Mail</span>
                <input class="form-control" type="email" name="admin_email" required />
              </label>
              <label class="full-width">
                <span>Passwort</span>
                <input class="form-control" type="password" name="admin_password" required minlength="8" />
              </label>
              <label class="full-width">
                <span>Name der Haltung / Organisation</span>
                <input class="form-control" type="text" name="organization_name" placeholder="optional" />
              </label>
            </div>
          </div>
        </details>

        <details class="accordion-item" open>
          <summary>2. Tierarzt</summary>
          <div class="accordion-content">
            <div class="form-grid">
              <label class="full-width">
                <span>Name</span>
                <input class="form-control" type="text" name="veterinarian_name" required />
              </label>
              <label class="full-width">
                <span>Straße</span>
                <input class="form-control" type="text" name="veterinarian_street" />
              </label>
              <label>
                <span>PLZ</span>
                <input class="form-control" type="text" name="veterinarian_postal_code" />
              </label>
              <label>
                <span>Ort</span>
                <input class="form-control" type="text" name="veterinarian_city" />
              </label>
              <label>
                <span>Land</span>
                <input class="form-control" type="text" name="veterinarian_country" value="Deutschland" />
              </label>
              <label>
                <span>Telefon</span>
                <input class="form-control" type="text" name="veterinarian_phone" />
              </label>
              <label class="full-width">
                <span>E-Mail</span>
                <input class="form-control" type="email" name="veterinarian_email" />
              </label>
            </div>
          </div>
        </details>

        <details class="accordion-item" open>
          <summary>3. Erstes Tier</summary>
          <div class="accordion-content">
            <div class="form-grid">
              <label>
                <span>Name</span>
                <input class="form-control" type="text" name="animal_name" required />
              </label>
              <label>
                <span>Tierart</span>
                <input class="form-control" type="text" name="species_name" list="setup-species-options" required />
              </label>
              <label>
                <span>Geschlecht</span>
                <select class="form-select" name="animal_sex">
                  <option value="">Bitte wählen</option>
                  <option value="Weiblich">Weiblich</option>
                  <option value="Männlich">Männlich</option>
                  <option value="Unbekannt">Unbekannt</option>
                </select>
              </label>
              <label>
                <span>Aufnahmedatum</span>
                <input class="form-control" type="date" name="animal_intake_date" />
              </label>
              <label>
                <span>Geburtsdatum</span>
                <input class="form-control" type="date" name="animal_birth_date" />
              </label>
              <label>
                <span>Herkunft</span>
                <input class="form-control" type="text" name="animal_source" />
              </label>
            </div>
            <datalist id="setup-species-options">
              <% species.forEach((item) => { %>
                <option value="<%= item.name %>"></option>
              <% }) %>
            </datalist>
          </div>
        </details>

        <div class="form-actions-bar">
          <div class="form-actions-copy">Nach dem Abschluss wirst du automatisch zur Anmeldung oder direkt in die App weitergeleitet, je nach aktuellem Setup-Status.</div>
          <button type="submit" class="btn btn-success">Ersteinrichtung abschließen</button>
        </div>
      </form>
    </section>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
    <script src="/static/js/app.js"></script>
  </body>
</html>
