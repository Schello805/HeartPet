<%- include('../partials/top', { pageTitle }) %>

<section class="accordion-stack">
  <details class="accordion-item" open>
    <summary>HeartPet Import</summary>
    <div class="accordion-content">
      <p class="help-copy">JSON-Exporte aus HeartPet können hier wieder eingelesen werden.</p>
      <form method="post" action="/admin/import" enctype="multipart/form-data" class="stack form-compact">
        <input type="file" name="import_file" accept="application/json" required />
        <button type="submit" class="button">Import starten</button>
      </form>
    </div>
  </details>
</section>

<%- include('../partials/bottom') %>
