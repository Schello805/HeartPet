<%- include('../partials/top', { pageTitle }) %>
<% const selectedAnimalState = typeof selectedAnimal !== 'undefined' ? selectedAnimal : null; %>
<% const selectedAnimalViewState = typeof selectedAnimalView !== 'undefined' ? selectedAnimalView : null; %>
<% const sectionState = typeof animalSection !== 'undefined' ? animalSection : { key: 'active', workspaceTitle: 'Tierbestand', workspaceIntro: '', totalLabel: 'Einträge', allowStatusFilter: true }; %>

<% if (sectionState.key === 'resting') { %>
<section class="panel resting-place-panel card border-0 shadow-sm">
  <div class="resting-place-intro">
    <p class="eyebrow">Ruhestätte</p>
    <h2>In liebevoller Erinnerung</h2>
    <p class="resting-place-copy">
      Hier bleiben verstorbene Tiere mit ihrer Akte sichtbar. Die Ansicht ist bewusst ruhig gehalten und vom aktiven Bestand getrennt.
    </p>
  </div>

  <% if (animals.length === 0) { %>
    <section class="panel animals-empty-detail resting-place-empty card border-0 shadow-sm">
      <div class="panel-head">
        <h2>Ruhestätte</h2>
      </div>
      <div class="empty-state-card">
        <strong>Noch keine Einträge</strong>
        <p class="empty-state">Noch keine Tiere in der Ruhestätte vorhanden.</p>
        <small>Wenn ein Tier als verstorben markiert wird, erscheint es hier automatisch in dieser ruhigeren Ansicht.</small>
      </div>
    </section>
  <% } else { %>
    <div class="resting-place-grid">
      <% animals.forEach((animal) => { %>
        <a href="/animals/<%= animal.id %>" class="resting-place-card">
          <div class="resting-place-image-wrap">
            <% if (animal.profile_image_stored_name) { %>
              <img class="resting-place-image" src="/media/<%= animal.profile_image_stored_name %>" alt="Profilbild von <%= animal.name %>" />
            <% } else { %>
              <div class="resting-place-image resting-place-image-fallback"><%= getAnimalInitial(animal.name) %></div>
            <% } %>
          </div>
          <div class="resting-place-body">
            <p class="eyebrow">In Erinnerung</p>
            <h3><%= animal.name %></h3>
            <p class="resting-place-meta"><%= animal.species_name || 'Tier' %><%= animal.breed ? ` · ${animal.breed}` : '' %></p>
            <div class="resting-place-facts">
              <div>
                <span>Geboren</span>
                <strong><%= formatDate(animal.birth_date) %></strong>
              </div>
              <div>
                <span>Bei dir seit</span>
                <strong><%= formatDate(animal.intake_date) %></strong>
              </div>
            </div>
            <% if (animal.notes) { %>
              <p class="resting-place-note"><%= animal.notes %></p>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>
<% } else { %>
<section class="animals-workspace">
  <aside class="animals-list-pane">
    <section class="panel animals-list-summary card border-0 shadow-sm">
      <div class="animals-list-summary-head">
        <div>
          <p class="eyebrow">Arbeitsansicht</p>
          <h2><%= sectionState.workspaceTitle %></h2>
          <% if (sectionState.workspaceIntro) { %>
            <p class="table-sub"><%= sectionState.workspaceIntro %></p>
          <% } %>
        </div>
        <span class="counter"><%= pagination.totalCount %> <%= sectionState.totalLabel %></span>
      </div>
      <div class="workspace-intro-strip">
        <article class="workspace-intro-card">
          <span>Was du hier machen kannst</span>
          <strong>
            <%= sectionState.key === 'history'
              ? 'Frühere Akten weiter einsehen'
              : 'Tiere auswählen und direkt in der Akte weiterarbeiten' %>
          </strong>
        </article>
        <article class="workspace-intro-card">
          <span>Fokus</span>
          <strong>
            <%= sectionState.key === 'history'
              ? 'Vermittelte und verkaufte Tiere'
              : 'Aktive Tiere mit offenen Themen und nächsten Terminen' %>
          </strong>
        </article>
      </div>
      <div class="animals-summary-grid">
        <article class="animals-summary-card">
          <span>Aktuelle Auswahl</span>
          <strong data-animals-selected-name><%= selectedAnimalState ? selectedAnimalState.name : 'Kein Tier' %></strong>
          <small data-animals-selected-species><%= selectedAnimalState ? (selectedAnimalState.species_name || 'Tier') : 'Bitte links ein Tier auswählen' %></small>
        </article>
        <article class="animals-summary-card">
          <span>Nächster Termin</span>
          <strong data-animals-next-type><%= selectedAnimalState?.next_term?.type || 'Offen' %></strong>
          <small data-animals-next-label><%= selectedAnimalState?.next_term?.displayLabel || 'Noch kein Termin hinterlegt' %></small>
        </article>
      </div>
    </section>

    <section class="panel animals-filter-panel card border-0 shadow-sm">
      <div class="panel-head compact-panel-head">
        <div>
          <h2>Filtern und sortieren</h2>
          <p class="panel-subtitle">Suche gezielt nach Tier, Tierart oder Arbeitsstatus.</p>
        </div>
      </div>
      <form method="get" action="/animals" class="filter-row animals-filter-grid">
        <label class="search-autocomplete-field full-width">
          <span>Suche</span>
          <input class="form-control" type="text" name="q" value="<%= filters.search %>" placeholder="Name, Herkunft, Rasse" data-global-search-autocomplete="true" />
        </label>
        <label>
          <span>Status</span>
          <select class="form-select" name="status">
            <% if (sectionState.allowStatusFilter) { %>
              <option value="">Alle</option>
              <option value="Vermittelt" <%= filters.status === 'Vermittelt' ? 'selected' : '' %>>Vermittelt</option>
              <option value="Verkauft" <%= filters.status === 'Verkauft' ? 'selected' : '' %>>Verkauft</option>
            <% } else { %>
              <option value="<%= filters.status || (sectionState.allowedStatuses ? sectionState.allowedStatuses[0] : 'Aktiv') %>" selected>
                <%= filters.status || (sectionState.allowedStatuses ? sectionState.allowedStatuses[0] : 'Aktiv') %>
              </option>
            <% } %>
          </select>
        </label>
        <label>
          <span>Tierart</span>
          <select class="form-select" name="species_id">
            <option value="">Alle</option>
            <% speciesOptions.forEach((item) => { %>
              <option value="<%= item.id %>" <%= String(filters.speciesId || '') === String(item.id) ? 'selected' : '' %>><%= item.name %></option>
            <% }) %>
          </select>
        </label>
        <label class="full-width">
          <span>Sortierung</span>
          <select class="form-select" name="sort">
            <option value="name_asc" <%= filters.sort === 'name_asc' ? 'selected' : '' %>>Name A-Z</option>
            <option value="name_desc" <%= filters.sort === 'name_desc' ? 'selected' : '' %>>Name Z-A</option>
            <option value="intake_desc" <%= filters.sort === 'intake_desc' ? 'selected' : '' %>>Aufnahme neu zuerst</option>
            <option value="intake_asc" <%= filters.sort === 'intake_asc' ? 'selected' : '' %>>Aufnahme alt zuerst</option>
            <option value="created_desc" <%= filters.sort === 'created_desc' ? 'selected' : '' %>>Zuletzt angelegt</option>
            <option value="status_asc" <%= filters.sort === 'status_asc' ? 'selected' : '' %>>Status</option>
            <option value="next_term_asc" <%= filters.sort === 'next_term_asc' ? 'selected' : '' %>>Nächster Termin</option>
          </select>
        </label>
        <% if (selectedAnimalState) { %>
          <input type="hidden" name="animal_id" value="<%= selectedAnimalState.id %>" />
        <% } %>
        <button type="submit" class="btn btn-success">Filtern</button>
        <a href="<%= sectionState.key === 'history' ? '/animals/historie' : sectionState.key === 'resting' ? '/animals/ruhestaette' : '/animals' %>" class="btn btn-outline-secondary">Zurücksetzen</a>
      </form>
    </section>

    <section class="panel animals-list-panel card border-0 shadow-sm">
      <div class="panel-head">
        <div>
          <h2>Liste</h2>
          <p class="panel-subtitle">Wähle links ein Tier und arbeite rechts direkt in der Akte weiter.</p>
        </div>
        <span class="counter"><%= animals.length %> sichtbar</span>
      </div>

      <% if (animals.length === 0) { %>
        <div class="empty-state-card">
          <strong>
            <%= sectionState.key === 'history'
              ? 'Noch keine historischen Einträge'
              : sectionState.key === 'resting'
                ? 'Noch keine Tiere in der Ruhestätte'
                : 'Noch kein aktiver Bestand' %>
          </strong>
          <p class="empty-state">
            <%= sectionState.key === 'history'
              ? 'Noch keine vermittelten oder verkauften Tiere vorhanden.'
              : sectionState.key === 'resting'
                ? 'Noch keine Tiere in der Ruhestätte vorhanden.'
                : 'Noch keine aktiven Tiere vorhanden. Lege dein erstes Tier über „Neues Tier“ an.' %>
          </p>
        </div>
      <% } else { %>
        <div class="animals-list-stack">
          <% animals.forEach((animal) => { %>
            <% const rowParams = new URLSearchParams(); %>
            <% if (filters.search) rowParams.set('q', filters.search); %>
            <% if (filters.status) rowParams.set('status', filters.status); %>
            <% if (filters.speciesId) rowParams.set('species_id', filters.speciesId); %>
            <% if (filters.sort) rowParams.set('sort', filters.sort); %>
            <% if (pagination.currentPage > 1) rowParams.set('page', String(pagination.currentPage)); %>
            <% rowParams.set('animal_id', String(animal.id)); %>
            <a
              href="/animals?<%= rowParams.toString() %>"
              class="animal-list-entry <%= selectedAnimalState && String(selectedAnimalState.id) === String(animal.id) ? 'active' : '' %>"
              data-animal-workspace-link="true"
              data-no-soft-nav="true"
              data-panel-url="/animals/<%= animal.id %>/workspace-panel?<%= rowParams.toString() %>"
            >
              <div class="animal-list-entry-main">
                <div class="animal-list-cell">
                  <% if (animal.profile_image_stored_name) { %>
                    <img class="animal-thumb" src="/media/<%= animal.profile_image_stored_name %>" alt="Profilbild von <%= animal.name %>" />
                  <% } else { %>
                    <div class="animal-thumb animal-thumb-fallback"><%= getAnimalInitial(animal.name) %></div>
                  <% } %>
                  <div>
                    <strong><%= animal.name %></strong>
                    <div class="table-sub"><%= animal.species_name || '-' %> · <%= animal.breed || '-' %></div>
                  </div>
                </div>
                <span class="pill"><%= animal.status %></span>
              </div>
              <div class="animal-list-entry-meta">
                <span><%= animal.veterinarian_name || 'Kein Tierarzt' %></span>
                <% if (animal.next_term) { %>
                  <strong><%= animal.next_term.type %></strong>
                  <span><%= animal.next_term.displayLabel %></span>
                <% } else { %>
                  <span>Kein nächster Termin</span>
                <% } %>
              </div>
            </a>
          <% }) %>
        </div>

        <% if (pagination.totalPages > 1) { %>
          <nav class="pagination-row">
            <% for (let page = 1; page <= pagination.totalPages; page += 1) { %>
              <% const url = `/animals?q=${encodeURIComponent(filters.search || '')}&status=${encodeURIComponent(filters.status || '')}&species_id=${encodeURIComponent(filters.speciesId || '')}&sort=${encodeURIComponent(filters.sort || 'name_asc')}&page=${page}${selectedAnimalState ? `&animal_id=${selectedAnimalState.id}` : ''}`; %>
              <a href="<%= url %>" class="pagination-link <%= page === pagination.currentPage ? 'active' : '' %>"><%= page %></a>
            <% } %>
          </nav>
        <% } %>
      <% } %>
    </section>
  </aside>

  <section class="animals-detail-pane" data-animal-workspace-target>
    <%- include('./animal-workspace-detail', { selectedAnimal: selectedAnimalState, selectedAnimalView: selectedAnimalViewState, animalSection: sectionState }) %>
  </section>
</section>
<% } %>

<%- include('../partials/bottom') %>
