<% const sectionState = typeof animalSection !== 'undefined' ? animalSection : { key: 'active', workspaceTitle: 'Tierbestand', workspaceIntro: '', totalLabel: 'Einträge', allowStatusFilter: true }; %>
<%- include('../partials/top', { pageTitle, pageClass: `animals-page animals-page--${sectionState.key}` }) %>
<% const selectedAnimalState = typeof selectedAnimal !== 'undefined' ? selectedAnimal : null; %>
<% const selectedAnimalViewState = typeof selectedAnimalView !== 'undefined' ? selectedAnimalView : null; %>

<% if (sectionState.key === 'resting') { %>
<section class="card border-0">
  <div class="card-body p-4">
    <div class="mb-4">
      <div class="text-uppercase small fw-semibold text-body-secondary mb-2">Ruhestätte</div>
      <h2 class="h3 mb-2">In liebevoller Erinnerung</h2>
      <p class="text-body-secondary mb-0">
        Hier bleiben verstorbene Tiere mit ihrer Akte sichtbar. Die Ansicht ist bewusst ruhig gehalten und vom aktiven Bestand getrennt.
      </p>
    </div>

    <% if (animals.length === 0) { %>
      <div class="card border bg-body-tertiary-subtle">
        <div class="card-body p-4">
          <h3 class="h5 mb-2">Noch keine Einträge</h3>
          <p class="text-body-secondary mb-1">Hier sind noch keine Tiere eingetragen.</p>
          <div class="small text-body-secondary">Wenn ein Tier als verstorben markiert wird, bleibt seine Akte hier in einer ruhigeren, stilleren Ansicht erhalten.</div>
        </div>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% animals.forEach((animal) => { %>
          <div class="col-md-6 col-xl-4">
            <a href="/animals/<%= animal.id %>" class="card h-100 border text-decoration-none">
              <% if (animal.profile_image_stored_name) { %>
                <img class="card-img-top object-fit-cover" src="/media/<%= animal.profile_image_stored_name %>" alt="Profilbild von <%= animal.name %>" style="height: 220px;" />
              <% } else { %>
                <div class="card-img-top d-flex align-items-center justify-content-center bg-secondary-subtle fw-semibold fs-1" style="height: 220px;"><%= getAnimalInitial(animal.name) %></div>
              <% } %>
              <div class="card-body">
                <div class="text-uppercase small fw-semibold text-body-secondary mb-2">In Erinnerung</div>
                <h3 class="h4 mb-1"><%= animal.name %></h3>
                <p class="text-body-secondary mb-3"><%= animal.species_name || 'Tier' %><%= animal.breed ? ` · ${animal.breed}` : '' %></p>
                <div class="row g-3 small">
                  <div class="col-6">
                    <div class="text-body-secondary">Geboren</div>
                    <div class="fw-semibold"><%= formatDate(animal.birth_date) %></div>
                  </div>
                  <div class="col-6">
                    <div class="text-body-secondary">Bei dir seit</div>
                    <div class="fw-semibold"><%= formatDate(animal.intake_date) %></div>
                  </div>
                </div>
                <% if (animal.notes) { %>
                  <p class="mt-3 mb-0 small text-body-secondary"><%= animal.notes %></p>
                <% } %>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
<% } else { %>
<div class="row g-3">
  <div class="col-12">
    <% if (sectionState.key !== 'active') { %>
      <section class="card border-0">
        <div class="card-body p-3 p-md-4">
          <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
              <div class="text-uppercase small fw-semibold text-body-secondary mb-2">Arbeitsansicht</div>
              <h2 class="h3 mb-2"><%= sectionState.workspaceTitle %></h2>
              <p class="text-body-secondary mb-0">
                <%= sectionState.workspaceIntro || 'Hier arbeitest du mit allen Tieren im aktuellen Tierbestand.' %>
              </p>
            </div>
            <span class="badge text-bg-secondary-subtle border"><%= pagination.totalCount %> <%= sectionState.totalLabel %></span>
          </div>
          <div class="row g-3">
            <div class="col-md-4">
              <div class="card border bg-body-tertiary-subtle h-100">
                <div class="card-body">
                  <div class="small text-body-secondary mb-2">Aktuelle Auswahl</div>
                  <div class="fw-semibold" data-animals-selected-name><%= selectedAnimalState ? selectedAnimalState.name : 'Kein Tier' %></div>
                  <div class="small text-body-secondary" data-animals-selected-species><%= selectedAnimalState ? (selectedAnimalState.species_name || 'Tier') : 'Bitte unten ein Tier auswählen' %></div>
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card border bg-body-tertiary-subtle h-100">
                <div class="card-body">
                  <div class="small text-body-secondary mb-2">Nächster Termin</div>
                  <div class="fw-semibold" data-animals-next-type><%= selectedAnimalState?.next_term?.type || 'Offen' %></div>
                  <div class="small text-body-secondary" data-animals-next-label><%= selectedAnimalState?.next_term?.displayLabel || 'Noch kein Termin hinterlegt' %></div>
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card border bg-body-tertiary-subtle h-100">
                <div class="card-body">
                  <div class="small text-body-secondary mb-2">Arbeitsweise</div>
                  <div class="fw-semibold">Oben wählen</div>
                  <div class="small text-body-secondary">Danach erscheint die komplette Akte direkt darunter.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    <% } %>
  </div>

  <div class="col-12">
    <section class="card border-0">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
          <div>
            <h2 class="h4 mb-1">Filter und Auswahl</h2>
          </div>
          <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#animals-filter-collapse" aria-expanded="false" aria-controls="animals-filter-collapse">Filter anzeigen</button>
        </div>
        <div class="collapse" id="animals-filter-collapse">
          <form method="get" action="/animals" class="row g-3 align-items-end">
            <div class="col-lg-4">
              <label class="form-label">Suche</label>
              <div class="search-autocomplete-field">
                <input class="form-control" type="text" name="q" value="<%= filters.search %>" placeholder="Name, Herkunft, Rasse" data-global-search-autocomplete="true" />
              </div>
            </div>
            <div class="col-sm-6 col-lg-2">
              <label class="form-label">Status</label>
              <select class="form-select" name="status">
                <% if (sectionState.allowStatusFilter) { %>
                  <option value="">Alle</option>
                  <option value="Vermittelt" <%= filters.status === 'Vermittelt' ? 'selected' : '' %>>Vermittelt</option>
                  <option value="Verkauft" <%= filters.status === 'Verkauft' ? 'selected' : '' %>>Verkauft</option>
                <% } else { %>
                  <option value="<%= filters.status || (sectionState.allowedStatuses ? sectionState.allowedStatuses[0] : 'Aktiv') %>" selected>
                    <%= filters.status || (sectionState.allowedStatuses ? sectionState.allowedStatuses[0] : 'Aktiv') %>
                  </option>
                <% } %>
              </select>
            </div>
            <div class="col-sm-6 col-lg-2">
              <label class="form-label">Tierart</label>
              <select class="form-select" name="species_id">
                <option value="">Alle</option>
                <% speciesOptions.forEach((item) => { %>
                  <option value="<%= item.id %>" <%= String(filters.speciesId || '') === String(item.id) ? 'selected' : '' %>><%= item.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-lg-2">
              <label class="form-label">Sortierung</label>
              <select class="form-select" name="sort">
                <option value="name_asc" <%= filters.sort === 'name_asc' ? 'selected' : '' %>>Name A-Z</option>
                <option value="name_desc" <%= filters.sort === 'name_desc' ? 'selected' : '' %>>Name Z-A</option>
                <option value="intake_desc" <%= filters.sort === 'intake_desc' ? 'selected' : '' %>>Aufnahme neu zuerst</option>
                <option value="intake_asc" <%= filters.sort === 'intake_asc' ? 'selected' : '' %>>Aufnahme alt zuerst</option>
                <option value="created_desc" <%= filters.sort === 'created_desc' ? 'selected' : '' %>>Zuletzt angelegt</option>
                <option value="status_asc" <%= filters.sort === 'status_asc' ? 'selected' : '' %>>Status</option>
                <option value="next_term_asc" <%= filters.sort === 'next_term_asc' ? 'selected' : '' %>>Nächster Termin</option>
              </select>
            </div>
            <% if (selectedAnimalState) { %>
              <input type="hidden" name="animal_id" value="<%= selectedAnimalState.id %>" />
            <% } %>
            <div class="col-lg-2 d-flex gap-2">
              <button type="submit" class="btn btn-primary flex-fill">Filtern</button>
              <a href="<%= sectionState.key === 'history' ? '/animals/historie' : sectionState.key === 'resting' ? '/animals/ruhestaette' : '/animals' %>" class="btn btn-outline-secondary">Zurücksetzen</a>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>

  <div class="col-12">
    <section class="card border-0">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
          <div>
            <h2 class="h4 mb-1">Tierliste</h2>
          </div>
          <span class="badge text-bg-secondary-subtle border"><%= animals.length %> sichtbar</span>
        </div>

        <% if (animals.length === 0) { %>
          <div class="card border bg-body-tertiary-subtle">
            <div class="card-body">
              <h3 class="h6 mb-2">
                <%= sectionState.key === 'history'
                  ? 'Noch keine historischen Einträge'
                  : sectionState.key === 'resting'
                    ? 'Noch keine Tiere in der Ruhestätte'
                    : 'Noch kein aktiver Bestand' %>
              </h3>
              <p class="text-body-secondary mb-0">
                <%= sectionState.key === 'history'
                  ? 'Sobald Tiere als vermittelt oder verkauft markiert werden, erscheinen sie hier gesammelt in der Historie.'
                  : sectionState.key === 'resting'
                    ? 'Noch keine Tiere in der Ruhestätte vorhanden.'
                    : 'Noch keine aktiven Tiere vorhanden. Lege dein erstes Tier über „Neues Tier“ an.' %>
              </p>
            </div>
          </div>
        <% } else { %>
          <div class="list-group">
            <% animals.forEach((animal) => { %>
              <% const rowParams = new URLSearchParams(); %>
              <% if (filters.search) rowParams.set('q', filters.search); %>
              <% if (filters.status) rowParams.set('status', filters.status); %>
              <% if (filters.speciesId) rowParams.set('species_id', filters.speciesId); %>
              <% if (filters.sort) rowParams.set('sort', filters.sort); %>
              <% if (pagination.currentPage > 1) rowParams.set('page', String(pagination.currentPage)); %>
              <% rowParams.set('animal_id', String(animal.id)); %>
              <a
                href="/animals?<%= rowParams.toString() %>"
                class="list-group-item list-group-item-action bg-transparent px-3 py-3 <%= selectedAnimalState && String(selectedAnimalState.id) === String(animal.id) ? 'active' : '' %>"
                data-animal-workspace-link="true"
                data-no-soft-nav="true"
                data-panel-url="/animals/<%= animal.id %>/workspace-panel?<%= rowParams.toString() %>"
              >
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                  <div class="d-flex gap-3 align-items-center">
                    <% if (animal.profile_image_stored_name) { %>
                      <img class="rounded object-fit-cover" src="/media/<%= animal.profile_image_stored_name %>" alt="Profilbild von <%= animal.name %>" width="56" height="56" />
                    <% } else { %>
                      <div class="rounded bg-secondary-subtle d-flex align-items-center justify-content-center fw-semibold" style="width:56px;height:56px;"><%= getAnimalInitial(animal.name) %></div>
                    <% } %>
                    <div>
                      <div class="fw-semibold"><%= animal.name %></div>
                      <div class="small text-body-secondary"><%= animal.species_name || '-' %> · <%= animal.breed || '-' %></div>
                    </div>
                  </div>
                  <div class="text-lg-end">
                    <div class="small text-body-secondary"><%= animal.veterinarian_name || 'Kein Tierarzt' %></div>
                    <% if (animal.next_term) { %>
                      <div class="fw-semibold"><%= animal.next_term.type %></div>
                      <div class="small text-body-secondary"><%= animal.next_term.displayLabel %></div>
                    <% } else { %>
                      <div class="small text-body-secondary">Kein nächster Termin</div>
                    <% } %>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <nav class="mt-3">
              <ul class="pagination pagination-sm mb-0">
                <% for (let page = 1; page <= pagination.totalPages; page += 1) { %>
                  <% const url = `/animals?q=${encodeURIComponent(filters.search || '')}&status=${encodeURIComponent(filters.status || '')}&species_id=${encodeURIComponent(filters.speciesId || '')}&sort=${encodeURIComponent(filters.sort || 'name_asc')}&page=${page}${selectedAnimalState ? `&animal_id=${selectedAnimalState.id}` : ''}`; %>
                  <li class="page-item <%= page === pagination.currentPage ? 'active' : '' %>">
                    <a href="<%= url %>" class="page-link"><%= page %></a>
                  </li>
                <% } %>
              </ul>
            </nav>
          <% } %>
        <% } %>
      </div>
    </section>
  </div>

  <div class="col-12">
    <section data-animal-workspace-target>
      <%- include('./animal-workspace-detail', { selectedAnimal: selectedAnimalState, selectedAnimalView: selectedAnimalViewState, animalSection: sectionState }) %>
    </section>
  </div>
</div>
<% } %>

<%- include('../partials/bottom') %>
