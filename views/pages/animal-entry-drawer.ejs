<%
  const isEdit = mode === 'edit';
  const isEvent = entryType === 'event';
  const isCondition = entryType === 'condition';
  const isFeeding = entryType === 'feeding';
  const isNote = entryType === 'note';
  const isMedication = entryType === 'medication';
  const isVaccination = entryType === 'vaccination';
  const isAppointment = entryType === 'appointment';
  const isReminder = entryType === 'reminder';
  const isDocument = entryType === 'document';
  const isImage = entryType === 'image';
  const defaultReturnTo = returnTo || `/animals/${animal.id}`;
%>

<section class="panel drawer-fragment" data-drawer-fragment="animal-entry" data-drawer-title="<%= pageTitle %>">
  <div class="panel-head">
    <h2><%= pageTitle %></h2>
    <p><%= animal.name %> · <%= animal.species_name || 'Tier' %></p>
  </div>
  <% const drawerHelpText = isEvent
    ? 'Über dieses Formular erfasst du medizinische Ereignisse, Arzttermine oder freie Erinnerungen direkt in der Akte.'
    : isCondition
      ? 'Hier dokumentierst du bekannte Vorerkrankungen oder dauerhafte gesundheitliche Besonderheiten.'
      : isFeeding
        ? 'Nutze diesen Bereich für wiederkehrende Fütterungen, feste Uhrzeiten und kurze Hinweise zur Versorgung.'
        : isNote
          ? 'Protokolle eignen sich für Beobachtungen, Übergaben, Vorfälle oder alles, was später nachvollziehbar bleiben soll.'
          : isMedication
            ? 'Passe hier laufende Medikamentengaben an, wenn sich Name, Zeitraum oder Hinweise geändert haben.'
            : isVaccination
              ? 'Hier pflegst du Impfdaten und die nächste Fälligkeit. Erledigte Impfungen bleiben damit sauber nachvollziehbar.'
              : isAppointment
                ? 'Arzttermine helfen dir, Besuche in der Praxis oder Vor-Ort-Termine sauber zu planen und später wiederzufinden.'
                : isReminder
                  ? 'Freie Erinnerungen sind für alles gedacht, was nicht direkt Medikament, Impfung oder Termin ist.'
                  : isDocument
                    ? 'Dokumente und Nachweise bleiben hier direkt am Tier. Mit einer Kategorie findest du sie später schneller wieder.'
                    : isImage
                      ? 'Bilder kannst du hier als zusätzliche Fotos zur Tierakte hochladen, getrennt vom Profilbild.'
                      : ''; %>
  <% if (drawerHelpText) { %>
    <p class="compact-note"><%= drawerHelpText %></p>
  <% } %>

  <% if (isEvent) { %>
    <form method="post" action="/animals/<%= animal.id %>/events" class="stack form-compact event-form" data-drawer-form="animal-entry" data-event-form>
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <div class="form-grid event-grid event-grid-row-1">
        <label>
          <span>Typ</span>
          <select name="event_kind" required data-event-kind-select title="Wähle hier, was du erfassen möchtest. Das Formular passt sich danach an.">
            <% if (permissions.canManageHealth) { %>
              <option value="medication">Medikament</option>
              <option value="vaccination">Impfung</option>
              <option value="appointment">Arzttermin</option>
            <% } %>
            <% if (permissions.canManageReminders) { %>
              <option value="reminder">Freie Erinnerung</option>
            <% } %>
          </select>
        </label>
        <label>
          <span>Bezeichnung</span>
          <input type="text" name="title" required placeholder="z. B. Wurmkur, Tollwut, Nachkontrolle" />
        </label>
      </div>

      <div class="form-grid event-grid event-grid-row-2">
        <label>
          <span>Datum</span>
          <input type="date" name="event_date" required data-event-date />
        </label>
        <label data-event-time-wrap>
          <span>Uhrzeit</span>
          <input type="time" name="event_time" data-event-time />
        </label>
      </div>

      <div class="form-grid event-grid event-grid-row-3">
        <div data-veterinarian-fields hidden>
          <label>
            <span>Tierarzt</span>
            <select name="veterinarian_id">
              <option value="">Tierarzt auswählen</option>
              <% veterinarians.forEach((vet) => { %>
                <option value="<%= vet.id %>"><%= vet.name %></option>
              <% }) %>
            </select>
          </label>
        </div>
        <label class="checkbox-line subtle-toggle compact-toggle">
          <input type="checkbox" name="handled_by_veterinarian" value="1" data-handled-by-vet />
          <span>Durch Tierarzt</span>
        </label>
        <label class="checkbox-line subtle-toggle compact-toggle" data-reminder-inline-wrap>
          <input type="checkbox" name="create_reminder" value="1" data-create-reminder />
          <span>Erinnern</span>
        </label>
      </div>

      <label>
        <span>Bemerkung (optional)</span>
        <textarea name="notes" rows="3" placeholder="Optionaler Hinweis"></textarea>
      </label>

      <div class="button-row">
        <button type="submit" class="button">Ereignis speichern</button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isCondition) { %>
    <form method="post" action="<%= isEdit ? `/animals/${animal.id}/conditions/${item.id}/update` : `/animals/${animal.id}/conditions` %>" class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <label>
        <span>Bezeichnung</span>
        <input type="text" name="title" required value="<%= item?.title || '' %>" />
      </label>
      <label>
        <span>Beschreibung</span>
        <textarea name="details" rows="4"><%= item?.details || '' %></textarea>
      </label>
      <small class="compact-note">Hilfreich sind z. B. Diagnose, Auffälligkeiten, bekannte Einschränkungen oder wichtige Rückfragen für spätere Arzttermine.</small>
      <div class="button-row">
        <button type="submit" class="button"><%= isEdit ? 'Vorerkrankung speichern' : 'Vorerkrankung anlegen' %></button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isFeeding) { %>
    <form method="post" action="<%= isEdit ? `/animals/${animal.id}/feedings/${item.id}/update` : `/animals/${animal.id}/feedings` %>" class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <div class="mini-grid">
        <label>
          <span>Bezeichnung</span>
          <input type="text" name="label" required value="<%= item?.label || '' %>" />
        </label>
        <label>
          <span>Uhrzeit</span>
          <input type="time" name="time_of_day" value="<%= item?.time_of_day || '' %>" />
        </label>
      </div>
      <div class="mini-grid">
        <label>
          <span>Futter</span>
          <input type="text" name="food" value="<%= item?.food || '' %>" />
        </label>
        <label>
          <span>Menge</span>
          <input type="text" name="amount" value="<%= item?.amount || '' %>" />
        </label>
      </div>
      <label>
        <span>Notizen</span>
        <textarea name="notes" rows="3"><%= item?.notes || '' %></textarea>
      </label>
      <small class="compact-note">Wenn du möchtest, kannst du hier z. B. Futtersorte, Zubereitung, Verträglichkeit oder besondere Hinweise für Helfer notieren.</small>
      <div class="button-row">
        <button type="submit" class="button"><%= isEdit ? 'Fütterung speichern' : 'Fütterung anlegen' %></button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isNote) { %>
    <form method="post" action="<%= isEdit ? `/animals/${animal.id}/notes/${item.id}/update` : `/animals/${animal.id}/notes` %>" class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <label>
        <span>Titel</span>
        <input type="text" name="title" required value="<%= item?.title || '' %>" />
      </label>
      <label>
        <span>Inhalt</span>
        <textarea name="content" rows="5" required><%= item?.content || '' %></textarea>
      </label>
      <small class="compact-note">Halte hier fest, was später nachvollziehbar bleiben soll, zum Beispiel Beobachtungen, Übergaben oder kurze Tagesprotokolle.</small>
      <div class="button-row">
        <button type="submit" class="button"><%= isEdit ? 'Protokoll speichern' : 'Protokoll anlegen' %></button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isMedication) { %>
    <form method="post" action="/animals/<%= animal.id %>/medications/<%= item.id %>/update" class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <label>
        <span>Name</span>
        <input type="text" name="name" required value="<%= item?.name || '' %>" />
      </label>
      <div class="mini-grid">
        <label>
          <span>Dosis</span>
          <input type="text" name="dosage" value="<%= item?.dosage || '' %>" />
        </label>
        <label>
          <span>Plan</span>
          <input type="text" name="schedule" value="<%= item?.schedule || '' %>" />
        </label>
      </div>
      <div class="mini-grid">
        <label>
          <span>Startdatum</span>
          <input type="date" name="start_date" value="<%= item?.start_date || '' %>" />
        </label>
        <label>
          <span>Enddatum</span>
          <input type="date" name="end_date" value="<%= item?.end_date || '' %>" />
        </label>
      </div>
      <label>
        <span>Notizen</span>
        <textarea name="notes" rows="4"><%= item?.notes || '' %></textarea>
      </label>
      <small class="compact-note">Wenn du hier nichts weiter einträgst, reicht oft schon der Name. Zusätzliche Hinweise helfen vor allem bei längeren Behandlungen.</small>
      <div class="button-row">
        <button type="submit" class="button">Medikament speichern</button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isVaccination) { %>
    <form method="post" action="/animals/<%= animal.id %>/vaccinations/<%= item.id %>/update" class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <label>
        <span>Impfung</span>
        <input type="text" name="name" required value="<%= item?.name || '' %>" />
      </label>
      <div class="mini-grid">
        <label>
          <span>Impfdatum</span>
          <input type="date" name="vaccination_date" value="<%= item?.vaccination_date || '' %>" />
        </label>
        <label>
          <span>Nächste Fälligkeit</span>
          <input type="date" name="next_due_date" value="<%= item?.next_due_date || '' %>" />
        </label>
      </div>
      <label>
        <span>Notizen</span>
        <textarea name="notes" rows="4"><%= item?.notes || '' %></textarea>
      </label>
      <small class="compact-note">Hinterlege hier bei Bedarf Chargenhinweise, Reaktionen auf die Impfung oder Verweise auf einen hochgeladenen Nachweis.</small>
      <div class="button-row">
        <button type="submit" class="button">Impfung speichern</button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isAppointment) { %>
    <form method="post" action="/animals/<%= animal.id %>/appointments/<%= item.id %>/update" class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <label>
        <span>Titel</span>
        <input type="text" name="title" required value="<%= item?.title || '' %>" />
      </label>
      <label>
        <span>Termin</span>
        <input type="datetime-local" name="appointment_at" required value="<%= item?.appointment_at || '' %>" />
      </label>
      <div class="mini-grid">
        <label>
          <span>Ort</span>
          <select name="location_mode">
            <option value="praxis" <%= item?.location_mode === 'praxis' ? 'selected' : '' %>>Tier zum Arzt</option>
            <option value="vor_ort" <%= item?.location_mode === 'vor_ort' ? 'selected' : '' %>>Tierarzt kommt vor Ort</option>
          </select>
        </label>
        <label>
          <span>Tierarzt</span>
          <select name="veterinarian_id">
            <option value="">Tierarzt auswählen</option>
            <% veterinarians.forEach((vet) => { %>
              <option value="<%= vet.id %>" <%= String(item?.veterinarian_id || '') === String(vet.id) ? 'selected' : '' %>><%= vet.name %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <label>
        <span>Ort / Adresse</span>
        <input type="text" name="location_text" value="<%= item?.location_text || '' %>" />
      </label>
      <label>
        <span>Notizen</span>
        <textarea name="notes" rows="4"><%= item?.notes || '' %></textarea>
      </label>
      <small class="compact-note">So lassen sich Terminart, Anfahrt und wichtige Absprachen später schnell wieder nachvollziehen.</small>
      <div class="button-row">
        <button type="submit" class="button">Arzttermin speichern</button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isReminder) { %>
    <form method="post" action="/animals/<%= animal.id %>/reminders/<%= item.id %>/update" class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <label>
        <span>Titel</span>
        <input type="text" name="title" required value="<%= item?.title || '' %>" />
      </label>
      <div class="mini-grid">
        <label>
          <span>Typ</span>
          <input type="text" name="reminder_type" value="<%= item?.reminder_type || '' %>" />
        </label>
        <label>
          <span>Fällig am</span>
          <input type="datetime-local" name="due_at" required value="<%= item?.due_at || '' %>" />
        </label>
      </div>
      <label>
        <span>Wiederholung in Tagen</span>
        <input type="number" min="0" step="1" name="repeat_interval_days" value="<%= item?.repeat_interval_days || 0 %>" />
      </label>
      <div class="mini-grid">
        <label class="checkbox-line">
          <input type="checkbox" name="channel_email" <%= item?.channel_email ? 'checked' : '' %> />
          E-Mail senden
        </label>
        <label class="checkbox-line">
          <input type="checkbox" name="channel_telegram" <%= item?.channel_telegram ? 'checked' : '' %> />
          Telegram senden
        </label>
      </div>
      <label>
        <span>Notizen</span>
        <textarea name="notes" rows="4"><%= item?.notes || '' %></textarea>
      </label>
      <small class="compact-note">Wenn die Erinnerung nur einmalig sein soll, lass die Wiederholung einfach auf 0 stehen.</small>
      <div class="button-row">
        <button type="submit" class="button">Erinnerung speichern</button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isDocument) { %>
    <form method="post" action="<%= isEdit ? `/animals/${animal.id}/documents/${item.id}/update` : `/animals/${animal.id}/documents` %>" <%= isEdit ? '' : 'enctype="multipart/form-data"' %> class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <label>
        <span>Titel</span>
        <input type="text" name="title" <%= isEdit ? 'required' : '' %> value="<%= item?.title || '' %>" placeholder="z. B. Impfpass 2026" />
      </label>
      <label>
        <span>Kategorie</span>
        <select name="category_id">
          <option value="">Keine Kategorie</option>
          <% categories.forEach((category) => { %>
            <option value="<%= category.id %>" <%= String(item?.category_id || '') === String(category.id) ? 'selected' : '' %>><%= category.name %><%= category.is_required ? ' (Pflicht)' : '' %></option>
          <% }) %>
        </select>
      </label>
      <% if (!isEdit) { %>
        <label>
          <span>Datei</span>
          <input type="file" name="document" required />
        </label>
      <% } %>
      <small class="compact-note">Mit einer Kategorie bleibt die Datei später leichter auffindbar. Titel und Kategorie können auch nach dem Upload noch angepasst werden.</small>
      <div class="button-row">
        <button type="submit" class="button"><%= isEdit ? 'Dokument speichern' : 'Dokument hochladen' %></button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>

  <% if (isImage) { %>
    <form method="post" action="/animals/<%= animal.id %>/images" enctype="multipart/form-data" class="stack form-compact" data-drawer-form="animal-entry">
      <input type="hidden" name="return_to" value="<%= defaultReturnTo %>" />
      <label>
        <span>Titel</span>
        <input type="text" name="title" placeholder="z. B. Sommer 2026" />
      </label>
      <label>
        <span>Bilddatei</span>
        <input type="file" name="image" accept="image/*" required />
      </label>
      <small class="compact-note">Zusätzliche Fotos eignen sich z. B. für Verlauf, Verletzungen, Besonderheiten oder die Dokumentation von Veränderungen.</small>
      <div class="button-row">
        <button type="submit" class="button">Bild hochladen</button>
        <button type="button" class="button button-secondary" data-drawer-close>Abbrechen</button>
      </div>
    </form>
  <% } %>
</section>
