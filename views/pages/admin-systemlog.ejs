<%- include('../partials/top', { pageTitle }) %>

<div class="accordion" id="systemlogAccordion">
  <div class="accordion-item">
    <h2 class="accordion-header" id="systemlog-heading-notifications">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#systemlog-notifications" aria-expanded="false" aria-controls="systemlog-notifications">
        Mail- und Benachrichtigungslog
      </button>
    </h2>
    <div id="systemlog-notifications" class="accordion-collapse collapse" aria-labelledby="systemlog-heading-notifications" data-bs-parent="#systemlogAccordion">
      <div class="accordion-body">
        <form method="get" action="/admin/systemlog" class="row g-3 align-items-end mb-4">
          <div class="col-md-4">
            <label class="form-label" for="systemlog-level">Kanal</label>
            <select class="form-select" id="systemlog-level" name="level">
              <option value="all" <%= filters.level === 'all' ? 'selected' : '' %>>Alle</option>
              <option value="email" <%= filters.level === 'email' ? 'selected' : '' %>>E-Mail</option>
              <option value="telegram" <%= filters.level === 'telegram' ? 'selected' : '' %>>Telegram</option>
            </select>
          </div>
          <div class="col-md-auto d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">Filtern</button>
            <a href="/admin/systemlog" class="btn btn-outline-secondary">Zurücksetzen</a>
          </div>
        </form>

        <% if (!notificationLogs.length) { %>
          <div class="empty-state-card">
            <strong>Noch keine Benachrichtigungs-Logs</strong>
            <p class="empty-state">Sobald E-Mail- oder Telegram-Versand stattfindet, siehst du die Einträge hier im Verlauf.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead>
                <tr>
                  <th>Zeit</th>
                  <th>Kanal</th>
                  <th>Typ</th>
                  <th>Empfänger</th>
                  <th>Status</th>
                  <th>Fehler</th>
                </tr>
              </thead>
              <tbody>
                <% notificationLogs.forEach((item) => { %>
                  <tr>
                    <td><%= formatDateTime(item.created_at) %></td>
                    <td><%= item.channel %></td>
                    <td><%= item.notification_type %></td>
                    <td><%= item.recipient || '-' %></td>
                    <td><span class="status-chip status-<%= item.status %>"><%= item.status %></span></td>
                    <td><%= item.error_message || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="accordion-item">
    <h2 class="accordion-header" id="systemlog-heading-audit">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#systemlog-audit" aria-expanded="false" aria-controls="systemlog-audit">
        Audit-Log
      </button>
    </h2>
    <div id="systemlog-audit" class="accordion-collapse collapse" aria-labelledby="systemlog-heading-audit" data-bs-parent="#systemlogAccordion">
      <div class="accordion-body">
        <% if (!auditLogs.length) { %>
          <div class="empty-state-card">
            <strong>Noch keine Audit-Einträge</strong>
            <p class="empty-state">Änderungen durch Nutzer erscheinen hier automatisch, sobald in der App Aktionen protokolliert werden.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead>
                <tr>
                  <th>Zeit</th>
                  <th>Benutzer</th>
                  <th>Aktion</th>
                  <th>Objekt</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody>
                <% auditLogs.forEach((item) => { %>
                  <tr>
                    <td><%= formatDateTime(item.created_at) %></td>
                    <td><%= item.actor_email || '-' %></td>
                    <td><%= item.action %></td>
                    <td><%= item.entity_type || '-' %> <%= item.entity_id || '' %></td>
                    <td><code><%= item.details || '-' %></code></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/bottom') %>
