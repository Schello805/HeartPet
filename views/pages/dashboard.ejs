<%- include('../partials/top', { pageTitle }) %>
<% const searchState = typeof search !== 'undefined' ? search : { q: '', searchable: false }; %>
<% const dashboardSearchResults = typeof searchResults !== 'undefined' ? searchResults : []; %>

<section class="panel dashboard-hero-panel card border-0 shadow-sm">
  <div class="dashboard-hero-layout">
    <div class="dashboard-hero-copy">
      <p class="eyebrow">Heute im Blick</p>
      <h2>Bestand, Erinnerungen und nächste Schritte auf einen Blick.</h2>
      <p class="dashboard-hero-text">
        Starte hier mit der Suche oder springe direkt in die wichtigsten Bereiche. Die Karten darunter zeigen dir, wo gerade Handlungsbedarf besteht.
      </p>
      <div class="dashboard-hero-highlights">
        <span class="pill">Aktiver Bestand: <strong><%= stats.animalCount %></strong></span>
        <span class="pill">Offene Erinnerungen: <strong><%= stats.openReminderCount %></strong></span>
        <span class="pill">Heute fällig: <strong><%= stats.dueReminderCount %></strong></span>
      </div>
      <div class="dashboard-hero-links">
        <a href="/animals" class="dashboard-hero-link">Zu den Tieren</a>
        <a href="#dringende-erinnerungen" class="dashboard-hero-link">Zu dringenden Erinnerungen</a>
        <a href="/hilfe" class="dashboard-hero-link">Hilfe öffnen</a>
      </div>
    </div>
    <div class="dashboard-hero-search">
      <form method="get" action="/" class="dashboard-search-form">
        <div class="search-autocomplete-field">
          <input class="form-control" type="search" name="q" value="<%= searchState.q || '' %>" placeholder="Tiere, Dokumente, Ereignisse suchen ..." autocomplete="off" data-global-search-autocomplete="true" />
        </div>
        <button type="submit" class="btn btn-success">Suchen</button>
      </form>
      <% if (searchState.q && !searchState.searchable) { %>
        <p class="empty-state">Bitte mindestens 2 Zeichen eingeben.</p>
      <% } %>
    </div>
  </div>
</section>

<% if (searchState.searchable) { %>
  <section class="panel card border-0 shadow-sm">
    <div class="panel-head">
      <h2>Suchergebnisse</h2>
      <span class="counter"><%= dashboardSearchResults.length %> Treffer</span>
    </div>
    <% if (!dashboardSearchResults.length) { %>
      <p class="empty-state">Keine Ergebnisse gefunden.</p>
    <% } else { %>
      <div class="stack">
        <% dashboardSearchResults.forEach((item) => { %>
          <a class="animal-card" href="<%= item.href %>">
            <div>
              <strong><%= item.title %></strong>
              <p><%= item.kind %> | <%= item.subtitle %></p>
            </div>
            <span><%= item.when || '' %></span>
          </a>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<section class="dashboard-grid">
  <a class="stat-card card border-0 shadow-sm text-decoration-none" href="/animals">
    <span>Tiere</span>
    <strong><%= stats.animalCount %></strong>
    <small>Direkt zur Tierübersicht</small>
  </a>
  <article class="stat-card card border-0 shadow-sm">
    <span>Dokumente</span>
    <strong><%= stats.documentCount %></strong>
    <small>Hinterlegte Unterlagen und Bilder</small>
  </article>
  <article class="stat-card card border-0 shadow-sm">
    <span>Offene Erinnerungen</span>
    <strong><%= stats.openReminderCount %></strong>
    <small>Alles, was noch auf Rückmeldung wartet</small>
  </article>
  <article class="stat-card stat-card-warning card border-0 shadow-sm">
    <span>Jetzt fällig</span>
    <strong><%= stats.dueReminderCount %></strong>
    <small>Heute oder bereits überfällig</small>
  </article>
</section>

<section class="content-grid">
  <article class="panel card border-0 shadow-sm" id="dringende-erinnerungen">
    <div class="panel-head">
      <div>
        <h2>Dringend: Überfällig & Heute</h2>
        <p class="panel-subtitle">Diese Einträge brauchen als Nächstes Aufmerksamkeit.</p>
      </div>
    </div>
    <% const urgentList = typeof urgentReminders !== 'undefined' ? urgentReminders : []; %>
    <% if (urgentList.length === 0) { %>
      <p class="empty-state">Keine dringenden Erinnerungen vorhanden.</p>
    <% } else { %>
      <div class="stack">
        <% urgentList.forEach((reminder) => { %>
          <div class="list-card">
            <div>
              <strong><%= reminder.title %></strong>
              <p><%= reminder.animal_name || "Ohne Tierzuordnung" %> | <%= reminder.reminder_type %></p>
              <small>Fällig: <%= formatDateTime(reminder.due_at) %></small>
            </div>
            <span class="status-chip <%= reminder.urgency === 'overdue' ? 'status-error' : reminder.urgency === 'today' ? 'status-warning' : 'status-muted' %>">
              <%= reminder.urgency === 'overdue' ? 'Überfällig' : reminder.urgency === 'today' ? 'Heute' : 'Bald' %>
            </span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </article>

  <article class="panel card border-0 shadow-sm" id="naechste-erinnerungen">
    <div class="panel-head">
      <div>
        <h2>Nächste Erinnerungen</h2>
        <p class="panel-subtitle">Vormerken, bevor daraus etwas Dringendes wird.</p>
      </div>
    </div>
    <% if (upcomingReminders.length === 0) { %>
      <p class="empty-state">Keine offenen Erinnerungen vorhanden.</p>
    <% } else { %>
      <div class="stack">
        <% upcomingReminders.forEach((reminder) => { %>
          <div class="list-card">
            <div>
              <strong><%= reminder.title %></strong>
              <p><%= reminder.animal_name || "Ohne Tierzuordnung" %> | <%= reminder.reminder_type %></p>
              <small>Fällig: <%= formatDateTime(reminder.due_at) %></small>
            </div>
            <% if (!reminder.completed_at && permissions.canManageReminders) { %>
              <form method="post" action="/reminders/<%= reminder.id %>/complete">
                <button type="submit" class="btn btn-outline-secondary">Als erledigt markieren</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </article>

  <article class="panel card border-0 shadow-sm">
    <div class="panel-head">
      <div>
        <h2>Neueste Tierakten</h2>
        <p class="panel-subtitle">Schneller Einstieg in die zuletzt gepflegten Akten.</p>
      </div>
      <a href="/animals" class="btn btn-outline-secondary btn-sm">Alle anzeigen</a>
    </div>
    <% if (recentAnimals.length === 0) { %>
      <p class="empty-state">Es wurden noch keine Tiere angelegt.</p>
    <% } else { %>
      <div class="stack">
        <% recentAnimals.forEach((animal) => { %>
          <a class="animal-card" href="/animals/<%= animal.id %>">
            <div>
              <strong><%= animal.name %></strong>
              <p><%= animal.species_name || "-" %> | <%= animal.status %></p>
            </div>
            <span><%= formatDate(animal.intake_date) %></span>
          </a>
        <% }) %>
      </div>
    <% } %>
  </article>
</section>

<section class="panel card border-0 shadow-sm">
  <div class="panel-head">
    <div>
      <h2>Schnell weiter</h2>
      <p class="panel-subtitle">Die häufigsten Wege direkt von hier aus.</p>
    </div>
  </div>
  <div class="quick-actions">
    <% if (permissions.canEditAnimals) { %>
      <a href="/animals/new" class="quick-card" data-drawer="animal-form">
        <strong>Tier anlegen</strong>
        <span>Neue Akte mit Stammdaten, Herkunft und Tierarzt erstellen.</span>
      </a>
    <% } %>
    <% if (permissions.canManageAdmin) { %>
      <a href="/admin/allgemein" class="quick-card">
        <strong>Admin öffnen</strong>
        <span>SMTP, Telegram, Benutzer, Tierarten und Dokumentkategorien verwalten.</span>
      </a>
    <% } %>
    <a href="/hilfe" class="quick-card">
      <strong>Hilfe lesen</strong>
      <span>Anleitungen für Einrichtung, Telegram-Bot und Updatescript.</span>
    </a>
  </div>
</section>

<%- include('../partials/bottom') %>
