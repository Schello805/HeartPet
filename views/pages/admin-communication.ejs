<%- include('../partials/top', { pageTitle }) %>
<% const resolvedInstanceTimezone = typeof instanceTimezone !== 'undefined' && instanceTimezone ? instanceTimezone : 'UTC'; %>

<form id="toggle-email-enabled-form" method="post" action="/admin/settings" class="hidden-form">
  <input type="hidden" name="_fields" value="reminder_email_enabled" />
  <input type="hidden" name="reminder_email_enabled" value="<%= settings.reminder_email_enabled === 'true' ? 'false' : 'true' %>" />
</form>

<form id="toggle-telegram-enabled-form" method="post" action="/admin/settings" class="hidden-form">
  <input type="hidden" name="_fields" value="reminder_telegram_enabled" />
  <input type="hidden" name="reminder_telegram_enabled" value="<%= settings.reminder_telegram_enabled === 'true' ? 'false' : 'true' %>" />
</form>

<div class="accordion" id="communicationAccordion">
  <div class="accordion-item">
    <h2 class="accordion-header" id="communication-general-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#communication-general" aria-expanded="false" aria-controls="communication-general">
        Wann und wie erinnert werden soll
      </button>
    </h2>
    <div id="communication-general" class="accordion-collapse collapse" aria-labelledby="communication-general-heading" data-bs-parent="#communicationAccordion">
      <div class="accordion-body">
        <form method="post" action="/admin/settings" class="vstack gap-4">
          <input type="hidden" name="_fields" value="browser_notifications_enabled,daily_digest_enabled,daily_digest_time,daily_digest_only_when_open" />
          <section class="card border-0 bg-body-tertiary">
            <div class="card-body">
              <div class="mb-3">
                <h3 class="h5 mb-1">Allgemeine Erinnerungen</h3>
                <p class="text-body-secondary mb-0">Hier legst du fest, ob HeartPet offene Erinnerungen zusätzlich im Browser und als tägliche Zusammenfassung anzeigen soll.</p>
              </div>
              <div class="row g-3">
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="browser_notifications_enabled" name="browser_notifications_enabled" <%= settings.browser_notifications_enabled === 'true' ? 'checked' : '' %> />
                    <label class="form-check-label" for="browser_notifications_enabled">Browser-Hinweise für offene Erinnerungen aktivieren</label>
                  </div>
                </div>
                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="daily_digest_enabled" name="daily_digest_enabled" <%= settings.daily_digest_enabled === 'true' ? 'checked' : '' %> />
                    <label class="form-check-label" for="daily_digest_enabled">Tägliche Erinnerungs-Zusammenfassung aktivieren</label>
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="daily_digest_time">Tägliche Zusammenfassung um</label>
                  <input class="form-control" id="daily_digest_time" type="time" name="daily_digest_time" value="<%= settings.daily_digest_time || '07:30' %>" />
                </div>
                <div class="col-md-6 d-flex align-items-end">
                  <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="daily_digest_only_when_open" name="daily_digest_only_when_open" <%= settings.daily_digest_only_when_open !== 'false' ? 'checked' : '' %> />
                    <label class="form-check-label" for="daily_digest_only_when_open">Nur senden, wenn offene Erinnerungen vorhanden sind</label>
                  </div>
                </div>
              </div>
              <div class="alert alert-secondary mt-3 mb-0" role="alert">
                Die Uhrzeit gilt in der Zeitzone dieser Instanz: <strong><%= resolvedInstanceTimezone %></strong>.
                Wenn dein Server oder LXC auf <strong>Europe/Berlin</strong> läuft, bedeutet <strong>07:30</strong> also auch wirklich 07:30 Uhr deutscher Zeit.
              </div>
            </div>
          </section>
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 pt-2 border-top">
            <p class="text-body-secondary small mb-0">Diese Einstellungen steuern nur Browser-Hinweise und die tägliche Zusammenfassung. E-Mail und Telegram bleiben darunter separat.</p>
            <button type="submit" class="btn btn-success">Benachrichtigungen speichern</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="accordion-item">
    <h2 class="accordion-header" id="communication-rules-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#communication-rules" aria-expanded="false" aria-controls="communication-rules">
        Erinnerungsregeln je Ereignis
      </button>
    </h2>
    <div id="communication-rules" class="accordion-collapse collapse" aria-labelledby="communication-rules-heading" data-bs-parent="#communicationAccordion">
      <div class="accordion-body">
        <form method="post" action="/admin/settings" class="vstack gap-4">
          <input type="hidden" name="_fields" value="medication_reminder_lead_days,medication_reminder_repeat_count,vaccination_reminder_lead_days,vaccination_reminder_repeat_count,appointment_reminder_lead_days,appointment_reminder_repeat_count" />
          <section class="card border-0 bg-body-tertiary">
            <div class="card-body">
              <div class="mb-3">
                <h3 class="h5 mb-1">Regeln pro Ereignistyp</h3>
                <p class="text-body-secondary mb-0">Diese Regeln gelten nur für Ereignisse, bei denen in der Tierakte der Haken <strong>Erinnern</strong> gesetzt wurde.</p>
              </div>
              <div class="alert alert-secondary" role="alert">E-Mail und Telegram werden global unten aktiviert und gelten dann zusätzlich für alle passenden Ereignisse.</div>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label" for="medication_reminder_lead_days">Medikamente: Tage vorher</label>
                  <input class="form-control" id="medication_reminder_lead_days" type="number" min="0" step="1" name="medication_reminder_lead_days" value="<%= settings.medication_reminder_lead_days || '0' %>" />
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="medication_reminder_repeat_count">Medikamente: Anzahl Erinnerungen</label>
                  <input class="form-control" id="medication_reminder_repeat_count" type="number" min="0" step="1" name="medication_reminder_repeat_count" value="<%= settings.medication_reminder_repeat_count || '0' %>" />
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="vaccination_reminder_lead_days">Impfungen: Tage vorher</label>
                  <input class="form-control" id="vaccination_reminder_lead_days" type="number" min="0" step="1" name="vaccination_reminder_lead_days" value="<%= settings.vaccination_reminder_lead_days || '30' %>" />
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="vaccination_reminder_repeat_count">Impfungen: Anzahl Erinnerungen</label>
                  <input class="form-control" id="vaccination_reminder_repeat_count" type="number" min="0" step="1" name="vaccination_reminder_repeat_count" value="<%= settings.vaccination_reminder_repeat_count || '1' %>" />
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="appointment_reminder_lead_days">Arzttermine: Tage vorher</label>
                  <input class="form-control" id="appointment_reminder_lead_days" type="number" min="0" step="1" name="appointment_reminder_lead_days" value="<%= settings.appointment_reminder_lead_days || '1' %>" />
                </div>
                <div class="col-md-6">
                  <label class="form-label" for="appointment_reminder_repeat_count">Arzttermine: Anzahl Erinnerungen</label>
                  <input class="form-control" id="appointment_reminder_repeat_count" type="number" min="0" step="1" name="appointment_reminder_repeat_count" value="<%= settings.appointment_reminder_repeat_count || '1' %>" />
                </div>
              </div>
              <div class="alert alert-secondary mt-3 mb-0" role="alert">Die Anzahl steuert, wie viele Erinnerungen automatisch erzeugt werden. Bei mehreren Erinnerungen wird ab dem Vorlauf täglich erinnert.</div>
            </div>
          </section>
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 pt-2 border-top">
            <p class="text-body-secondary small mb-0">Halte die Regeln lieber knapp und erhöhe die Wiederholungen nur dort, wo ihr sie im Alltag wirklich braucht.</p>
            <button type="submit" class="btn btn-success">Erinnerungsregeln speichern</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="accordion-item">
    <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center gap-2 p-3 border-bottom">
      <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#communication-email" aria-expanded="false" aria-controls="communication-email">
        E-Mail
      </button>
      <div class="d-flex flex-wrap gap-2">
        <span class="status-chip setup-status-chip <%= communicationStatus.emailReady ? 'status-ok' : 'status-muted' %>">
          <%= communicationStatus.emailReady ? 'Konfiguriert' : 'Nicht konfiguriert' %>
        </span>
        <button type="submit" form="toggle-email-enabled-form" class="status-chip service-status-chip <%= settings.reminder_email_enabled === 'true' ? 'status-active' : 'status-muted' %>">
          <%= settings.reminder_email_enabled === 'true' ? 'Aktiviert' : 'Deaktiviert' %>
        </button>
      </div>
    </div>
    <div id="communication-email" class="accordion-collapse collapse" data-bs-parent="#communicationAccordion">
      <div class="accordion-body">
        <div class="vstack gap-4">
          <form method="post" action="/admin/settings" class="vstack gap-4">
            <input type="hidden" name="_fields" value="smtp_host,smtp_port,smtp_user,smtp_password,smtp_from,notification_email_to,smtp_secure" />
            <section class="card border-0 bg-body-tertiary">
              <div class="card-body">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label" for="smtp_host">SMTP Host</label>
                    <input class="form-control" id="smtp_host" type="text" name="smtp_host" value="<%= settings.smtp_host || '' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="smtp_port">SMTP Port</label>
                    <input class="form-control" id="smtp_port" type="number" name="smtp_port" value="<%= settings.smtp_port || '587' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="smtp_user">SMTP Benutzer</label>
                    <input class="form-control" id="smtp_user" type="email" name="smtp_user" value="<%= settings.smtp_user || '' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="smtp_password">SMTP Passwort</label>
                    <input class="form-control" id="smtp_password" type="password" name="smtp_password" value="<%= settings.smtp_password || '' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="smtp_from">Absenderadresse</label>
                    <input class="form-control" id="smtp_from" type="email" name="smtp_from" value="<%= settings.smtp_from || '' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="notification_email_to">Empfänger für Erinnerungen / Tests</label>
                    <input class="form-control" id="notification_email_to" type="email" name="notification_email_to" value="<%= settings.notification_email_to || '' %>" placeholder="leer = SMTP Benutzer verwenden" />
                  </div>
                  <div class="col-12">
                    <div class="form-check">
                      <input class="form-check-input" id="smtp_secure" type="checkbox" name="smtp_secure" <%= settings.smtp_secure === 'true' ? 'checked' : '' %> />
                      <label class="form-check-label" for="smtp_secure">SMTPS / SSL direkt verwenden</label>
                    </div>
                  </div>
                </div>
              </div>
            </section>
            <div class="d-flex justify-content-end">
              <button type="submit" class="btn btn-success">E-Mail speichern</button>
            </div>
          </form>

          <section class="card border-0 bg-body-tertiary">
            <div class="card-body vstack gap-3">
              <div>
                <h3 class="h5 mb-1">Prüfen und testen</h3>
                <p class="text-body-secondary mb-0">Nach dem Speichern kannst du hier direkt prüfen, ob sich der SMTP-Server erreichen lässt und ob Testmails sauber ankommen.</p>
              </div>
              <div class="d-flex flex-wrap gap-2">
                <form method="post" action="/admin/test-smtp-connection">
                  <button type="submit" class="btn btn-outline-secondary">SMTP-Verbindung prüfen</button>
                </form>
                <form method="post" action="/admin/test-email">
                  <button type="submit" class="btn btn-outline-secondary">SMTP-Testmail senden</button>
                </form>
              </div>
              <div class="alert alert-secondary mb-0" role="alert">
                Letzter erfolgreicher Test:
                <strong><%= communicationStatus.emailLastSuccessfulCheckAt ? formatDateTime(communicationStatus.emailLastSuccessfulCheckAt) : 'Noch kein erfolgreicher Test' %></strong>
              </div>
              <div class="alert alert-secondary mb-0" role="alert">
                Zustellbarkeit: Für stabile Zustellung sollten SPF, DKIM und DMARC für deine Absender-Domain korrekt gesetzt sein. Prüfe zusätzlich regelmäßig den Versandstatus im Systemlog.
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>

  <div class="accordion-item">
    <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center gap-2 p-3 border-bottom">
      <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#communication-telegram" aria-expanded="false" aria-controls="communication-telegram">
        Telegram
      </button>
      <div class="d-flex flex-wrap gap-2">
        <span class="status-chip setup-status-chip <%= communicationStatus.telegramReady ? 'status-ok' : 'status-muted' %>">
          <%= communicationStatus.telegramReady ? 'Konfiguriert' : 'Nicht konfiguriert' %>
        </span>
        <button type="submit" form="toggle-telegram-enabled-form" class="status-chip service-status-chip <%= settings.reminder_telegram_enabled === 'true' ? 'status-active' : 'status-muted' %>">
          <%= settings.reminder_telegram_enabled === 'true' ? 'Aktiviert' : 'Deaktiviert' %>
        </button>
      </div>
    </div>
    <div id="communication-telegram" class="accordion-collapse collapse" data-bs-parent="#communicationAccordion">
      <div class="accordion-body">
        <div class="vstack gap-4">
          <form id="telegram-settings-form" method="post" action="/admin/settings" class="vstack gap-4">
            <input type="hidden" name="_fields" value="telegram_bot_token,telegram_chat_id" />

            <section class="card border-0 bg-body-tertiary">
              <div class="card-body vstack gap-3">
                <div>
                  <h3 class="h5 mb-1">Telegram verbinden</h3>
                  <p class="text-body-secondary mb-0">Hier hinterlegst du die Zugangsdaten deines Bots. Wenn beides gespeichert ist, kann HeartPet Erinnerungen direkt an deinen Telegram-Chat senden.</p>
                </div>
                <div>
                  <h4 class="h6 mb-1">BotFather-Anleitung</h4>
                  <p class="text-body-secondary mb-2">Wenn du Telegram zum ersten Mal einrichtest, geh diese Schritte einmal in Ruhe durch.</p>
                  <div class="alert alert-secondary mb-0" role="alert">
                    <ol class="mb-0 ps-3">
                      <li>In Telegram <strong>@BotFather</strong> öffnen.</li>
                      <li>Mit <strong>/newbot</strong> einen Bot erstellen und den Token kopieren.</li>
                      <li>Wichtig: Oben nur den Token selbst speichern. Das Präfix <strong>bot</strong> wird von HeartPet beim API-Aufruf automatisch ergänzt.</li>
                      <li>Dem Bot einmal schreiben.</li>
                      <li>Im Browser <strong>https://api.telegram.org/botTOKEN/getUpdates</strong> aufrufen und die <strong>chat.id</strong> auslesen.</li>
                      <li>Token und Chat ID links speichern.</li>
                    </ol>
                  </div>
                </div>
              </div>
            </section>

            <section class="card border-0 bg-body-tertiary">
              <div class="card-body">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label" for="telegram_bot_token">Telegram Bot Token</label>
                    <input class="form-control" id="telegram_bot_token" type="text" name="telegram_bot_token" value="<%= settings.telegram_bot_token || '' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="telegram_chat_id">Telegram Chat ID</label>
                    <input class="form-control" id="telegram_chat_id" type="text" name="telegram_chat_id" value="<%= settings.telegram_chat_id || '' %>" />
                  </div>
                  <div class="col-12">
                    <div class="alert alert-secondary mb-0" role="alert">Nur den echten Token aus BotFather eintragen. Das Wort <strong>bot</strong> gehört nicht zum gespeicherten Token dazu.</div>
                  </div>
                </div>
              </div>
            </section>

            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 pt-2 border-top">
              <p class="text-body-secondary small mb-0">Oben im Akkordeon-Kopf kannst du Telegram jederzeit direkt aktivieren oder deaktivieren, ohne die restlichen Einstellungen zu ändern.</p>
              <button type="submit" class="btn btn-success">Telegram speichern</button>
            </div>
          </form>

          <section class="card border-0 bg-body-tertiary">
            <div class="card-body vstack gap-3">
              <div>
                <h3 class="h5 mb-1">Prüfen und testen</h3>
                <p class="text-body-secondary mb-0">Wenn Token und Chat ID gespeichert sind, kannst du hier direkt eine Testnachricht an Telegram senden.</p>
              </div>
              <div class="d-flex flex-wrap gap-2">
                <form id="telegram-test-form" method="post" action="/admin/test-telegram">
                  <button type="submit" class="btn btn-outline-secondary">Telegram-Test senden</button>
                </form>
              </div>
              <div class="alert alert-secondary mb-0" role="alert">
                Letzter erfolgreicher Test:
                <strong><%= communicationStatus.telegramLastSuccessfulCheckAt ? formatDateTime(communicationStatus.telegramLastSuccessfulCheckAt) : 'Noch kein erfolgreicher Test' %></strong>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/bottom') %>
