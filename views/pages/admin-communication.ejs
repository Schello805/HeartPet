<%- include('../partials/top', { pageTitle }) %>

<section class="accordion-stack">
  <details class="accordion-item" open>
    <summary>E-Mail und allgemeine Benachrichtigungen</summary>
    <div class="accordion-content">
      <form method="post" action="/admin/settings" class="form-grid">
        <input type="hidden" name="_fields" value="smtp_host,smtp_port,smtp_user,smtp_password,smtp_from,notification_email_to,smtp_secure,reminder_email_enabled,browser_notifications_enabled" />
        <label>
          <span>SMTP Host</span>
          <input type="text" name="smtp_host" value="<%= settings.smtp_host || '' %>" />
        </label>
        <label>
          <span>SMTP Port</span>
          <input type="number" name="smtp_port" value="<%= settings.smtp_port || '587' %>" />
        </label>
        <label>
          <span>SMTP Benutzer</span>
          <input type="email" name="smtp_user" value="<%= settings.smtp_user || '' %>" />
        </label>
        <label>
          <span>SMTP Passwort</span>
          <input type="password" name="smtp_password" value="<%= settings.smtp_password || '' %>" />
        </label>
        <label>
          <span>Absenderadresse</span>
          <input type="email" name="smtp_from" value="<%= settings.smtp_from || '' %>" />
        </label>
        <label>
          <span>Empfänger für Erinnerungen / Tests</span>
          <input type="email" name="notification_email_to" value="<%= settings.notification_email_to || '' %>" placeholder="leer = SMTP Benutzer verwenden" />
        </label>
        <label class="checkbox-line">
          <input type="checkbox" name="smtp_secure" <%= settings.smtp_secure === 'true' ? 'checked' : '' %> />
          SMTPS / SSL direkt verwenden
        </label>
        <label class="checkbox-line full-width">
          <input type="checkbox" name="reminder_email_enabled" <%= settings.reminder_email_enabled === 'true' ? 'checked' : '' %> />
          Erinnerungen per E-Mail aktivieren
        </label>
        <label class="checkbox-line full-width">
          <input type="checkbox" name="browser_notifications_enabled" <%= settings.browser_notifications_enabled === 'true' ? 'checked' : '' %> />
          Browser-Hinweise für offene Erinnerungen aktivieren
        </label>
        <div class="full-width form-actions">
          <button type="submit" class="button">E-Mail-Einstellungen speichern</button>
        </div>
      </form>

      <div class="status-row">
        <span class="status-chip <%= communicationStatus.emailReady ? 'status-ok' : 'status-muted' %>">
          <%= communicationStatus.emailReady ? 'E-Mail Versand bereit' : 'E-Mail Versand noch nicht vollständig konfiguriert' %>
        </span>
        <form method="post" action="/admin/test-email">
          <button type="submit" class="button button-secondary">SMTP-Testmail senden</button>
        </form>
      </div>
    </div>
  </details>

  <details class="accordion-item">
    <summary>Erinnerungsregeln je Ereignis</summary>
    <div class="accordion-content">
      <form method="post" action="/admin/settings" class="form-grid">
        <input type="hidden" name="_fields" value="medication_reminder_lead_days,medication_reminder_repeat_count,vaccination_reminder_lead_days,vaccination_reminder_repeat_count,appointment_reminder_lead_days,appointment_reminder_repeat_count" />
        <div class="full-width note-box">
          Diese Regeln gelten nur für Ereignisse, bei denen in der Tierakte der Haken <strong>Erinnern</strong> gesetzt wurde.
          E-Mail und Telegram werden global oben aktiviert und gelten dann zusätzlich für alle passenden Ereignisse.
        </div>
        <label>
          <span>Medikamente: Tage vorher</span>
          <input type="number" min="0" step="1" name="medication_reminder_lead_days" value="<%= settings.medication_reminder_lead_days || '0' %>" />
        </label>
        <label>
          <span>Medikamente: Anzahl Erinnerungen</span>
          <input type="number" min="0" step="1" name="medication_reminder_repeat_count" value="<%= settings.medication_reminder_repeat_count || '0' %>" />
        </label>
        <label>
          <span>Impfungen: Tage vorher</span>
          <input type="number" min="0" step="1" name="vaccination_reminder_lead_days" value="<%= settings.vaccination_reminder_lead_days || '30' %>" />
        </label>
        <label>
          <span>Impfungen: Anzahl Erinnerungen</span>
          <input type="number" min="0" step="1" name="vaccination_reminder_repeat_count" value="<%= settings.vaccination_reminder_repeat_count || '1' %>" />
        </label>
        <label>
          <span>Arzttermine: Tage vorher</span>
          <input type="number" min="0" step="1" name="appointment_reminder_lead_days" value="<%= settings.appointment_reminder_lead_days || '1' %>" />
        </label>
        <label>
          <span>Arzttermine: Anzahl Erinnerungen</span>
          <input type="number" min="0" step="1" name="appointment_reminder_repeat_count" value="<%= settings.appointment_reminder_repeat_count || '1' %>" />
        </label>
        <div class="full-width note-box">Die Anzahl steuert, wie viele Erinnerungen automatisch erzeugt werden. Bei mehreren Erinnerungen wird ab dem Vorlauf täglich erinnert.</div>
        <div class="full-width form-actions">
          <button type="submit" class="button">Erinnerungsregeln speichern</button>
        </div>
      </form>
    </div>
  </details>

  <details class="accordion-item">
    <summary>Telegram</summary>
    <div class="accordion-content">
      <form method="post" action="/admin/settings" class="stack">
        <input type="hidden" name="_fields" value="telegram_bot_token,telegram_chat_id,reminder_telegram_enabled" />
        <label>
          <span>Telegram Bot Token</span>
          <input type="text" name="telegram_bot_token" value="<%= settings.telegram_bot_token || '' %>" />
        </label>
        <label>
          <span>Telegram Chat ID</span>
          <input type="text" name="telegram_chat_id" value="<%= settings.telegram_chat_id || '' %>" />
        </label>
        <label class="checkbox-line">
          <input type="checkbox" name="reminder_telegram_enabled" <%= settings.reminder_telegram_enabled === 'true' ? 'checked' : '' %> />
          Erinnerungen per Telegram aktivieren
        </label>
        <button type="submit" class="button">Telegram speichern</button>
      </form>

      <div class="status-row">
        <span class="status-chip <%= communicationStatus.telegramReady ? 'status-ok' : 'status-muted' %>">
          <%= communicationStatus.telegramReady ? 'Telegram Versand bereit' : 'Telegram Versand noch nicht vollständig konfiguriert' %>
        </span>
        <form method="post" action="/admin/test-telegram">
          <button type="submit" class="button button-secondary">Telegram-Test senden</button>
        </form>
      </div>

      <div class="note-box">
        Telegram Bot Anleitung:
        <ol>
          <li>In Telegram <strong>@BotFather</strong> öffnen.</li>
          <li>Mit <strong>/newbot</strong> einen Bot erstellen und den Token kopieren.</li>
          <li>Dem Bot einmal schreiben.</li>
          <li>Im Browser <strong>https://api.telegram.org/botTOKEN/getUpdates</strong> aufrufen und die <strong>chat.id</strong> auslesen.</li>
          <li>Token und Chat ID oben speichern.</li>
        </ol>
      </div>
    </div>
  </details>
</section>

<%- include('../partials/bottom') %>
