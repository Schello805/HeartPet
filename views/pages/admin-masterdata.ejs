<%- include('../partials/top', { pageTitle }) %>
<% const defaultVetIdState = typeof defaultVeterinarianId !== 'undefined' && defaultVeterinarianId ? String(defaultVeterinarianId) : ''; %>

<section class="masterdata-hero panel">
  <div>
    <p class="eyebrow">Verwaltung</p>
    <h2>Stammdaten kompakt verwalten</h2>
    <p class="help-copy">Tierärzte, Tierarten und Dokumentkategorien in einer klareren Desktop-Ansicht mit weniger Leerraum.</p>
  </div>
  <div class="masterdata-hero-stats">
    <div class="pill">Kategorien <strong><%= categories.length %></strong></div>
    <div class="pill">Tierärzte <strong><%= veterinarians.length %></strong></div>
    <div class="pill">Tierarten <strong><%= species.length %></strong></div>
  </div>
</section>

<section class="accordion-stack masterdata-layout">
  <details id="stammdaten-kategorien" class="accordion-item masterdata-section masterdata-section-wide" open>
    <summary>Dokumentkategorien</summary>
    <div class="accordion-content">
      <p class="compact-note">Hier legst du fest, wie hochgeladene Unterlagen einsortiert werden. Pflichtkategorien helfen dabei, wichtige Nachweise später schneller wiederzufinden.</p>
      <div class="button-row">
        <a href="/admin/categories/new" class="button" data-drawer="masterdata-form">Neue Kategorie</a>
      </div>
      <div class="masterdata-category-grid compact-list">
        <% categories.forEach((category) => { %>
          <div class="list-card static-card masterdata-category-card">
            <div>
              <strong><%= category.name %></strong>
              <p><%= category.is_required ? 'Pflichtkategorie' : 'Optional' %></p>
            </div>
            <div class="inline-actions masterdata-category-actions">
              <a href="/admin/categories/<%= category.id %>/edit" data-drawer="masterdata-form" class="button button-secondary icon-button" aria-label="Dokumentkategorie bearbeiten" title="Bearbeiten">
                <span aria-hidden="true">✎</span>
                <span class="visually-hidden">Bearbeiten</span>
              </a>
              <form method="post" action="/admin/categories/<%= category.id %>/delete" data-confirm="Dokumentkategorie wirklich löschen?">
                <button type="submit" class="button button-danger icon-button" aria-label="Dokumentkategorie löschen" title="Löschen">
                  <span aria-hidden="true">🗑</span>
                  <span class="visually-hidden">Löschen</span>
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </details>

  <details id="stammdaten-tieraerzte" class="accordion-item masterdata-section">
    <summary>Tierärzte</summary>
    <div class="accordion-content">
      <p class="compact-note">Tierärzte können global hinterlegt und später einzelnen Tierarten oder direkt einem Tier zugeordnet werden. Der Standardtierarzt dient als Fallback, wenn beim Tier selbst nichts ausgewählt ist.</p>
      <div class="button-row">
        <a href="/admin/veterinarians/new" class="button" data-drawer="masterdata-form">Neuer Tierarzt</a>
      </div>
      <div class="masterdata-card-grid compact-list">
        <% veterinarians.forEach((vet) => { %>
          <div class="list-card static-card masterdata-entity-card">
            <div>
              <strong><%= vet.name %></strong>
              <% if (defaultVetIdState === String(vet.id)) { %>
                <p><span class="status-chip status-ok">Standardtierarzt</span></p>
              <% } %>
              <p><%= [vet.street, vet.postal_code, vet.city, vet.country].filter(Boolean).join(', ') || 'Keine Adresse' %></p>
              <p><%= vet.phone || '-' %> | <%= vet.email || '-' %></p>
            </div>
            <div class="inline-actions">
              <a href="/admin/veterinarians/<%= vet.id %>/edit" data-drawer="masterdata-form" class="button button-secondary icon-button" aria-label="Tierarzt bearbeiten" title="Bearbeiten">
                <span aria-hidden="true">✎</span>
                <span class="visually-hidden">Bearbeiten</span>
              </a>
              <% if (defaultVetIdState !== String(vet.id)) { %>
                <form method="post" action="/admin/veterinarians/<%= vet.id %>/set-default">
                  <button type="submit" class="button button-secondary" title="Wird automatisch verwendet, wenn bei einer Tierart oder einem Tier kein eigener Tierarzt hinterlegt ist.">Als Standard markieren</button>
                </form>
              <% } %>
              <form method="post" action="/admin/veterinarians/<%= vet.id %>/delete" data-confirm="Tierarzt wirklich löschen?">
                <button type="submit" class="button button-danger icon-button" aria-label="Tierarzt löschen" title="Löschen">
                  <span aria-hidden="true">🗑</span>
                  <span class="visually-hidden">Löschen</span>
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </details>

  <details id="stammdaten-tierarten" class="accordion-item masterdata-section">
    <summary>Tierarten</summary>
    <div class="accordion-content">
      <p class="compact-note">Tierarten helfen dir bei der sauberen Struktur. Du kannst hier pro Art einen Standardtierarzt hinterlegen, der beim Anlegen neuer Tiere automatisch vorgeschlagen wird.</p>
      <div class="button-row">
        <a href="/admin/species/new" class="button" data-drawer="masterdata-form">Neue Tierart</a>
      </div>
      <div class="masterdata-card-grid compact-list">
        <% species.forEach((item) => { %>
          <div class="list-card static-card masterdata-entity-card">
            <div>
              <strong><%= item.name %></strong>
              <p>Standard Tierarzt: <%= item.veterinarian_name || '-' %></p>
            </div>
            <div class="inline-actions">
              <a href="/admin/species/<%= item.id %>/edit" data-drawer="masterdata-form" class="button button-secondary icon-button" aria-label="Tierart bearbeiten" title="Bearbeiten">
                <span aria-hidden="true">✎</span>
                <span class="visually-hidden">Bearbeiten</span>
              </a>
              <form method="post" action="/admin/species/<%= item.id %>/delete" data-confirm="Tierart wirklich löschen?">
                <button type="submit" class="button button-danger icon-button" aria-label="Tierart löschen" title="Löschen">
                  <span aria-hidden="true">🗑</span>
                  <span class="visually-hidden">Löschen</span>
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </details>
</section>

<%- include('../partials/bottom') %>
