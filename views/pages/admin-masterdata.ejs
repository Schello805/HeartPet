<%- include('../partials/top', { pageTitle }) %>
<% const defaultVetIdState = typeof defaultVeterinarianId !== 'undefined' && defaultVeterinarianId ? String(defaultVeterinarianId) : ''; %>

<section class="card border-0 bg-body-tertiary mb-3">
  <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3">
    <div>
      <h2 class="h4 mb-1">Stammdaten kompakt verwalten</h2>
      <p class="text-body-secondary mb-0">Tierärzte, Tierarten und Dokumentkategorien in einer klareren Übersicht mit weniger Sonderlogik.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <span class="badge text-bg-secondary">Kategorien <%= categories.length %></span>
      <span class="badge text-bg-secondary">Tierärzte <%= veterinarians.length %></span>
      <span class="badge text-bg-secondary">Tierarten <%= species.length %></span>
    </div>
  </div>
</section>

<div class="accordion" id="masterdataAccordion">
  <div class="accordion-item">
    <h2 class="accordion-header" id="masterdata-categories-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#stammdaten-kategorien" aria-expanded="false" aria-controls="stammdaten-kategorien">
        Dokumentkategorien
      </button>
    </h2>
    <div id="stammdaten-kategorien" class="accordion-collapse collapse" aria-labelledby="masterdata-categories-heading" data-bs-parent="#masterdataAccordion">
      <div class="accordion-body">
        <div class="vstack gap-3">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <p class="text-body-secondary mb-0">Hier legst du fest, wie hochgeladene Unterlagen einsortiert werden. Pflichtkategorien helfen dabei, wichtige Nachweise später schneller wiederzufinden.</p>
            <a href="/admin/categories/new" class="btn btn-success" data-drawer="masterdata-form">Neue Kategorie</a>
          </div>

          <% if (!categories.length) { %>
            <div class="card border bg-body">
              <div class="card-body">
                <strong class="d-block mb-1">Noch keine Dokumentkategorien</strong>
                <p class="text-body-secondary mb-0">Lege zuerst die wichtigsten Kategorien an, damit Unterlagen später sauber einsortiert werden.</p>
              </div>
            </div>
          <% } else { %>
            <div class="row g-3">
              <% categories.forEach((category) => { %>
                <div class="col-lg-6">
                  <div class="card border bg-body h-100">
                    <div class="card-body d-flex justify-content-between align-items-start gap-3">
                      <div>
                        <strong class="d-block mb-1"><%= category.name %></strong>
                        <p class="text-body-secondary mb-0"><%= category.is_required ? 'Pflichtkategorie' : 'Optional' %></p>
                      </div>
                      <div class="d-flex gap-2">
                        <a href="/admin/categories/<%= category.id %>/edit" data-drawer="masterdata-form" class="btn btn-outline-secondary btn-sm" aria-label="Dokumentkategorie bearbeiten">Bearbeiten</a>
                        <form method="post" action="/admin/categories/<%= category.id %>/delete" data-confirm="Dokumentkategorie wirklich löschen?">
                          <button type="submit" class="btn btn-outline-danger btn-sm" aria-label="Dokumentkategorie löschen">Löschen</button>
                        </form>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="accordion-item">
    <h2 class="accordion-header" id="masterdata-vets-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#stammdaten-tieraerzte" aria-expanded="false" aria-controls="stammdaten-tieraerzte">
        Tierärzte
      </button>
    </h2>
    <div id="stammdaten-tieraerzte" class="accordion-collapse collapse" aria-labelledby="masterdata-vets-heading" data-bs-parent="#masterdataAccordion">
      <div class="accordion-body">
        <div class="vstack gap-3">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <p class="text-body-secondary mb-0">Tierärzte können global hinterlegt und später einzelnen Tierarten oder direkt einem Tier zugeordnet werden. Der Standardtierarzt dient als Fallback, wenn beim Tier selbst nichts ausgewählt ist.</p>
            <a href="/admin/veterinarians/new" class="btn btn-success" data-drawer="masterdata-form">Neuer Tierarzt</a>
          </div>

          <% if (!veterinarians.length) { %>
            <div class="card border bg-body">
              <div class="card-body">
                <strong class="d-block mb-1">Noch keine Tierärzte</strong>
                <p class="text-body-secondary mb-0">Sobald du Tierärzte anlegst, kannst du sie hier als Standard markieren oder einzelnen Tieren zuordnen.</p>
              </div>
            </div>
          <% } else { %>
            <div class="row g-3">
              <% veterinarians.forEach((vet) => { %>
                <div class="col-xl-6">
                  <div class="card border bg-body h-100">
                    <div class="card-body d-flex flex-column gap-3">
                      <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                          <strong class="d-block mb-1"><%= vet.name %></strong>
                          <% if (defaultVetIdState === String(vet.id)) { %>
                            <p class="mb-2"><span class="status-chip status-ok">Standardtierarzt</span></p>
                          <% } %>
                          <p class="text-body-secondary mb-1"><%= [vet.street, vet.postal_code, vet.city, vet.country].filter(Boolean).join(', ') || 'Keine Adresse' %></p>
                          <p class="text-body-secondary mb-0"><%= vet.phone || '-' %> | <%= vet.email || '-' %></p>
                        </div>
                      </div>
                      <div class="d-flex flex-wrap gap-2">
                        <a href="/admin/veterinarians/<%= vet.id %>/edit" data-drawer="masterdata-form" class="btn btn-outline-secondary btn-sm" aria-label="Tierarzt bearbeiten">Bearbeiten</a>
                        <% if (defaultVetIdState !== String(vet.id)) { %>
                          <form method="post" action="/admin/veterinarians/<%= vet.id %>/set-default">
                            <button type="submit" class="btn btn-outline-secondary btn-sm" title="Wird automatisch verwendet, wenn bei einer Tierart oder einem Tier kein eigener Tierarzt hinterlegt ist.">Als Standard markieren</button>
                          </form>
                        <% } %>
                        <form method="post" action="/admin/veterinarians/<%= vet.id %>/delete" data-confirm="Tierarzt wirklich löschen?">
                          <button type="submit" class="btn btn-outline-danger btn-sm" aria-label="Tierarzt löschen">Löschen</button>
                        </form>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="accordion-item">
    <h2 class="accordion-header" id="masterdata-species-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#stammdaten-tierarten" aria-expanded="false" aria-controls="stammdaten-tierarten">
        Tierarten
      </button>
    </h2>
    <div id="stammdaten-tierarten" class="accordion-collapse collapse" aria-labelledby="masterdata-species-heading" data-bs-parent="#masterdataAccordion">
      <div class="accordion-body">
        <div class="vstack gap-3">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <p class="text-body-secondary mb-0">Tierarten helfen dir bei der sauberen Struktur. Du kannst hier pro Art einen Standardtierarzt hinterlegen, der beim Anlegen neuer Tiere automatisch vorgeschlagen wird.</p>
            <a href="/admin/species/new" class="btn btn-success" data-drawer="masterdata-form">Neue Tierart</a>
          </div>

          <% if (!species.length) { %>
            <div class="card border bg-body">
              <div class="card-body">
                <strong class="d-block mb-1">Noch keine Tierarten</strong>
                <p class="text-body-secondary mb-0">Tierarten helfen dir bei Filtern, Standardtierärzten und einem sauberen Bestand.</p>
              </div>
            </div>
          <% } else { %>
            <div class="row g-3">
              <% species.forEach((item) => { %>
                <div class="col-xl-6">
                  <div class="card border bg-body h-100">
                    <div class="card-body d-flex justify-content-between align-items-start gap-3">
                      <div>
                        <strong class="d-block mb-1"><%= item.name %></strong>
                        <p class="text-body-secondary mb-0">Standard Tierarzt: <%= item.veterinarian_name || '-' %></p>
                      </div>
                      <div class="d-flex gap-2">
                        <a href="/admin/species/<%= item.id %>/edit" data-drawer="masterdata-form" class="btn btn-outline-secondary btn-sm" aria-label="Tierart bearbeiten">Bearbeiten</a>
                        <form method="post" action="/admin/species/<%= item.id %>/delete" data-confirm="Tierart wirklich löschen?">
                          <button type="submit" class="btn btn-outline-danger btn-sm" aria-label="Tierart löschen">Löschen</button>
                        </form>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/bottom') %>
