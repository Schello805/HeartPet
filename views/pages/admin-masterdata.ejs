<%- include('../partials/top', { pageTitle }) %>
<% const masterEditState = typeof masterEdit !== 'undefined' && masterEdit ? masterEdit : { categoryId: null, speciesId: null, veterinarianId: null }; %>

<section class="accordion-stack">
  <details class="accordion-item" open>
    <summary>Dokumentkategorien</summary>
    <div class="accordion-content">
      <div class="stack compact-list">
        <% categories.forEach((category) => { %>
          <% if (masterEditState.categoryId === category.id) { %>
            <form method="post" action="/admin/categories/<%= category.id %>/update" class="stack form-compact list-card static-card">
              <input type="text" name="name" required value="<%= category.name %>" />
              <label class="checkbox-line">
                <input type="checkbox" name="is_required" <%= category.is_required ? 'checked' : '' %> />
                Als Pflichtkategorie markieren
              </label>
              <div class="inline-actions">
                <button type="submit" class="button">Speichern</button>
                <a href="/admin/stammdaten" class="button button-secondary">Abbrechen</a>
              </div>
            </form>
          <% } else { %>
            <div class="list-card static-card">
              <div>
                <strong><%= category.name %></strong>
                <p><%= category.is_required ? 'Pflichtkategorie' : 'Optional' %></p>
              </div>
              <div class="inline-actions">
                <a href="/admin/stammdaten?editCategory=<%= category.id %>" class="button button-secondary">Bearbeiten</a>
                <form method="post" action="/admin/categories/<%= category.id %>/delete" data-confirm="Dokumentkategorie wirklich löschen?">
                  <button type="submit" class="button button-danger">Löschen</button>
                </form>
              </div>
            </div>
          <% } %>
        <% }) %>
      </div>
      <form method="post" action="/admin/categories" class="stack form-compact">
        <input type="text" name="name" required placeholder="Neue Kategorie" />
        <label class="checkbox-line">
          <input type="checkbox" name="is_required" />
          Als Pflichtkategorie markieren
        </label>
        <button type="submit" class="button">Anlegen</button>
      </form>
    </div>
  </details>

  <details class="accordion-item">
    <summary>Tierärzte</summary>
    <div class="accordion-content">
      <div class="stack compact-list">
        <% veterinarians.forEach((vet) => { %>
          <% if (masterEditState.veterinarianId === vet.id) { %>
            <form method="post" action="/admin/veterinarians/<%= vet.id %>/update" class="stack form-compact list-card static-card">
              <input type="text" name="name" required value="<%= vet.name %>" />
              <input type="text" name="street" placeholder="Straße und Hausnummer" minlength="3" maxlength="120" pattern="[A-Za-zÄÖÜäöüß0-9 .,\-\/]{3,120}" value="<%= vet.street || '' %>" />
              <div class="mini-grid">
                <input type="text" name="postal_code" placeholder="PLZ" minlength="3" maxlength="12" pattern="[A-Za-z0-9 -]{3,12}" value="<%= vet.postal_code || '' %>" />
                <input type="text" name="city" placeholder="Ort" minlength="2" maxlength="80" pattern="[A-Za-zÄÖÜäöüß0-9 .'\-]{2,80}" value="<%= vet.city || '' %>" />
              </div>
              <input type="text" name="country" placeholder="Land" minlength="2" maxlength="80" pattern="[A-Za-zÄÖÜäöüß .'\-]{2,80}" value="<%= vet.country || '' %>" />
              <input type="text" name="phone" placeholder="Telefon" value="<%= vet.phone || '' %>" />
              <input type="email" name="email" placeholder="E-Mail" value="<%= vet.email || '' %>" />
              <textarea name="notes" rows="3" placeholder="Notizen"><%= vet.notes || '' %></textarea>
              <div class="inline-actions">
                <button type="submit" class="button">Speichern</button>
                <a href="/admin/stammdaten" class="button button-secondary">Abbrechen</a>
              </div>
            </form>
          <% } else { %>
            <div class="list-card static-card">
              <div>
                <strong><%= vet.name %></strong>
                <% if (String(defaultVeterinarianId || '') === String(vet.id)) { %>
                  <p><span class="status-chip status-ok">Standardtierarzt</span></p>
                <% } %>
                <p><%= [vet.street, vet.postal_code, vet.city, vet.country].filter(Boolean).join(', ') || 'Keine Adresse' %></p>
                <p><%= vet.phone || '-' %> | <%= vet.email || '-' %></p>
              </div>
              <div class="inline-actions">
                <a href="/admin/stammdaten?editVeterinarian=<%= vet.id %>" class="button button-secondary">Bearbeiten</a>
                <% if (String(defaultVeterinarianId || '') !== String(vet.id)) { %>
                  <form method="post" action="/admin/veterinarians/<%= vet.id %>/set-default">
                    <button type="submit" class="button button-secondary">Als Standard markieren</button>
                  </form>
                <% } %>
                <form method="post" action="/admin/veterinarians/<%= vet.id %>/delete" data-confirm="Tierarzt wirklich löschen?">
                  <button type="submit" class="button button-danger">Löschen</button>
                </form>
              </div>
            </div>
          <% } %>
        <% }) %>
      </div>
      <form method="post" action="/admin/veterinarians" class="stack form-compact">
        <input type="text" name="name" required placeholder="Name" />
        <input type="text" name="street" placeholder="Straße und Hausnummer" minlength="3" maxlength="120" pattern="[A-Za-zÄÖÜäöüß0-9 .,\-\/]{3,120}" />
        <div class="mini-grid">
          <input type="text" name="postal_code" placeholder="PLZ" minlength="3" maxlength="12" pattern="[A-Za-z0-9 -]{3,12}" />
          <input type="text" name="city" placeholder="Ort" minlength="2" maxlength="80" pattern="[A-Za-zÄÖÜäöüß0-9 .'\-]{2,80}" />
        </div>
        <input type="text" name="country" placeholder="Land" minlength="2" maxlength="80" pattern="[A-Za-zÄÖÜäöüß .'\-]{2,80}" />
        <input type="text" name="phone" placeholder="Telefon" />
        <input type="email" name="email" placeholder="E-Mail" />
        <textarea name="notes" rows="3" placeholder="Notizen"></textarea>
        <button type="submit" class="button">Speichern</button>
      </form>
    </div>
  </details>

  <details class="accordion-item">
    <summary>Tierarten</summary>
    <div class="accordion-content">
      <div class="stack compact-list">
        <% species.forEach((item) => { %>
          <% if (masterEditState.speciesId === item.id) { %>
            <form method="post" action="/admin/species/<%= item.id %>/update" class="stack form-compact list-card static-card">
              <input type="text" name="name" required value="<%= item.name %>" />
              <select name="default_veterinarian_id">
                <option value="">Kein Standard-Tierarzt</option>
                <% veterinarians.forEach((vet) => { %>
                  <option value="<%= vet.id %>" <%= String(item.default_veterinarian_id || '') === String(vet.id) ? 'selected' : '' %>><%= vet.name %></option>
                <% }) %>
              </select>
              <textarea name="notes" rows="3" placeholder="Notizen"><%= item.notes || '' %></textarea>
              <div class="inline-actions">
                <button type="submit" class="button">Speichern</button>
                <a href="/admin/stammdaten" class="button button-secondary">Abbrechen</a>
              </div>
            </form>
          <% } else { %>
            <div class="list-card static-card">
              <div>
                <strong><%= item.name %></strong>
                <p>Standard Tierarzt: <%= item.veterinarian_name || '-' %></p>
              </div>
              <div class="inline-actions">
                <a href="/admin/stammdaten?editSpecies=<%= item.id %>" class="button button-secondary">Bearbeiten</a>
                <form method="post" action="/admin/species/<%= item.id %>/delete" data-confirm="Tierart wirklich löschen?">
                  <button type="submit" class="button button-danger">Löschen</button>
                </form>
              </div>
            </div>
          <% } %>
        <% }) %>
      </div>
      <form method="post" action="/admin/species" class="stack form-compact">
        <input type="text" name="name" required placeholder="Tierart" />
        <select name="default_veterinarian_id">
          <option value="">Kein Standard-Tierarzt</option>
          <% veterinarians.forEach((vet) => { %>
            <option value="<%= vet.id %>"><%= vet.name %></option>
          <% }) %>
        </select>
        <textarea name="notes" rows="3" placeholder="Notizen"></textarea>
        <button type="submit" class="button">Speichern</button>
      </form>
    </div>
  </details>
</section>

<%- include('../partials/bottom') %>
