<!DOCTYPE html>
<html lang="de">
  <head>
    <% const resolvedAssetBaseUrl = typeof assetBaseUrl !== 'undefined' && assetBaseUrl ? assetBaseUrl.replace(/\/+$/, '') : ''; %>
    <% const resolvedAppLogoUrl = typeof appLogoUrl !== 'undefined' && appLogoUrl ? appLogoUrl : `${resolvedAssetBaseUrl}/static/images/logo-heartpet.png`; %>
    <% const absoluteLogoUrl = /^https?:\/\//i.test(resolvedAppLogoUrl) ? resolvedAppLogoUrl : `${resolvedAssetBaseUrl}${resolvedAppLogoUrl.startsWith('/') ? '' : '/'}${resolvedAppLogoUrl}`; %>
    <% const canonicalUrl = `${resolvedAssetBaseUrl}/reminders`; %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | <%= appSettings?.app_name || 'HeartPet' %></title>
    <meta name="description" content="Rückmeldung zu einer HeartPet-Erinnerung. Interne Bestätigungsseite für E-Mail-Aktionen." />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="canonical" href="<%= canonicalUrl %>" />
    <meta property="og:title" content="<%= pageTitle %> | <%= appSettings?.app_name || 'HeartPet' %>" />
    <meta property="og:description" content="Rückmeldung zu einer HeartPet-Erinnerung. Interne Bestätigungsseite für E-Mail-Aktionen." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="<%= canonicalUrl %>" />
    <meta property="og:image" content="<%= absoluteLogoUrl %>" />
    <link rel="icon" type="image/png" sizes="any" href="<%= resolvedAppLogoUrl %>" />
    <link rel="shortcut icon" type="image/png" href="<%= resolvedAppLogoUrl %>" />
    <link rel="apple-touch-icon" href="<%= resolvedAppLogoUrl %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous" />
    <link rel="stylesheet" href="<%= `${resolvedAssetBaseUrl}/static/css/theme-foundation.css` %>" />
    <link rel="stylesheet" href="<%= `${resolvedAssetBaseUrl}/static/css/theme-layout.css` %>" />
    <link rel="stylesheet" href="<%= `${resolvedAssetBaseUrl}/static/css/theme-components.css` %>" />
  </head>
  <body class="bootstrap-app" data-bs-theme="dark">
    <main class="container py-5 min-vh-100 d-flex align-items-center">
      <div class="row justify-content-center w-100">
        <div class="col-12 col-sm-11 col-md-9 col-lg-7 col-xl-6">
          <section class="card border-0 shadow-sm bg-body-tertiary">
            <div class="card-body p-4 p-lg-5">
              <div class="d-flex align-items-center gap-3 mb-4">
                <img class="brand-logo" src="<%= resolvedAppLogoUrl %>" alt="HeartPet Logo" />
                <div>
                  <h1 class="h3 mb-1"><%= title %></h1>
                  <p class="text-body-secondary mb-0"><%= message %></p>
                </div>
              </div>

              <div class="vstack gap-4">
                <div>
                  <h2 class="h5 mb-2"><%= success ? 'Aktion verarbeitet' : 'Manuelle Prüfung empfohlen' %></h2>
                  <p class="text-body-secondary mb-0">
                    <%= success
                      ? 'HeartPet hat deine Rückmeldung übernommen und die Akte entsprechend aktualisiert.'
                      : 'Die Rückmeldung konnte nicht eindeutig verarbeitet werden. Bitte prüfe den Eintrag direkt in der App.' %>
                  </p>
                </div>

                <div class="alert <%= success ? 'alert-success' : 'alert-danger' %> mb-0" role="alert">
                  <%= success ? 'Die Aktion wurde erfolgreich verarbeitet.' : 'Die Aktion konnte nicht automatisch abgeschlossen werden.' %>
                </div>

                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 pt-2 border-top">
                  <p class="text-body-secondary small mb-0">Du kannst jetzt direkt in HeartPet weitermachen oder zur Übersicht zurückkehren.</p>
                  <a href="<%= nextUrl || '/' %>" class="btn btn-primary"><%= nextLabel || 'Weiter' %></a>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
    <script src="<%= `${resolvedAssetBaseUrl}/static/js/app.js` %>"></script>
  </body>
</html>
