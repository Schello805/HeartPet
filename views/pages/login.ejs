<!DOCTYPE html>
<html lang="de">
  <head>
    <% const resolvedAppLogoUrl = typeof appLogoUrl !== 'undefined' && appLogoUrl ? appLogoUrl : '/static/images/logo-heartpet.png'; %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | HeartPet</title>
    <link rel="icon" type="image/png" sizes="any" href="<%= resolvedAppLogoUrl %>" />
    <link rel="shortcut icon" type="image/png" href="<%= resolvedAppLogoUrl %>" />
    <link rel="apple-touch-icon" href="<%= resolvedAppLogoUrl %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous" />
    <link rel="stylesheet" href="/static/css/app.css" />
  </head>
  <body class="bootstrap-app" data-bs-theme="dark">
    <main class="container py-5 min-vh-100 d-flex align-items-center">
      <div class="row justify-content-center w-100">
        <div class="col-12 col-sm-11 col-md-9 col-lg-6 col-xl-5">
          <section class="card border-0 shadow-sm bg-body-tertiary">
            <div class="card-body p-4 p-lg-5">
              <div class="d-flex align-items-center gap-3 mb-4">
                <img class="brand-logo" src="<%= resolvedAppLogoUrl %>" alt="HeartPet Logo" />
                <div>
                  <h1 class="h3 mb-1">HeartPet</h1>
                  <p class="text-body-secondary mb-0">Tierakten, Dokumente, Erinnerungen und Admin-Einstellungen in einer Webapp.</p>
                </div>
              </div>

              <% if (flash) { %>
                <div class="alert <%= flash.type === 'error' ? 'alert-danger' : 'alert-success' %> mb-4" role="alert"><%= flash.message %></div>
              <% } %>

              <form method="post" action="/login" class="vstack gap-4">
                <% if (typeof returnTo !== 'undefined' && returnTo) { %>
                  <input type="hidden" name="return_to" value="<%= returnTo %>" />
                <% } %>

                <div>
                  <h2 class="h5 mb-2">Anmelden</h2>
                  <p class="text-body-secondary mb-0">Melde dich mit deinem HeartPet-Konto an. Danach landest du wieder genau dort, wo du zuletzt weiterarbeiten wolltest.</p>
                </div>

                <div class="row g-3">
                  <div class="col-12">
                    <label class="form-label" for="login-email">E-Mail</label>
                    <input class="form-control" id="login-email" type="email" name="email" required />
                  </div>
                  <div class="col-12">
                    <label class="form-label" for="login-password">Passwort</label>
                    <input class="form-control" id="login-password" type="password" name="password" required />
                  </div>
                </div>

                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 pt-2 border-top">
                  <p class="text-body-secondary small mb-0">Wenn dies eine neue Installation ist, wirst du automatisch zuerst in die Ersteinrichtung weitergeleitet.</p>
                  <button type="submit" class="btn btn-success">Anmelden</button>
                </div>
              </form>
            </div>
          </section>
        </div>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
    <script src="/static/js/app.js"></script>
  </body>
</html>
