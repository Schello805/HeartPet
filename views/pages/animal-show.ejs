<% const isEmbeddedView = typeof embedded !== 'undefined' && embedded; %>
<% if (!isEmbeddedView) { %>
  <%- include('../partials/top', { pageTitle }) %>
<% } %>
<% const reminderSourceMap = typeof sourceReminderMap !== 'undefined' ? sourceReminderMap : {}; %>
<% const freeReminders = typeof manualReminders !== 'undefined' ? manualReminders : []; %>
<% const animalTimeline = typeof timeline !== 'undefined' ? timeline : []; %>
<%
  const activeVeterinarianName = animal.veterinarian_name || animal.species_veterinarian_name || '';
  const activeVeterinarianAddress = animal.veterinarian_name
    ? [animal.veterinarian_street, animal.veterinarian_postal_code, animal.veterinarian_city, animal.veterinarian_country].filter(Boolean).join(', ')
    : [animal.species_veterinarian_street, animal.species_veterinarian_postal_code, animal.species_veterinarian_city, animal.species_veterinarian_country].filter(Boolean).join(', ');
  const activeVeterinarianEmail = animal.veterinarian_name ? (animal.veterinarian_email || '') : (animal.species_veterinarian_email || '');
  const activeVeterinarianPhone = animal.veterinarian_name ? (animal.veterinarian_phone || '') : (animal.species_veterinarian_phone || '');
  const hasVeterinarianContact = Boolean(activeVeterinarianName && (activeVeterinarianAddress || activeVeterinarianEmail || activeVeterinarianPhone));
%>
<% 
  const openReminderCount = reminderBuckets.overdue.length + reminderBuckets.open.length;
  const nextFocusLabel = related.vaccinations[0]
    ? `Impfung: ${related.vaccinations[0].name}`
    : ((related.appointments || [])[0] ? `Termin: ${(related.appointments || [])[0].title}` : 'Kein Termin hinterlegt');
  const focusFacts = [];
  if (openReminderCount > 0) {
    focusFacts.push(`${openReminderCount} offene Erinnerung${openReminderCount === 1 ? '' : 'en'}`);
  }
  if (related.vaccinations.length > 0) {
    focusFacts.push(`${related.vaccinations.length} Impfung${related.vaccinations.length === 1 ? '' : 'en'} im Blick`);
  }
  if ((related.appointments || []).length > 0) {
    focusFacts.push(`${(related.appointments || []).length} Termin${(related.appointments || []).length === 1 ? '' : 'e'} hinterlegt`);
  }
  if (!focusFacts.length) {
    focusFacts.push('Akte ist aktuell gut gepflegt');
  }
%>

<section class="card border-0 shadow-sm animal-hero-card">
  <div class="animal-hero-profile">
    <div class="profile-image-panel">
      <div class="profile-image-frame">
        <% if (animal.profile_image_stored_name) { %>
          <img class="animal-profile-image" src="/media/<%= animal.profile_image_stored_name %>" alt="Profilbild von <%= animal.name %>" />
        <% } else { %>
          <div class="animal-profile-image animal-profile-fallback"><%= getAnimalInitial(animal.name) %></div>
        <% } %>
      </div>
      <% if (permissions.canManageGallery) { %>
        <form method="post" action="/animals/<%= animal.id %>/profile-image" enctype="multipart/form-data" class="profile-image-inline-form">
          <input id="profile-upload-<%= animal.id %>" class="visually-hidden profile-upload-input" type="file" name="profile_image" accept="image/*" required />
          <label for="profile-upload-<%= animal.id %>" class="profile-upload-trigger icon-only subtle" aria-label="<%= animal.profile_image_stored_name ? 'Profilbild ändern' : 'Profilbild hochladen' %>" title="<%= animal.profile_image_stored_name ? 'Profilbild ändern' : 'Profilbild hochladen' %>">
            <span aria-hidden="true">✎</span>
          </label>
          <% if (animal.profile_image_stored_name) { %>
            <button type="submit" class="profile-delete-button subtle" form="profile-image-delete-<%= animal.id %>" aria-label="Profilbild löschen" title="Profilbild löschen">🗑</button>
            <form method="post" action="/animals/<%= animal.id %>/profile-image/delete" id="profile-image-delete-<%= animal.id %>" class="hidden-form" data-confirm="Profilbild wirklich löschen?"></form>
          <% } %>
        </form>
      <% } %>
    </div>
  </div>
  <div class="animal-hero-content">
    <div class="animal-hero-head">
      <div class="animal-hero-title">
        <p class="eyebrow"><%= animal.species_name || 'Tier' %></p>
        <h2><%= animal.name %></h2>
      </div>
      <div class="hero-actions">
        <% if (permissions.canEditAnimals) { %>
          <a href="/animals/<%= animal.id %>/edit" class="btn btn-primary btn-sm icon-button" aria-label="Tier bearbeiten" title="Bearbeiten" data-drawer="animal-form">
            <span aria-hidden="true">✎</span>
            <span class="visually-hidden">Bearbeiten</span>
          </a>
        <% } %>
        <a href="/animals/<%= animal.id %>/export/pdf" class="btn btn-outline-secondary btn-sm icon-button hero-pdf-button" aria-label="Als PDF exportieren" title="Als PDF exportieren">
          <span aria-hidden="true">📄</span>
          <span class="visually-hidden">Als PDF exportieren</span>
        </a>
      </div>
    </div>
    <div class="animal-hero-meta-grid">
      <article class="animal-hero-meta-card">
        <span>Alter</span>
        <strong><%= getAnimalAge(animal.birth_date) %></strong>
      </article>
      <article class="animal-hero-meta-card">
        <span>Aufnahme</span>
        <strong><%= formatDate(animal.intake_date) %></strong>
      </article>
      <article class="animal-hero-meta-card">
        <span>Geburtsdatum</span>
        <strong><%= formatDate(animal.birth_date) %></strong>
      </article>
      <article class="animal-hero-meta-card <%= hasVeterinarianContact ? 'has-action' : '' %>">
        <% if (hasVeterinarianContact) { %>
          <button type="button" class="animal-vet-trigger" data-vet-contact-toggle="<%= animal.id %>" aria-haspopup="dialog" aria-expanded="false">
            <span>Tierarzt</span>
            <strong><%= activeVeterinarianName %></strong>
            <small>Kontaktdaten anzeigen</small>
          </button>
        <% } else { %>
          <span>Tierarzt</span>
          <strong><%= activeVeterinarianName || '-' %></strong>
        <% } %>
      </article>
    </div>
  </div>
</section>

<section class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <div class="row g-3 align-items-start">
      <div class="col-lg-4">
        <div class="d-grid gap-2">
          <p class="eyebrow mb-0">Heute im Fokus</p>
          <h3 class="h4 mb-0">Was bei <%= animal.name %> gerade wichtig ist</h3>
          <p class="small text-body-secondary mb-0">Die wichtigsten Punkte und nächsten Schritte auf einen Blick, bevor du tiefer in die Akte springst.</p>
        </div>
      </div>
      <div class="col-lg-8">
        <div class="row g-2">
          <% focusFacts.forEach((fact) => { %>
            <div class="col-md-6">
              <article class="card border bg-body-tertiary h-100">
                <div class="card-body p-3 d-grid gap-1">
                  <span class="small text-body-secondary">Hinweis</span>
                  <strong><%= fact %></strong>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>

<% if (hasVeterinarianContact) { %>
  <div class="vet-contact-popover" data-vet-contact-popover="<%= animal.id %>" hidden>
    <div class="vet-contact-card" role="dialog" aria-modal="false" aria-label="Kontaktdaten Tierarzt">
      <div class="vet-contact-head">
        <div>
          <p class="eyebrow">Tierarzt</p>
          <h3><%= activeVeterinarianName %></h3>
        </div>
        <button type="button" class="vet-contact-close" data-vet-contact-close="<%= animal.id %>" aria-label="Kontaktdaten schließen">×</button>
      </div>
      <dl class="row g-2 mb-0 vet-contact-list">
        <div class="col-12">
          <div class="card border-0 bg-body-tertiary h-100">
            <div class="card-body p-3">
              <dt class="small text-body-secondary mb-1">Adresse</dt>
              <dd class="mb-0 fw-semibold"><%= activeVeterinarianAddress || 'Keine Adresse hinterlegt' %></dd>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card border-0 bg-body-tertiary h-100">
            <div class="card-body p-3">
              <dt class="small text-body-secondary mb-1">E-Mail</dt>
              <dd class="mb-0 fw-semibold">
            <% if (activeVeterinarianEmail) { %>
              <a href="mailto:<%= activeVeterinarianEmail %>"><%= activeVeterinarianEmail %></a>
            <% } else { %>
              Keine E-Mail hinterlegt
            <% } %>
              </dd>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card border-0 bg-body-tertiary h-100">
            <div class="card-body p-3">
              <dt class="small text-body-secondary mb-1">Telefon</dt>
              <dd class="mb-0 fw-semibold">
            <% if (activeVeterinarianPhone) { %>
              <a href="tel:<%= activeVeterinarianPhone.replace(/\s+/g, '') %>"><%= activeVeterinarianPhone %></a>
            <% } else { %>
              Keine Telefonnummer hinterlegt
            <% } %>
              </dd>
            </div>
          </div>
        </div>
      </dl>
    </div>
  </div>
<% } %>

<section class="row row-cols-2 row-cols-xl-4 g-2 mb-3">
  <div class="col">
    <article class="card border bg-body-tertiary h-100">
      <div class="card-body p-3 d-grid gap-1">
        <span class="small text-uppercase text-body-secondary">Dokumente</span>
        <strong class="h4 mb-0"><%= related.documents.length %></strong>
      </div>
    </article>
  </div>
  <div class="col">
    <article class="card border bg-body-tertiary h-100">
      <div class="card-body p-3 d-grid gap-1">
        <span class="small text-uppercase text-body-secondary">Fotos</span>
        <strong class="h4 mb-0"><%= related.images.length %></strong>
      </div>
    </article>
  </div>
  <div class="col">
    <article class="card border bg-body-tertiary h-100">
      <div class="card-body p-3 d-grid gap-1">
        <span class="small text-uppercase text-body-secondary">Offene Erinnerungen</span>
        <strong class="h4 mb-0"><%= reminderBuckets.overdue.length + reminderBuckets.open.length %></strong>
      </div>
    </article>
  </div>
  <div class="col">
    <article class="card border bg-body-tertiary h-100">
      <div class="card-body p-3 d-grid gap-1">
        <span class="small text-uppercase text-body-secondary">Nächste Termine</span>
        <strong class="h4 mb-0"><%= (related.appointments || []).length + related.vaccinations.length %></strong>
      </div>
    </article>
  </div>
</section>

<nav class="d-flex flex-wrap gap-2 mb-3" aria-label="Bereiche der Tierakte">
  <a href="#animal-stammdaten" class="btn btn-outline-secondary btn-sm">Stammdaten</a>
  <a href="#animal-neu" class="btn btn-outline-secondary btn-sm">Neuer Eintrag</a>
  <a href="#animal-medizin" class="btn btn-outline-secondary btn-sm">Medizin</a>
  <a href="#animal-timeline" class="btn btn-outline-secondary btn-sm">Timeline</a>
  <a href="#animal-dokumente" class="btn btn-outline-secondary btn-sm">Dokumente & Fotos</a>
</nav>

<div class="card border-0 shadow-sm d-lg-none mb-3">
  <div class="card-body d-grid gap-3">
    <div class="d-grid gap-1">
      <p class="eyebrow mb-0">Schneller Überblick</p>
      <strong>Auf dem Smartphone zuerst das Wichtigste, danach die tieferen Bereiche der Akte.</strong>
    </div>
    <div class="row g-2">
      <div class="col-12">
        <article class="card border bg-body-tertiary h-100">
          <div class="card-body p-3 d-grid gap-1">
            <span class="small text-body-secondary">Offene Aufgaben</span>
            <strong><%= openReminderCount %></strong>
            <small class="text-body-secondary"><%= openReminderCount ? 'Erinnerungen brauchen Rückmeldung' : 'Derzeit nichts offen' %></small>
          </div>
        </article>
      </div>
      <div class="col-12">
        <article class="card border bg-body-tertiary h-100">
          <div class="card-body p-3 d-grid gap-1">
            <span class="small text-body-secondary">Nächster Fokus</span>
            <strong><%= nextFocusLabel %></strong>
            <small class="text-body-secondary"><%= focusFacts[0] %></small>
          </div>
        </article>
      </div>
      <div class="col-12">
        <article class="card border bg-body-tertiary h-100">
          <div class="card-body p-3 d-grid gap-1">
            <span class="small text-body-secondary">Akte</span>
            <strong><%= related.documents.length %> Dokumente · <%= related.images.length %> Fotos</strong>
            <small class="text-body-secondary">Schneller Einstieg in Unterlagen und Nachweise</small>
          </div>
        </article>
      </div>
    </div>
    <div class="d-grid gap-2">
      <a href="#animal-neu" class="btn btn-outline-secondary btn-sm">Neuer Eintrag</a>
      <a href="#animal-medizin" class="btn btn-outline-secondary btn-sm">Medizin</a>
      <a href="#animal-dokumente" class="btn btn-outline-secondary btn-sm">Dokumente</a>
    </div>
  </div>
</div>

<section class="accordion animal-record-accordion" id="animalRecordAccordion">
  <section class="accordion-item" id="animal-stammdaten">
    <h2 class="accordion-header" id="animal-stammdaten-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-stammdaten-body" aria-expanded="false" aria-controls="animal-stammdaten-body">
        <span class="accordion-summary-main">Stammdaten</span>
        <span class="accordion-summary-meta">Basis, Fütterung, Protokolle</span>
      </button>
    </h2>
    <div id="animal-stammdaten-body" class="accordion-collapse collapse" aria-labelledby="animal-stammdaten-heading" data-bs-parent="#animalRecordAccordion">
      <div class="accordion-body d-grid gap-3">
      <div class="card border-0 bg-body-tertiary">
        <div class="card-body p-3">
        <h3>Basisdaten</h3>
        <dl class="row g-2 mb-3">
          <div class="col-md-6"><div class="card border-0 bg-dark-subtle h-100"><div class="card-body p-3"><dt class="small text-body-secondary mb-1">Herkunft</dt><dd class="mb-0 fw-semibold"><%= animal.source || '-' %></dd></div></div></div>
          <div class="col-md-6"><div class="card border-0 bg-dark-subtle h-100"><div class="card-body p-3"><dt class="small text-body-secondary mb-1">Rasse</dt><dd class="mb-0 fw-semibold"><%= animal.breed || '-' %></dd></div></div></div>
          <div class="col-md-6"><div class="card border-0 bg-dark-subtle h-100"><div class="card-body p-3"><dt class="small text-body-secondary mb-1">Farbe</dt><dd class="mb-0 fw-semibold"><%= animal.color || '-' %></dd></div></div></div>
          <div class="col-md-6"><div class="card border-0 bg-dark-subtle h-100"><div class="card-body p-3"><dt class="small text-body-secondary mb-1">Geschlecht</dt><dd class="mb-0 fw-semibold"><%= animal.sex || '-' %></dd></div></div></div>
          <div class="col-md-6"><div class="card border-0 bg-dark-subtle h-100"><div class="card-body p-3"><dt class="small text-body-secondary mb-1">Mikrochip</dt><dd class="mb-0 fw-semibold"><%= animal.microchip_number || '-' %></dd></div></div></div>
          <div class="col-md-6"><div class="card border-0 bg-dark-subtle h-100"><div class="card-body p-3"><dt class="small text-body-secondary mb-1">Gewicht</dt><dd class="mb-0 fw-semibold"><%= animal.weight_kg || '-' %></dd></div></div></div>
        </dl>
        <p class="small text-body-secondary mb-0"><%= animal.notes || 'Keine weiteren Notizen vorhanden.' %></p>
        </div>
      </div>

      <div class="accordion animal-subaccordion">
      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-feedings-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-feedings-body" aria-expanded="false" aria-controls="animal-feedings-body">
            Fütterung
          </button>
        </h3>
        <div id="animal-feedings-body" class="accordion-collapse collapse" aria-labelledby="animal-feedings-heading">
          <div class="accordion-body d-grid gap-2">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <p class="small text-body-secondary mb-0">Zeiten, Futter und Mengen an einem Ort.</p>
            <% if (permissions.canManageFeedings) { %>
              <a href="/animals/<%= animal.id %>/feedings/new" class="btn btn-outline-secondary btn-sm" data-drawer="animal-entry">Fütterung anlegen</a>
            <% } %>
          </div>
          <% related.feedings.forEach((item) => { %>
            <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
              <div class="card-body d-grid gap-1 p-3 flex-grow-1">
                <strong><%= item.label %></strong>
                <p><%= item.time_of_day || '-' %> | <%= item.food || '-' %> | <%= item.amount || '-' %></p>
                <% if (item.notes) { %><small><%= item.notes %></small><% } %>
              </div>
              <% if (permissions.canManageFeedings) { %>
                <div class="inline-actions">
                  <a href="/animals/<%= animal.id %>/feedings/<%= item.id %>/edit" class="btn btn-outline-secondary btn-sm icon-button" aria-label="Fütterung bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                    <span aria-hidden="true">✎</span>
                    <span class="visually-hidden">Bearbeiten</span>
                  </a>
                  <form method="post" action="/animals/<%= animal.id %>/feedings/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                    <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Fütterung löschen" title="Löschen">
                      <span aria-hidden="true">🗑</span>
                      <span class="visually-hidden">Löschen</span>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (related.feedings.length === 0) { %>
            <p class="empty-state">Noch kein Fütterungsplan hinterlegt.</p>
          <% } %>
          </div>
        </div>
      </section>

      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-notes-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-notes-body" aria-expanded="false" aria-controls="animal-notes-body">
            Protokolle
          </button>
        </h3>
        <div id="animal-notes-body" class="accordion-collapse collapse" aria-labelledby="animal-notes-heading">
          <div class="accordion-body d-grid gap-2">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <p class="small text-body-secondary mb-0">Kurze Einträge für Verlauf, Beobachtungen und Nachweise.</p>
            <% if (permissions.canManageNotes) { %>
              <a href="/animals/<%= animal.id %>/notes/new" class="btn btn-outline-secondary btn-sm" data-drawer="animal-entry">Protokoll anlegen</a>
            <% } %>
          </div>
          <% related.notes.forEach((item) => { %>
            <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
              <div class="card-body d-grid gap-1 p-3 flex-grow-1">
                <strong><%= item.title %></strong>
                <p><%= item.content %></p>
                <small><%= formatDateTime(item.created_at) %></small>
              </div>
              <% if (permissions.canManageNotes) { %>
                <div class="inline-actions">
                  <a href="/animals/<%= animal.id %>/notes/<%= item.id %>/edit" class="btn btn-outline-secondary btn-sm icon-button" aria-label="Protokoll bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                    <span aria-hidden="true">✎</span>
                    <span class="visually-hidden">Bearbeiten</span>
                  </a>
                  <form method="post" action="/animals/<%= animal.id %>/notes/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                    <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Protokoll löschen" title="Löschen">
                      <span aria-hidden="true">🗑</span>
                      <span class="visually-hidden">Löschen</span>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (related.notes.length === 0) { %>
            <p class="empty-state">Noch keine Protokolle vorhanden.</p>
          <% } %>
          </div>
        </div>
      </section>
      </div>
      </div>
    </div>
  </section>

  <section class="accordion-item" id="animal-neu">
    <h2 class="accordion-header" id="animal-neu-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-neu-body" aria-expanded="false" aria-controls="animal-neu-body">
        <span class="accordion-summary-main">Neuer Eintrag</span>
        <span class="accordion-summary-meta">Schnell Medikamente, Impfungen, Termine oder Erinnerungen erfassen</span>
      </button>
    </h2>
    <div id="animal-neu-body" class="accordion-collapse collapse" aria-labelledby="animal-neu-heading" data-bs-parent="#animalRecordAccordion">
      <div class="accordion-body d-grid gap-3">
      <% if (permissions.canManageHealth || permissions.canManageReminders) { %>
        <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
          <div class="card-body d-grid gap-1 p-3 flex-grow-1">
            <strong>Schneller neuer Eintrag</strong>
            <p>Nutze diesen Einstieg für alles, was im Alltag schnell erfasst werden soll. Medikamente, Impfungen, Termine oder Erinnerungen landen direkt in der passenden Akte, ohne dass du erst zwischen Bereichen springen musst.</p>
            <div class="inline-pill-list">
              <span class="pill subtle-pill">Medikament</span>
              <span class="pill subtle-pill">Impfung</span>
              <span class="pill subtle-pill">Termin</span>
              <span class="pill subtle-pill">Fütterung</span>
              <span class="pill subtle-pill">Notiz</span>
              <span class="pill subtle-pill">Vorerkrankung</span>
            </div>
          </div>
          <div class="inline-actions">
            <a href="/animals/<%= animal.id %>/events/new" class="btn btn-primary btn-sm" data-drawer="animal-entry">Ereignis anlegen</a>
          </div>
        </div>
      <% } else { %>
        <p class="empty-state">Für neue Ereignisse fehlen die erforderlichen Rechte.</p>
      <% } %>
      </div>
    </div>
  </section>

  <section class="accordion-item" id="animal-medizin">
    <h2 class="accordion-header" id="animal-medizin-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-medizin-body" aria-expanded="false" aria-controls="animal-medizin-body">
        <span class="accordion-summary-main">Medizin</span>
        <span class="accordion-summary-meta"><%= related.conditions.length + related.medications.length + related.vaccinations.length + (related.appointments || []).length + freeReminders.length %> Einträge</span>
      </button>
    </h2>
    <div id="animal-medizin-body" class="accordion-collapse collapse" aria-labelledby="animal-medizin-heading" data-bs-parent="#animalRecordAccordion">
      <div class="accordion-body d-grid gap-3">
      <div class="accordion animal-subaccordion">
      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-conditions-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-conditions-body" aria-expanded="false" aria-controls="animal-conditions-body">
            Vorerkrankungen
          </button>
        </h3>
        <div id="animal-conditions-body" class="accordion-collapse collapse" aria-labelledby="animal-conditions-heading">
          <div class="accordion-body d-grid gap-2">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <p class="small text-body-secondary mb-0">Dauerhafte oder bekannte Vorerkrankungen mit kurzem Kontext.</p>
            <% if (permissions.canManageHealth) { %>
              <a href="/animals/<%= animal.id %>/conditions/new" class="btn btn-outline-secondary btn-sm" data-drawer="animal-entry">Vorerkrankung anlegen</a>
            <% } %>
          </div>
          <% related.conditions.forEach((item) => { %>
            <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
              <div class="card-body d-grid gap-1 p-3 flex-grow-1">
                <strong><%= item.title %></strong>
                <p><%= item.details || 'Keine Details' %></p>
              </div>
              <% if (permissions.canManageHealth) { %>
                <div class="inline-actions">
                  <a href="/animals/<%= animal.id %>/conditions/<%= item.id %>/edit" class="btn btn-outline-secondary btn-sm icon-button" aria-label="Vorerkrankung bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                    <span aria-hidden="true">✎</span>
                    <span class="visually-hidden">Bearbeiten</span>
                  </a>
                  <form method="post" action="/animals/<%= animal.id %>/conditions/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                    <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Vorerkrankung löschen" title="Löschen">
                      <span aria-hidden="true">🗑</span>
                      <span class="visually-hidden">Löschen</span>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (related.conditions.length === 0) { %>
            <p class="empty-state">Noch keine Vorerkrankungen hinterlegt.</p>
          <% } %>
          </div>
        </div>
      </section>

      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-medications-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-medications-body" aria-expanded="false" aria-controls="animal-medications-body">
            Medikamente
          </button>
        </h3>
        <div id="animal-medications-body" class="accordion-collapse collapse" aria-labelledby="animal-medications-heading">
          <div class="accordion-body d-grid gap-2">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <p class="small text-body-secondary mb-0">Wirkstoff, Dosis, Zeitplan und offene Erinnerungen.</p>
          </div>
          <% related.medications.forEach((item) => { %>
            <% const medicationReminders = reminderSourceMap[`medication:${item.id}`] || []; %>
            <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
              <div class="card-body d-grid gap-1 p-3 flex-grow-1">
                <strong><%= item.name %></strong>
                <p>Dosis: <%= item.dosage || '-' %> | Plan: <%= item.schedule || '-' %></p>
                <small>Start: <%= formatDate(item.start_date) %> | Ende: <%= formatDate(item.end_date) %></small>
                <% if (item.notes) { %><small><%= item.notes %></small><% } %>
                <% if (medicationReminders.length > 0) { %>
                  <div class="inline-reminder-list">
                    <% medicationReminders.forEach((reminder) => { %>
                      <div class="inline-reminder">
                        <span><%= formatDateTime(reminder.due_at) %></span>
                        <span class="status-chip status-<%= reminder.last_delivery_status || 'pending' %>"><%= reminder.completed_at ? 'erledigt' : 'offen' %></span>
                        <% if (permissions.canManageReminders) { %>
                          <% if (!reminder.completed_at) { %>
                            <form method="post" action="/reminders/<%= reminder.id %>/complete">
                              <button type="submit" class="btn btn-outline-secondary btn-sm">Erledigt</button>
                            </form>
                          <% } else { %>
                            <form method="post" action="/reminders/<%= reminder.id %>/reopen">
                              <button type="submit" class="btn btn-outline-secondary btn-sm">Wieder öffnen</button>
                            </form>
                          <% } %>
                        <% } %>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </div>
              <% if (permissions.canManageHealth) { %>
                <div class="inline-actions">
                  <a href="/animals/<%= animal.id %>/medications/<%= item.id %>/edit" class="btn btn-outline-secondary btn-sm icon-button" aria-label="Medikament bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                    <span aria-hidden="true">✎</span>
                    <span class="visually-hidden">Bearbeiten</span>
                  </a>
                  <form method="post" action="/animals/<%= animal.id %>/medications/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                    <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Medikament löschen" title="Löschen">
                      <span aria-hidden="true">🗑</span>
                      <span class="visually-hidden">Löschen</span>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (related.medications.length === 0) { %>
            <p class="empty-state">Noch keine Medikamente vorhanden.</p>
          <% } %>
          </div>
        </div>
      </section>

      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-vaccinations-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-vaccinations-body" aria-expanded="false" aria-controls="animal-vaccinations-body">
            Impfungen
          </button>
        </h3>
        <div id="animal-vaccinations-body" class="accordion-collapse collapse" aria-labelledby="animal-vaccinations-heading">
          <div class="accordion-body d-grid gap-2">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <p class="small text-body-secondary mb-0">Vergangene Impfungen, nächste Fälligkeiten und Erinnerungen.</p>
          </div>
          <% related.vaccinations.forEach((item) => { %>
            <% const vaccinationReminders = reminderSourceMap[`vaccination:${item.id}`] || []; %>
            <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div class="card-body d-grid gap-1 p-3 flex-grow-1">
                  <strong><%= item.name %></strong>
                  <p>Geimpft: <%= formatDate(item.vaccination_date) %> | Nächste Fälligkeit: <%= formatDate(item.next_due_date) %></p>
                  <% if (item.notes) { %><small><%= item.notes %></small><% } %>
                  <% if (vaccinationReminders.length > 0) { %>
                    <div class="inline-reminder-list">
                      <% vaccinationReminders.forEach((reminder) => { %>
                        <div class="inline-reminder">
                          <span><%= formatDateTime(reminder.due_at) %></span>
                          <span class="status-chip status-<%= reminder.last_delivery_status || 'pending' %>"><%= reminder.completed_at ? 'erledigt' : 'offen' %></span>
                          <% if (permissions.canManageReminders) { %>
                            <% if (!reminder.completed_at) { %>
                              <form method="post" action="/reminders/<%= reminder.id %>/complete">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Erledigt</button>
                              </form>
                            <% } else { %>
                              <form method="post" action="/reminders/<%= reminder.id %>/reopen">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Wieder öffnen</button>
                              </form>
                            <% } %>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
                <% if (permissions.canManageHealth) { %>
                  <div class="inline-actions">
                    <a href="/animals/<%= animal.id %>/vaccinations/<%= item.id %>/edit" class="btn btn-outline-secondary btn-sm icon-button" aria-label="Impfung bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                      <span aria-hidden="true">✎</span>
                      <span class="visually-hidden">Bearbeiten</span>
                    </a>
                    <form method="post" action="/animals/<%= animal.id %>/vaccinations/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                      <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Impfung löschen" title="Löschen">
                        <span aria-hidden="true">🗑</span>
                        <span class="visually-hidden">Löschen</span>
                      </button>
                    </form>
                  </div>
                <% } %>
            </div>
          <% }) %>
          <% if (related.vaccinations.length === 0) { %>
            <p class="empty-state">Noch keine Impfungen vorhanden.</p>
          <% } %>
          </div>
        </div>
      </section>

      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-appointments-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-appointments-body" aria-expanded="false" aria-controls="animal-appointments-body">
            Arzttermine
          </button>
        </h3>
        <div id="animal-appointments-body" class="accordion-collapse collapse" aria-labelledby="animal-appointments-heading">
          <div class="accordion-body d-grid gap-2">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <p class="small text-body-secondary mb-0">Praxis- und Vor-Ort-Termine mit Tierarzt und Zeitpunkt.</p>
          </div>
          <% (related.appointments || []).forEach((item) => { %>
            <% const appointmentReminders = reminderSourceMap[`appointment:${item.id}`] || []; %>
            <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div class="card-body d-grid gap-1 p-3 flex-grow-1">
                  <strong><%= item.title %></strong>
                  <p><%= formatDateTime(item.appointment_at) %> | <%= item.location_mode === 'vor_ort' ? 'Tierarzt kommt vor Ort' : 'Tier wird zur Praxis gebracht' %></p>
                  <small>Ort: <%= item.location_text || '-' %> | Tierarzt: <%= item.veterinarian_name || '-' %></small>
                  <% if (item.notes) { %><small><%= item.notes %></small><% } %>
                  <% if (appointmentReminders.length > 0) { %>
                    <div class="inline-reminder-list">
                      <% appointmentReminders.forEach((reminder) => { %>
                        <div class="inline-reminder">
                          <span><%= formatDateTime(reminder.due_at) %></span>
                          <span class="status-chip status-<%= reminder.last_delivery_status || 'pending' %>"><%= reminder.completed_at ? 'erledigt' : 'offen' %></span>
                          <% if (permissions.canManageReminders) { %>
                            <% if (!reminder.completed_at) { %>
                              <form method="post" action="/reminders/<%= reminder.id %>/complete">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Erledigt</button>
                              </form>
                            <% } else { %>
                              <form method="post" action="/reminders/<%= reminder.id %>/reopen">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Wieder öffnen</button>
                              </form>
                            <% } %>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
                <% if (permissions.canManageHealth) { %>
                  <div class="inline-actions">
                    <a href="/animals/<%= animal.id %>/appointments/<%= item.id %>/edit" class="btn btn-outline-secondary btn-sm icon-button" aria-label="Arzttermin bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                      <span aria-hidden="true">✎</span>
                      <span class="visually-hidden">Bearbeiten</span>
                    </a>
                    <form method="post" action="/animals/<%= animal.id %>/appointments/<%= item.id %>/delete" data-confirm="Arzttermin wirklich löschen?">
                      <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Arzttermin löschen" title="Löschen">
                        <span aria-hidden="true">🗑</span>
                        <span class="visually-hidden">Löschen</span>
                      </button>
                    </form>
                  </div>
                <% } %>
            </div>
          <% }) %>
          <% if ((related.appointments || []).length === 0) { %>
            <p class="empty-state">Noch keine Arzttermine vorhanden.</p>
          <% } %>
          </div>
        </div>
      </section>

      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-free-reminders-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-free-reminders-body" aria-expanded="false" aria-controls="animal-free-reminders-body">
            Freie Erinnerungen
          </button>
        </h3>
        <div id="animal-free-reminders-body" class="accordion-collapse collapse" aria-labelledby="animal-free-reminders-heading">
          <div class="accordion-body d-grid gap-2">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <p class="small text-body-secondary mb-0">Unabhängige Erinnerungen, die nicht an ein medizinisches Ereignis gebunden sind.</p>
          </div>
          <% if (permissions.canManageReminders && freeReminders.length > 0) { %>
            <div class="card border-0 bg-body-tertiary">
              <div class="card-body p-3 d-grid gap-2">
              <div class="row g-2 align-items-end">
                <div class="col-md-8">
                  <select class="form-select" name="bulk_action" required form="bulk-reminders-<%= animal.id %>">
                  <option value="">Massenaktion wählen</option>
                  <option value="complete">Als erledigt markieren</option>
                  <option value="reopen">Wieder öffnen</option>
                  <option value="delete">Löschen</option>
                  </select>
                </div>
                <div class="col-md-4 d-grid">
                  <button type="submit" class="btn btn-outline-secondary" form="bulk-reminders-<%= animal.id %>">Auf Auswahl anwenden</button>
                </div>
              </div>
              <small class="text-body-secondary">Auswahl unten per Checkbox treffen.</small>
              </div>
            </div>
          <% } %>
          <% freeReminders.forEach((item) => { %>
            <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div class="card-body d-grid gap-1 p-3 flex-grow-1">
                  <% if (permissions.canManageReminders) { %>
                    <label class="checkbox-line">
                      <input type="checkbox" name="reminder_ids" value="<%= item.id %>" form="bulk-reminders-<%= animal.id %>" />
                      <span>Auswählen</span>
                    </label>
                  <% } %>
                  <strong><%= item.title %></strong>
                  <p><%= item.reminder_type %> | Fällig: <%= formatDateTime(item.due_at) %></p>
                  <% if (item.notes) { %><small><%= item.notes %></small><% } %>
                </div>
                <% if (permissions.canManageReminders) { %>
                  <div class="inline-actions">
                    <% if (!item.completed_at) { %>
                      <form method="post" action="/reminders/<%= item.id %>/complete">
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Erledigt</button>
                      </form>
                    <% } else { %>
                      <form method="post" action="/reminders/<%= item.id %>/reopen">
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Wieder öffnen</button>
                      </form>
                    <% } %>
                    <a href="/animals/<%= animal.id %>/reminders/<%= item.id %>/edit" class="btn btn-outline-secondary btn-sm icon-button" aria-label="Erinnerung bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                      <span aria-hidden="true">✎</span>
                      <span class="visually-hidden">Bearbeiten</span>
                    </a>
                    <form method="post" action="/animals/<%= animal.id %>/reminders/<%= item.id %>/delete" data-confirm="Erinnerung wirklich löschen?">
                      <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Erinnerung löschen" title="Löschen">
                        <span aria-hidden="true">🗑</span>
                        <span class="visually-hidden">Löschen</span>
                      </button>
                    </form>
                  </div>
                <% } %>
            </div>
          <% }) %>
          <% if (permissions.canManageReminders && freeReminders.length > 0) { %>
            <form id="bulk-reminders-<%= animal.id %>" method="post" action="/animals/<%= animal.id %>/reminders/bulk" class="hidden-form" data-confirm="Ausgewählte Erinnerungen wirklich ändern?"></form>
          <% } %>
          <% if (freeReminders.length === 0) { %>
            <p class="empty-state">Noch keine freien Erinnerungen vorhanden.</p>
          <% } %>
          </div>
        </div>
      </section>
      </div>
      </div>
    </div>
  </section>

  <section class="accordion-item" id="animal-timeline">
    <h2 class="accordion-header" id="animal-timeline-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-timeline-body" aria-expanded="false" aria-controls="animal-timeline-body">
        <span class="accordion-summary-main">Timeline</span>
        <span class="accordion-summary-meta"><%= animalTimeline.length %> Verlaufseinträge</span>
      </button>
    </h2>
    <div id="animal-timeline-body" class="accordion-collapse collapse" aria-labelledby="animal-timeline-heading" data-bs-parent="#animalRecordAccordion">
      <div class="accordion-body d-grid gap-3">
      <% if (animalTimeline.length === 0) { %>
        <p class="empty-state">Noch keine Timeline-Einträge vorhanden.</p>
      <% } else { %>
        <div class="d-grid gap-2">
          <% animalTimeline.forEach((entry) => { %>
            <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
              <div class="card-body d-grid gap-1 p-3 flex-grow-1">
                <strong><%= entry.title %></strong>
                <p><%= entry.type %> | <%= formatDateTime(entry.at) %></p>
                <% if (entry.details) { %><small><%= entry.details %></small><% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
      </div>
    </div>
  </section>

  <section class="accordion-item" id="animal-dokumente">
    <h2 class="accordion-header" id="animal-dokumente-heading">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-dokumente-body" aria-expanded="false" aria-controls="animal-dokumente-body">
        <span class="accordion-summary-main">Dokumente / Fotos</span>
        <span class="accordion-summary-meta"><%= related.documents.length %> Dokumente · <%= related.images.length %> Fotos</span>
      </button>
    </h2>
    <div id="animal-dokumente-body" class="accordion-collapse collapse" aria-labelledby="animal-dokumente-heading" data-bs-parent="#animalRecordAccordion">
      <div class="accordion-body d-grid gap-3">
      <div class="accordion animal-subaccordion">
      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-photos-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-photos-body" aria-expanded="false" aria-controls="animal-photos-body">
            Fotos
          </button>
        </h3>
        <div id="animal-photos-body" class="accordion-collapse collapse" aria-labelledby="animal-photos-heading">
          <div class="accordion-body">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <p class="small text-body-secondary mb-0">Galerie, Profilbild und visuelle Dokumentation.</p>
            <% if (permissions.canManageGallery) { %>
              <a href="/animals/<%= animal.id %>/images/new" class="btn btn-outline-secondary btn-sm" data-drawer="animal-entry">Foto hochladen</a>
            <% } %>
          </div>
          <% if (related.images.length === 0) { %>
            <p class="empty-state">Noch keine Galeriebilder vorhanden.</p>
          <% } else { %>
            <div class="gallery-grid">
              <% related.images.forEach((item) => { %>
                <article class="gallery-card compact-card">
                  <a href="/media/<%= item.stored_name %>" target="_blank" rel="noreferrer">
                    <img class="gallery-image" src="/media/<%= item.stored_name %>" alt="<%= item.title || animal.name %>" />
                  </a>
                  <div class="gallery-meta">
                    <strong><%= item.title || 'Bild' %></strong>
                    <small><%= formatDateTime(item.created_at) %></small>
                  </div>
                  <% if (permissions.canManageGallery) { %>
                    <div class="inline-actions">
                      <form method="post" action="/animals/<%= animal.id %>/images/<%= item.id %>/set-profile">
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Als Profilbild</button>
                      </form>
                      <form method="post" action="/animals/<%= animal.id %>/images/<%= item.id %>/delete" data-confirm="Galeriebild wirklich löschen?">
                        <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Galeriebild löschen" title="Löschen">
                          <span aria-hidden="true">🗑</span>
                          <span class="visually-hidden">Löschen</span>
                        </button>
                      </form>
                    </div>
                  <% } %>
                </article>
              <% }) %>
            </div>
          <% } %>
          </div>
        </div>
      </section>

      <section class="accordion-item">
        <h3 class="accordion-header" id="animal-documents-heading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#animal-documents-body" aria-expanded="false" aria-controls="animal-documents-body">
            Dokumente
          </button>
        </h3>
        <div id="animal-documents-body" class="accordion-collapse collapse" aria-labelledby="animal-documents-heading">
          <div class="accordion-body">
          <% if (missingRequiredCategories.length > 0) { %>
            <div class="alert alert-warning mb-0">
              Fehlende Pflichtkategorien:
              <strong><%= missingRequiredCategories.map((item) => item.name).join(', ') %></strong>
            </div>
          <% } %>
          <div class="d-flex flex-column gap-3">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
              <p class="small text-body-secondary mb-0">Impfnachweise, Verträge und weitere Unterlagen mit Filter.</p>
              <% if (permissions.canManageDocuments) { %>
                <a href="/animals/<%= animal.id %>/documents/new" class="btn btn-outline-secondary" data-drawer="animal-entry">Dokument hochladen</a>
              <% } %>
            </div>
            <form method="get" action="/animals/<%= animal.id %>" class="row g-2 align-items-end">
            <div class="col-md-5">
              <label class="form-label" for="document-category-filter">Kategorie</label>
              <select class="form-select" id="document-category-filter" name="documentCategory">
                <option value="">Alle Kategorien</option>
                <% categories.forEach((category) => { %>
                  <option value="<%= category.id %>" <%= String(documentFilter.categoryId || '') === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-5">
              <label class="form-label" for="document-type-filter">Dateityp</label>
              <select class="form-select" id="document-type-filter" name="documentType">
                <option value="">Alle Typen</option>
                <option value="images" <%= documentFilter.fileType === 'images' ? 'selected' : '' %>>Nur Bilder</option>
                <option value="files" <%= documentFilter.fileType === 'files' ? 'selected' : '' %>>Nur Dokumente</option>
              </select>
            </div>
            <div class="col-md-2 d-grid">
              <button type="submit" class="btn btn-outline-secondary">Filter anwenden</button>
            </div>
            </form>
          </div>
          <% if (related.documents.length === 0) { %>
            <p class="empty-state">Noch keine Dokumente hochgeladen.</p>
          <% } else { %>
            <div class="d-grid gap-2">
              <% related.documents.forEach((item) => { %>
                <div class="card border-0 bg-body-tertiary d-flex flex-column flex-lg-row justify-content-between gap-3">
                  <a class="card-body d-grid gap-1 p-3 flex-grow-1" href="/documents/<%= item.id %>/download">
                    <strong><%= item.title %></strong>
                    <p><%= item.category_name || 'Ohne Kategorie' %></p>
                    <% if ((item.mime_type || '').startsWith('image/')) { %>
                      <img class="document-preview-image" src="/media/<%= item.stored_name %>" alt="<%= item.title %>" />
                    <% } %>
                    <small><%= formatDateTime(item.uploaded_at) %></small>
                  </a>
                  <% if (permissions.canManageDocuments) { %>
                    <div class="inline-actions">
                      <a href="/animals/<%= animal.id %>/documents/<%= item.id %>/edit" class="btn btn-outline-secondary btn-sm icon-button" aria-label="Dokument bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                        <span aria-hidden="true">✎</span>
                        <span class="visually-hidden">Bearbeiten</span>
                      </a>
                      <form method="post" action="/animals/<%= animal.id %>/documents/<%= item.id %>/delete" data-confirm="Dokument wirklich löschen?">
                        <button type="submit" class="btn btn-outline-danger btn-sm icon-button" aria-label="Dokument löschen" title="Löschen">
                          <span aria-hidden="true">🗑</span>
                          <span class="visually-hidden">Löschen</span>
                        </button>
                      </form>
                    </div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } %>
          </div>
        </div>
      </section>
      </div>

      <div class="d-flex justify-content-end mt-2">
        <a href="/animals/<%= animal.id %>/export/json" class="link-secondary small">JSON Export</a>
      </div>
      </div>
    </div>
  </section>
</section>

<% if (!isEmbeddedView) { %>
  <%- include('../partials/bottom') %>
<% } %>
