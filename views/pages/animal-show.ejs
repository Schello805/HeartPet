<% const isEmbeddedView = typeof embedded !== 'undefined' && embedded; %>
<% if (!isEmbeddedView) { %>
  <%- include('../partials/top', { pageTitle }) %>
<% } %>
<% const reminderSourceMap = typeof sourceReminderMap !== 'undefined' ? sourceReminderMap : {}; %>
<% const freeReminders = typeof manualReminders !== 'undefined' ? manualReminders : []; %>
<% const animalTimeline = typeof timeline !== 'undefined' ? timeline : []; %>

<section class="hero-card animal-hero-card">
  <div class="animal-hero-profile">
    <div class="profile-image-panel">
      <div class="profile-image-frame">
        <% if (animal.profile_image_stored_name) { %>
          <img class="animal-profile-image" src="/media/<%= animal.profile_image_stored_name %>" alt="Profilbild von <%= animal.name %>" />
        <% } else { %>
          <div class="animal-profile-image animal-profile-fallback"><%= getAnimalInitial(animal.name) %></div>
        <% } %>
      </div>
      <% if (permissions.canManageGallery) { %>
        <form method="post" action="/animals/<%= animal.id %>/profile-image" enctype="multipart/form-data" class="profile-image-inline-form">
          <input id="profile-upload-<%= animal.id %>" class="visually-hidden profile-upload-input" type="file" name="profile_image" accept="image/*" required />
          <label for="profile-upload-<%= animal.id %>" class="profile-upload-trigger subtle">
            <%= animal.profile_image_stored_name ? 'Profilbild ändern' : 'Profilbild hochladen' %>
          </label>
          <% if (animal.profile_image_stored_name) { %>
            <button type="submit" class="profile-delete-button subtle" form="profile-image-delete-<%= animal.id %>" aria-label="Profilbild löschen" title="Profilbild löschen">🗑</button>
            <form method="post" action="/animals/<%= animal.id %>/profile-image/delete" id="profile-image-delete-<%= animal.id %>" class="hidden-form" data-confirm="Profilbild wirklich löschen?"></form>
          <% } %>
        </form>
      <% } %>
    </div>
  </div>
  <div>
    <p class="eyebrow"><%= animal.species_name || 'Tier' %></p>
    <h2><%= animal.name %></h2>
    <p class="hero-copy">
      Alter: <strong><%= getAnimalAge(animal.birth_date) %></strong> |
      Aufnahme: <strong><%= formatDate(animal.intake_date) %></strong> |
      Status: <strong><%= animal.status %></strong>
    </p>
    <p class="hero-copy">
      Tierarzt: <strong><%= animal.veterinarian_name || animal.species_veterinarian_name || '-' %></strong>
    </p>
    <% if (animal.veterinarian_name && (animal.veterinarian_street || animal.veterinarian_city || animal.veterinarian_country)) { %>
      <p class="hero-copy">
        Adresse: <strong><%= [animal.veterinarian_street, animal.veterinarian_postal_code, animal.veterinarian_city, animal.veterinarian_country].filter(Boolean).join(', ') %></strong>
      </p>
    <% } %>
  </div>
  <div class="hero-actions">
    <% if (permissions.canEditAnimals) { %>
      <a href="/animals/<%= animal.id %>/edit" class="button icon-button" aria-label="Tier bearbeiten" title="Bearbeiten" data-drawer="animal-form">
        <span aria-hidden="true">✎</span>
        <span class="visually-hidden">Bearbeiten</span>
      </a>
    <% } %>
    <a href="/animals/<%= animal.id %>/export/pdf" class="button button-secondary">PDF Export</a>
  </div>
</section>

<section class="animal-workbench-strip">
  <article class="workbench-stat">
    <span class="workbench-label">Dokumente</span>
    <strong><%= related.documents.length %></strong>
  </article>
  <article class="workbench-stat">
    <span class="workbench-label">Fotos</span>
    <strong><%= related.images.length %></strong>
  </article>
  <article class="workbench-stat">
    <span class="workbench-label">Offene Erinnerungen</span>
    <strong><%= reminderBuckets.overdue.length + reminderBuckets.open.length %></strong>
  </article>
  <article class="workbench-stat">
    <span class="workbench-label">Nächste Termine</span>
    <strong><%= (related.appointments || []).length + related.vaccinations.length %></strong>
  </article>
</section>

<section class="accordion-stack">
  <details class="accordion-item" open>
    <summary>Stammdaten</summary>
    <div class="accordion-content compact-layout">
      <div class="section-block">
        <h3>Basisdaten</h3>
        <dl class="detail-list compact">
          <div><dt>Herkunft</dt><dd><%= animal.source || '-' %></dd></div>
          <div><dt>Rasse</dt><dd><%= animal.breed || '-' %></dd></div>
          <div><dt>Farbe</dt><dd><%= animal.color || '-' %></dd></div>
          <div><dt>Geschlecht</dt><dd><%= animal.sex || '-' %></dd></div>
          <div><dt>Mikrochip</dt><dd><%= animal.microchip_number || '-' %></dd></div>
          <div><dt>Gewicht</dt><dd><%= animal.weight_kg || '-' %></dd></div>
        </dl>
        <p class="compact-note"><%= animal.notes || 'Keine weiteren Notizen vorhanden.' %></p>
      </div>

      <details class="sub-accordion">
        <summary>Fütterung</summary>
        <div class="sub-accordion-content stack compact-stack">
          <div class="section-head compact-section-head">
            <p class="compact-note">Zeiten, Futter und Mengen an einem Ort.</p>
            <% if (permissions.canManageFeedings) { %>
              <a href="/animals/<%= animal.id %>/feedings/new" class="button button-secondary" data-drawer="animal-entry">Fütterung anlegen</a>
            <% } %>
          </div>
          <% related.feedings.forEach((item) => { %>
            <div class="list-card static-card compact-card">
              <div class="list-card-main">
                <strong><%= item.label %></strong>
                <p><%= item.time_of_day || '-' %> | <%= item.food || '-' %> | <%= item.amount || '-' %></p>
                <% if (item.notes) { %><small><%= item.notes %></small><% } %>
              </div>
              <% if (permissions.canManageFeedings) { %>
                <div class="inline-actions">
                  <a href="/animals/<%= animal.id %>/feedings/<%= item.id %>/edit" class="button button-secondary icon-button" aria-label="Fütterung bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                    <span aria-hidden="true">✎</span>
                    <span class="visually-hidden">Bearbeiten</span>
                  </a>
                  <form method="post" action="/animals/<%= animal.id %>/feedings/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                    <button type="submit" class="button button-danger icon-button" aria-label="Fütterung löschen" title="Löschen">
                      <span aria-hidden="true">🗑</span>
                      <span class="visually-hidden">Löschen</span>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (related.feedings.length === 0) { %>
            <p class="empty-state">Noch kein Fütterungsplan hinterlegt.</p>
          <% } %>
        </div>
      </details>

      <details class="sub-accordion">
        <summary>Protokolle</summary>
        <div class="sub-accordion-content stack compact-stack">
          <div class="section-head compact-section-head">
            <p class="compact-note">Kurze Einträge für Verlauf, Beobachtungen und Nachweise.</p>
            <% if (permissions.canManageNotes) { %>
              <a href="/animals/<%= animal.id %>/notes/new" class="button button-secondary" data-drawer="animal-entry">Protokoll anlegen</a>
            <% } %>
          </div>
          <% related.notes.forEach((item) => { %>
            <div class="list-card static-card compact-card">
              <div class="list-card-main">
                <strong><%= item.title %></strong>
                <p><%= item.content %></p>
                <small><%= formatDateTime(item.created_at) %></small>
              </div>
              <% if (permissions.canManageNotes) { %>
                <div class="inline-actions">
                  <a href="/animals/<%= animal.id %>/notes/<%= item.id %>/edit" class="button button-secondary icon-button" aria-label="Protokoll bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                    <span aria-hidden="true">✎</span>
                    <span class="visually-hidden">Bearbeiten</span>
                  </a>
                  <form method="post" action="/animals/<%= animal.id %>/notes/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                    <button type="submit" class="button button-danger icon-button" aria-label="Protokoll löschen" title="Löschen">
                      <span aria-hidden="true">🗑</span>
                      <span class="visually-hidden">Löschen</span>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (related.notes.length === 0) { %>
            <p class="empty-state">Noch keine Protokolle vorhanden.</p>
          <% } %>
        </div>
      </details>
    </div>
  </details>

  <details class="accordion-item" open>
    <summary>Ereignis erstellen</summary>
    <div class="accordion-content compact-layout">
      <% if (permissions.canManageHealth || permissions.canManageReminders) { %>
        <div class="list-card static-card compact-card">
          <div class="list-card-main">
            <strong>Schneller neuer Eintrag</strong>
            <p>Medikament, Impfung, Arzttermin oder freie Erinnerung im Drawer anlegen und direkt in der Akte weiterarbeiten.</p>
          </div>
          <div class="inline-actions">
            <a href="/animals/<%= animal.id %>/events/new" class="button" data-drawer="animal-entry">Ereignis anlegen</a>
          </div>
        </div>
      <% } else { %>
        <p class="empty-state">Für neue Ereignisse fehlen die erforderlichen Rechte.</p>
      <% } %>
    </div>
  </details>

  <details class="accordion-item">
    <summary>Medizin</summary>
    <div class="accordion-content compact-layout">
      <details class="sub-accordion">
        <summary>Vorerkrankungen</summary>
        <div class="sub-accordion-content stack compact-stack">
          <div class="section-head compact-section-head">
            <p class="compact-note">Dauerhafte oder bekannte Vorerkrankungen mit kurzem Kontext.</p>
            <% if (permissions.canManageHealth) { %>
              <a href="/animals/<%= animal.id %>/conditions/new" class="button button-secondary" data-drawer="animal-entry">Vorerkrankung anlegen</a>
            <% } %>
          </div>
          <% related.conditions.forEach((item) => { %>
            <div class="list-card static-card compact-card">
              <div class="list-card-main">
                <strong><%= item.title %></strong>
                <p><%= item.details || 'Keine Details' %></p>
              </div>
              <% if (permissions.canManageHealth) { %>
                <div class="inline-actions">
                  <a href="/animals/<%= animal.id %>/conditions/<%= item.id %>/edit" class="button button-secondary icon-button" aria-label="Vorerkrankung bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                    <span aria-hidden="true">✎</span>
                    <span class="visually-hidden">Bearbeiten</span>
                  </a>
                  <form method="post" action="/animals/<%= animal.id %>/conditions/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                    <button type="submit" class="button button-danger icon-button" aria-label="Vorerkrankung löschen" title="Löschen">
                      <span aria-hidden="true">🗑</span>
                      <span class="visually-hidden">Löschen</span>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (related.conditions.length === 0) { %>
            <p class="empty-state">Noch keine Vorerkrankungen hinterlegt.</p>
          <% } %>
        </div>
      </details>

      <details class="sub-accordion">
        <summary>Medikamente</summary>
        <div class="sub-accordion-content stack compact-stack">
          <div class="section-head compact-section-head">
            <p class="compact-note">Wirkstoff, Dosis, Zeitplan und offene Erinnerungen.</p>
          </div>
          <% related.medications.forEach((item) => { %>
            <% const medicationReminders = reminderSourceMap[`medication:${item.id}`] || []; %>
            <div class="list-card static-card compact-card">
              <div class="list-card-main">
                <strong><%= item.name %></strong>
                <p>Dosis: <%= item.dosage || '-' %> | Plan: <%= item.schedule || '-' %></p>
                <small>Start: <%= formatDate(item.start_date) %> | Ende: <%= formatDate(item.end_date) %></small>
                <% if (item.notes) { %><small><%= item.notes %></small><% } %>
                <% if (medicationReminders.length > 0) { %>
                  <div class="inline-reminder-list">
                    <% medicationReminders.forEach((reminder) => { %>
                      <div class="inline-reminder">
                        <span><%= formatDateTime(reminder.due_at) %></span>
                        <span class="status-chip status-<%= reminder.last_delivery_status || 'pending' %>"><%= reminder.completed_at ? 'erledigt' : 'offen' %></span>
                        <% if (permissions.canManageReminders) { %>
                          <% if (!reminder.completed_at) { %>
                            <form method="post" action="/reminders/<%= reminder.id %>/complete">
                              <button type="submit" class="button button-secondary">Erledigt</button>
                            </form>
                          <% } else { %>
                            <form method="post" action="/reminders/<%= reminder.id %>/reopen">
                              <button type="submit" class="button button-secondary">Wieder öffnen</button>
                            </form>
                          <% } %>
                        <% } %>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </div>
              <% if (permissions.canManageHealth) { %>
                <div class="inline-actions">
                  <a href="/animals/<%= animal.id %>/medications/<%= item.id %>/edit" class="button button-secondary icon-button" aria-label="Medikament bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                    <span aria-hidden="true">✎</span>
                    <span class="visually-hidden">Bearbeiten</span>
                  </a>
                  <form method="post" action="/animals/<%= animal.id %>/medications/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                    <button type="submit" class="button button-danger icon-button" aria-label="Medikament löschen" title="Löschen">
                      <span aria-hidden="true">🗑</span>
                      <span class="visually-hidden">Löschen</span>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (related.medications.length === 0) { %>
            <p class="empty-state">Noch keine Medikamente vorhanden.</p>
          <% } %>
        </div>
      </details>

      <details class="sub-accordion">
        <summary>Impfungen</summary>
        <div class="sub-accordion-content stack compact-stack">
          <div class="section-head compact-section-head">
            <p class="compact-note">Vergangene Impfungen, nächste Fälligkeiten und Erinnerungen.</p>
          </div>
          <% related.vaccinations.forEach((item) => { %>
            <% const vaccinationReminders = reminderSourceMap[`vaccination:${item.id}`] || []; %>
            <div class="list-card static-card compact-card">
                <div class="list-card-main">
                  <strong><%= item.name %></strong>
                  <p>Geimpft: <%= formatDate(item.vaccination_date) %> | Nächste Fälligkeit: <%= formatDate(item.next_due_date) %></p>
                  <% if (item.notes) { %><small><%= item.notes %></small><% } %>
                  <% if (vaccinationReminders.length > 0) { %>
                    <div class="inline-reminder-list">
                      <% vaccinationReminders.forEach((reminder) => { %>
                        <div class="inline-reminder">
                          <span><%= formatDateTime(reminder.due_at) %></span>
                          <span class="status-chip status-<%= reminder.last_delivery_status || 'pending' %>"><%= reminder.completed_at ? 'erledigt' : 'offen' %></span>
                          <% if (permissions.canManageReminders) { %>
                            <% if (!reminder.completed_at) { %>
                              <form method="post" action="/reminders/<%= reminder.id %>/complete">
                                <button type="submit" class="button button-secondary">Erledigt</button>
                              </form>
                            <% } else { %>
                              <form method="post" action="/reminders/<%= reminder.id %>/reopen">
                                <button type="submit" class="button button-secondary">Wieder öffnen</button>
                              </form>
                            <% } %>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
                <% if (permissions.canManageHealth) { %>
                  <div class="inline-actions">
                    <a href="/animals/<%= animal.id %>/vaccinations/<%= item.id %>/edit" class="button button-secondary icon-button" aria-label="Impfung bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                      <span aria-hidden="true">✎</span>
                      <span class="visually-hidden">Bearbeiten</span>
                    </a>
                    <form method="post" action="/animals/<%= animal.id %>/vaccinations/<%= item.id %>/delete" data-confirm="Eintrag wirklich löschen?">
                      <button type="submit" class="button button-danger icon-button" aria-label="Impfung löschen" title="Löschen">
                        <span aria-hidden="true">🗑</span>
                        <span class="visually-hidden">Löschen</span>
                      </button>
                    </form>
                  </div>
                <% } %>
            </div>
          <% }) %>
          <% if (related.vaccinations.length === 0) { %>
            <p class="empty-state">Noch keine Impfungen vorhanden.</p>
          <% } %>
        </div>
      </details>

      <details class="sub-accordion">
        <summary>Arzttermine</summary>
        <div class="sub-accordion-content stack compact-stack">
          <div class="section-head compact-section-head">
            <p class="compact-note">Praxis- und Vor-Ort-Termine mit Tierarzt und Zeitpunkt.</p>
          </div>
          <% (related.appointments || []).forEach((item) => { %>
            <% const appointmentReminders = reminderSourceMap[`appointment:${item.id}`] || []; %>
            <div class="list-card static-card compact-card">
                <div class="list-card-main">
                  <strong><%= item.title %></strong>
                  <p><%= formatDateTime(item.appointment_at) %> | <%= item.location_mode === 'vor_ort' ? 'Tierarzt kommt vor Ort' : 'Tier wird zur Praxis gebracht' %></p>
                  <small>Ort: <%= item.location_text || '-' %> | Tierarzt: <%= item.veterinarian_name || '-' %></small>
                  <% if (item.notes) { %><small><%= item.notes %></small><% } %>
                  <% if (appointmentReminders.length > 0) { %>
                    <div class="inline-reminder-list">
                      <% appointmentReminders.forEach((reminder) => { %>
                        <div class="inline-reminder">
                          <span><%= formatDateTime(reminder.due_at) %></span>
                          <span class="status-chip status-<%= reminder.last_delivery_status || 'pending' %>"><%= reminder.completed_at ? 'erledigt' : 'offen' %></span>
                          <% if (permissions.canManageReminders) { %>
                            <% if (!reminder.completed_at) { %>
                              <form method="post" action="/reminders/<%= reminder.id %>/complete">
                                <button type="submit" class="button button-secondary">Erledigt</button>
                              </form>
                            <% } else { %>
                              <form method="post" action="/reminders/<%= reminder.id %>/reopen">
                                <button type="submit" class="button button-secondary">Wieder öffnen</button>
                              </form>
                            <% } %>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
                <% if (permissions.canManageHealth) { %>
                  <div class="inline-actions">
                    <a href="/animals/<%= animal.id %>/appointments/<%= item.id %>/edit" class="button button-secondary icon-button" aria-label="Arzttermin bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                      <span aria-hidden="true">✎</span>
                      <span class="visually-hidden">Bearbeiten</span>
                    </a>
                    <form method="post" action="/animals/<%= animal.id %>/appointments/<%= item.id %>/delete" data-confirm="Arzttermin wirklich löschen?">
                      <button type="submit" class="button button-danger icon-button" aria-label="Arzttermin löschen" title="Löschen">
                        <span aria-hidden="true">🗑</span>
                        <span class="visually-hidden">Löschen</span>
                      </button>
                    </form>
                  </div>
                <% } %>
            </div>
          <% }) %>
          <% if ((related.appointments || []).length === 0) { %>
            <p class="empty-state">Noch keine Arzttermine vorhanden.</p>
          <% } %>
        </div>
      </details>

      <details class="sub-accordion">
        <summary>Freie Erinnerungen</summary>
        <div class="sub-accordion-content stack compact-stack">
          <div class="section-head compact-section-head">
            <p class="compact-note">Unabhängige Erinnerungen, die nicht an ein medizinisches Ereignis gebunden sind.</p>
          </div>
          <% if (permissions.canManageReminders && freeReminders.length > 0) { %>
            <div class="stack form-compact compact-card">
              <div class="mini-grid">
                <select name="bulk_action" required form="bulk-reminders-<%= animal.id %>">
                  <option value="">Massenaktion wählen</option>
                  <option value="complete">Als erledigt markieren</option>
                  <option value="reopen">Wieder öffnen</option>
                  <option value="delete">Löschen</option>
                </select>
                <button type="submit" class="button button-secondary" form="bulk-reminders-<%= animal.id %>">Auf Auswahl anwenden</button>
              </div>
              <small>Auswahl unten per Checkbox treffen.</small>
            </div>
          <% } %>
          <% freeReminders.forEach((item) => { %>
            <div class="list-card static-card compact-card">
                <div class="list-card-main">
                  <% if (permissions.canManageReminders) { %>
                    <label class="checkbox-line">
                      <input type="checkbox" name="reminder_ids" value="<%= item.id %>" form="bulk-reminders-<%= animal.id %>" />
                      <span>Auswählen</span>
                    </label>
                  <% } %>
                  <strong><%= item.title %></strong>
                  <p><%= item.reminder_type %> | Fällig: <%= formatDateTime(item.due_at) %></p>
                  <% if (item.notes) { %><small><%= item.notes %></small><% } %>
                </div>
                <% if (permissions.canManageReminders) { %>
                  <div class="inline-actions">
                    <% if (!item.completed_at) { %>
                      <form method="post" action="/reminders/<%= item.id %>/complete">
                        <button type="submit" class="button button-secondary">Erledigt</button>
                      </form>
                    <% } else { %>
                      <form method="post" action="/reminders/<%= item.id %>/reopen">
                        <button type="submit" class="button button-secondary">Wieder öffnen</button>
                      </form>
                    <% } %>
                    <a href="/animals/<%= animal.id %>/reminders/<%= item.id %>/edit" class="button button-secondary icon-button" aria-label="Erinnerung bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                      <span aria-hidden="true">✎</span>
                      <span class="visually-hidden">Bearbeiten</span>
                    </a>
                    <form method="post" action="/animals/<%= animal.id %>/reminders/<%= item.id %>/delete" data-confirm="Erinnerung wirklich löschen?">
                      <button type="submit" class="button button-danger icon-button" aria-label="Erinnerung löschen" title="Löschen">
                        <span aria-hidden="true">🗑</span>
                        <span class="visually-hidden">Löschen</span>
                      </button>
                    </form>
                  </div>
                <% } %>
            </div>
          <% }) %>
          <% if (permissions.canManageReminders && freeReminders.length > 0) { %>
            <form id="bulk-reminders-<%= animal.id %>" method="post" action="/animals/<%= animal.id %>/reminders/bulk" class="hidden-form" data-confirm="Ausgewählte Erinnerungen wirklich ändern?"></form>
          <% } %>
          <% if (freeReminders.length === 0) { %>
            <p class="empty-state">Noch keine freien Erinnerungen vorhanden.</p>
          <% } %>
        </div>
      </details>
    </div>
  </details>

  <details class="accordion-item">
    <summary>Timeline</summary>
    <div class="accordion-content compact-layout">
      <% if (animalTimeline.length === 0) { %>
        <p class="empty-state">Noch keine Timeline-Einträge vorhanden.</p>
      <% } else { %>
        <div class="stack compact-stack">
          <% animalTimeline.forEach((entry) => { %>
            <div class="list-card static-card compact-card">
              <div class="list-card-main">
                <strong><%= entry.title %></strong>
                <p><%= entry.type %> | <%= formatDateTime(entry.at) %></p>
                <% if (entry.details) { %><small><%= entry.details %></small><% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </details>

  <details class="accordion-item">
    <summary>Dokumente / Fotos</summary>
    <div class="accordion-content compact-layout">
      <details class="sub-accordion" open>
        <summary>Fotos</summary>
        <div class="sub-accordion-content">
          <div class="section-head compact-section-head">
            <p class="compact-note">Galerie, Profilbild und visuelle Dokumentation.</p>
            <% if (permissions.canManageGallery) { %>
              <a href="/animals/<%= animal.id %>/images/new" class="button button-secondary" data-drawer="animal-entry">Foto hochladen</a>
            <% } %>
          </div>
          <% if (related.images.length === 0) { %>
            <p class="empty-state">Noch keine Galeriebilder vorhanden.</p>
          <% } else { %>
            <div class="gallery-grid">
              <% related.images.forEach((item) => { %>
                <article class="gallery-card compact-card">
                  <a href="/media/<%= item.stored_name %>" target="_blank" rel="noreferrer">
                    <img class="gallery-image" src="/media/<%= item.stored_name %>" alt="<%= item.title || animal.name %>" />
                  </a>
                  <div class="gallery-meta">
                    <strong><%= item.title || 'Bild' %></strong>
                    <small><%= formatDateTime(item.created_at) %></small>
                  </div>
                  <% if (permissions.canManageGallery) { %>
                    <div class="inline-actions">
                      <form method="post" action="/animals/<%= animal.id %>/images/<%= item.id %>/set-profile">
                        <button type="submit" class="button button-secondary">Als Profilbild</button>
                      </form>
                      <form method="post" action="/animals/<%= animal.id %>/images/<%= item.id %>/delete" data-confirm="Galeriebild wirklich löschen?">
                        <button type="submit" class="button button-danger icon-button" aria-label="Galeriebild löschen" title="Löschen">
                          <span aria-hidden="true">🗑</span>
                          <span class="visually-hidden">Löschen</span>
                        </button>
                      </form>
                    </div>
                  <% } %>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>
      </details>

      <details class="sub-accordion" open>
        <summary>Dokumente</summary>
        <div class="sub-accordion-content">
          <% if (missingRequiredCategories.length > 0) { %>
            <div class="note-box">
              Fehlende Pflichtkategorien:
              <strong><%= missingRequiredCategories.map((item) => item.name).join(', ') %></strong>
            </div>
          <% } %>
          <div class="button-row compact-wrap">
            <p class="compact-note">Impfnachweise, Verträge und weitere Unterlagen mit Filter.</p>
            <% if (permissions.canManageDocuments) { %>
              <a href="/animals/<%= animal.id %>/documents/new" class="button button-secondary" data-drawer="animal-entry">Dokument hochladen</a>
            <% } %>
            <form method="get" action="/animals/<%= animal.id %>" class="filter-row compact-filter-row">
            <label>
              <span>Kategorie</span>
              <select name="documentCategory">
                <option value="">Alle Kategorien</option>
                <% categories.forEach((category) => { %>
                  <option value="<%= category.id %>" <%= String(documentFilter.categoryId || '') === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
                <% }) %>
              </select>
            </label>
            <label>
              <span>Dateityp</span>
              <select name="documentType">
                <option value="">Alle Typen</option>
                <option value="images" <%= documentFilter.fileType === 'images' ? 'selected' : '' %>>Nur Bilder</option>
                <option value="files" <%= documentFilter.fileType === 'files' ? 'selected' : '' %>>Nur Dokumente</option>
              </select>
            </label>
            <button type="submit" class="button button-secondary">Filter anwenden</button>
            </form>
          </div>
          <% if (related.documents.length === 0) { %>
            <p class="empty-state">Noch keine Dokumente hochgeladen.</p>
          <% } else { %>
            <div class="stack compact-stack">
              <% related.documents.forEach((item) => { %>
                <div class="list-card static-card compact-card">
                  <a class="list-card-main" href="/documents/<%= item.id %>/download">
                    <strong><%= item.title %></strong>
                    <p><%= item.category_name || 'Ohne Kategorie' %></p>
                    <% if ((item.mime_type || '').startsWith('image/')) { %>
                      <img class="document-preview-image" src="/media/<%= item.stored_name %>" alt="<%= item.title %>" />
                    <% } %>
                    <small><%= formatDateTime(item.uploaded_at) %></small>
                  </a>
                  <% if (permissions.canManageDocuments) { %>
                    <div class="inline-actions">
                      <a href="/animals/<%= animal.id %>/documents/<%= item.id %>/edit" class="button button-secondary icon-button" aria-label="Dokument bearbeiten" title="Bearbeiten" data-drawer="animal-entry">
                        <span aria-hidden="true">✎</span>
                        <span class="visually-hidden">Bearbeiten</span>
                      </a>
                      <form method="post" action="/animals/<%= animal.id %>/documents/<%= item.id %>/delete" data-confirm="Dokument wirklich löschen?">
                        <button type="submit" class="button button-danger icon-button" aria-label="Dokument löschen" title="Löschen">
                          <span aria-hidden="true">🗑</span>
                          <span class="visually-hidden">Löschen</span>
                        </button>
                      </form>
                    </div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </details>

      <div class="low-emphasis-actions">
        <a href="/animals/<%= animal.id %>/export/json" class="muted-link">JSON Export</a>
      </div>
    </div>
  </details>
</section>

<% if (!isEmbeddedView) { %>
  <%- include('../partials/bottom') %>
<% } %>
