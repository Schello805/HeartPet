<%
  const isCategory = entityType === 'category';
  const isVeterinarian = entityType === 'veterinarian';
  const isSpecies = entityType === 'species';
  const isEdit = Boolean(item);
%>
<section class="drawer-fragment card border-0 bg-body-tertiary" data-drawer-fragment="masterdata-form" data-drawer-title="<%= pageTitle %>">
  <div class="card-body">
    <h2 class="h4 mb-4"><%= pageTitle %></h2>

    <% if (isCategory) { %>
      <form method="post" action="<%= isEdit ? `/admin/categories/${item.id}/update` : '/admin/categories' %>" class="vstack gap-4" data-drawer-form="masterdata">
        <input type="hidden" name="return_to" value="<%= returnTo || '/admin/stammdaten' %>" />
        <section class="card border bg-body">
          <div class="card-body">
            <div class="mb-3">
              <h3 class="h5 mb-1">Dokumentkategorie</h3>
              <p class="text-body-secondary mb-0">Dokumentkategorien strukturieren hochgeladene Unterlagen wie Verträge, Impfbescheinigungen oder eigene Nachweise.</p>
            </div>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label" for="category-name">Name</label>
                <input class="form-control" id="category-name" type="text" name="name" required value="<%= item?.name || '' %>" />
              </div>
              <div class="col-12">
                <div class="form-check">
                  <input class="form-check-input" id="category-required" type="checkbox" name="is_required" <%= item?.is_required ? 'checked' : '' %> />
                  <label class="form-check-label" for="category-required">Als Pflichtkategorie markieren</label>
                </div>
              </div>
            </div>
          </div>
        </section>
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 pt-2 border-top">
          <p class="text-body-secondary small mb-0">Pflichtkategorien helfen dir dabei, wichtige Nachweise schneller als fehlend zu erkennen.</p>
          <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-success"><%= isEdit ? 'Kategorie speichern' : 'Kategorie anlegen' %></button>
            <button type="button" class="btn btn-outline-secondary" data-drawer-close>Abbrechen</button>
          </div>
        </div>
      </form>
    <% } %>

    <% if (isVeterinarian) { %>
      <form method="post" action="<%= isEdit ? `/admin/veterinarians/${item.id}/update` : '/admin/veterinarians' %>" class="vstack gap-4" data-drawer-form="masterdata">
        <input type="hidden" name="return_to" value="<%= returnTo || '/admin/stammdaten' %>" />
        <section class="card border bg-body">
          <div class="card-body">
            <div class="mb-3">
              <h3 class="h5 mb-1">Kontaktdaten</h3>
              <p class="text-body-secondary mb-0">Lege hier Kontaktdaten und Adresse an. Diese Angaben können später direkt bei Tierarten, Arztterminen und einzelnen Tieren verwendet werden.</p>
            </div>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label" for="vet-name">Name</label>
                <input class="form-control" id="vet-name" type="text" name="name" required value="<%= item?.name || '' %>" />
              </div>
              <div class="col-12">
                <label class="form-label" for="vet-street">Straße und Hausnummer</label>
                <input class="form-control" id="vet-street" type="text" name="street" minlength="3" maxlength="120" pattern="[A-Za-zÄÖÜäöüß0-9 .,\-\/]{3,120}" value="<%= item?.street || '' %>" />
              </div>
              <div class="col-md-4">
                <label class="form-label" for="vet-postal">PLZ</label>
                <input class="form-control" id="vet-postal" type="text" name="postal_code" minlength="3" maxlength="12" pattern="[A-Za-z0-9 -]{3,12}" value="<%= item?.postal_code || '' %>" />
              </div>
              <div class="col-md-4">
                <label class="form-label" for="vet-city">Ort</label>
                <input class="form-control" id="vet-city" type="text" name="city" minlength="2" maxlength="80" pattern="[A-Za-zÄÖÜäöüß0-9 .'\-]{2,80}" value="<%= item?.city || '' %>" />
              </div>
              <div class="col-md-4">
                <label class="form-label" for="vet-country">Land</label>
                <input class="form-control" id="vet-country" type="text" name="country" minlength="2" maxlength="80" pattern="[A-Za-zÄÖÜäöüß .'\-]{2,80}" value="<%= item?.country || '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label" for="vet-phone">Telefon</label>
                <input class="form-control" id="vet-phone" type="tel" name="phone" minlength="6" maxlength="30" pattern="[+0-9()\/.\-\s]{6,30}" value="<%= item?.phone || '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label" for="vet-email">E-Mail</label>
                <input class="form-control" id="vet-email" type="email" name="email" maxlength="120" value="<%= item?.email || '' %>" />
              </div>
              <div class="col-12">
                <label class="form-label" for="vet-notes">Notizen</label>
                <textarea class="form-control" id="vet-notes" name="notes" rows="4"><%= item?.notes || '' %></textarea>
              </div>
            </div>
          </div>
        </section>
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 pt-2 border-top">
          <p class="text-body-secondary small mb-0">Tipp: In die Notizen passen z. B. Sprechzeiten, Bereitschaft, Spezialgebiete oder Hinweise zur Erreichbarkeit.</p>
          <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-success"><%= isEdit ? 'Tierarzt speichern' : 'Tierarzt anlegen' %></button>
            <button type="button" class="btn btn-outline-secondary" data-drawer-close>Abbrechen</button>
          </div>
        </div>
      </form>
    <% } %>

    <% if (isSpecies) { %>
      <form method="post" action="<%= isEdit ? `/admin/species/${item.id}/update` : '/admin/species' %>" class="vstack gap-4" data-drawer-form="masterdata">
        <input type="hidden" name="return_to" value="<%= returnTo || '/admin/stammdaten' %>" />
        <section class="card border bg-body">
          <div class="card-body">
            <div class="mb-3">
              <h3 class="h5 mb-1">Tierart</h3>
              <p class="text-body-secondary mb-0">Tierarten vereinfachen das Anlegen neuer Tiere und sorgen für eine einheitliche Struktur in deinem Bestand.</p>
            </div>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label" for="species-name">Tierart</label>
                <input class="form-control" id="species-name" type="text" name="name" required value="<%= item?.name || '' %>" />
              </div>
              <div class="col-12">
                <label class="form-label" for="species-default-vet">Standard-Tierarzt</label>
                <select class="form-select" id="species-default-vet" name="default_veterinarian_id">
                  <option value="">Kein Standard-Tierarzt</option>
                  <% veterinarians.forEach((vet) => { %>
                    <option value="<%= vet.id %>" <%= String(item?.default_veterinarian_id || '') === String(vet.id) ? 'selected' : '' %>><%= vet.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label" for="species-notes">Notizen</label>
                <textarea class="form-control" id="species-notes" name="notes" rows="4"><%= item?.notes || '' %></textarea>
              </div>
            </div>
          </div>
        </section>
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 pt-2 border-top">
          <p class="text-body-secondary small mb-0">Wenn hier ein Standardtierarzt hinterlegt ist, wird er beim Anlegen eines passenden Tiers automatisch vorgeschlagen.</p>
          <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-success"><%= isEdit ? 'Tierart speichern' : 'Tierart anlegen' %></button>
            <button type="button" class="btn btn-outline-secondary" data-drawer-close>Abbrechen</button>
          </div>
        </div>
      </form>
    <% } %>
  </div>
</section>
