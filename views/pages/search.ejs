<%- include('../partials/top', { pageTitle }) %>

<section class="card border-0 shadow-sm">
  <div class="card-body">
    <form method="get" action="/suche" class="row g-3 align-items-end">
      <div class="col-md-7">
        <label class="form-label" for="search-query">Suchbegriff</label>
        <input class="form-control" id="search-query" type="text" name="q" value="<%= search.q %>" placeholder="Name, Dokument, Ereignis ..." />
      </div>
      <div class="col-md-3">
        <label class="form-label" for="search-scope">Bereich</label>
        <select class="form-select" id="search-scope" name="scope">
        <option value="all" <%= search.scope === 'all' ? 'selected' : '' %>>Alles</option>
        <option value="animals" <%= search.scope === 'animals' ? 'selected' : '' %>>Tiere</option>
        <option value="documents" <%= search.scope === 'documents' ? 'selected' : '' %>>Dokumente</option>
        <option value="events" <%= search.scope === 'events' ? 'selected' : '' %>>Ereignisse</option>
        </select>
      </div>
      <div class="col-md-2 d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">Suchen</button>
        <a href="/suche" class="btn btn-outline-secondary">Zurücksetzen</a>
      </div>
    </form>
  </div>
</section>

<% if (!search.searchable) { %>
  <section class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="empty-state-card">
      <strong>Suche starten</strong>
      <p class="empty-state">Bitte gib mindestens 2 Zeichen ein.</p>
      </div>
    </div>
  </section>
<% } else { %>
  <section class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <h2 class="h4 mb-0">Tiere</h2>
        <span class="badge text-bg-secondary"><%= results.animals.length %></span>
      </div>
    <% if (!results.animals.length) { %>
      <div class="empty-state-card">
        <strong>Keine Treffer bei Tieren</strong>
        <p class="empty-state">Passe den Suchbegriff oder den Bereich an und versuche es erneut.</p>
      </div>
    <% } else { %>
      <div class="vstack gap-3">
        <% results.animals.forEach((item) => { %>
          <a class="card border text-decoration-none" href="/animals/<%= item.id %>">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-start gap-2">
              <div>
                <strong><%= item.name %></strong>
                <p class="mb-0 text-body-secondary"><%= item.species_name || '-' %> | <%= item.status || '-' %></p>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
    </div>
  </section>

  <section class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <h2 class="h4 mb-0">Dokumente</h2>
        <span class="badge text-bg-secondary"><%= results.documents.length %></span>
      </div>
    <% if (!results.documents.length) { %>
      <div class="empty-state-card">
        <strong>Keine Treffer bei Dokumenten</strong>
        <p class="empty-state">Mit einem anderen Suchbegriff oder dem Bereich „Alles“ findest du oft schneller passende Einträge.</p>
      </div>
    <% } else { %>
      <div class="vstack gap-3">
        <% results.documents.forEach((item) => { %>
          <a class="card border text-decoration-none" href="/animals/<%= item.animal_id %>">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-start gap-2">
              <div>
                <strong><%= item.title %></strong>
                <p class="mb-0 text-body-secondary"><%= item.animal_name || 'Ohne Tier' %> | <%= item.category_name || 'Ohne Kategorie' %></p>
              </div>
              <span class="small text-body-secondary"><%= formatDateTime(item.uploaded_at) %></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
    </div>
  </section>

  <section class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <h2 class="h4 mb-0">Ereignisse / Erinnerungen</h2>
        <span class="badge text-bg-secondary"><%= results.events.length %></span>
      </div>
    <% if (!results.events.length) { %>
      <div class="empty-state-card">
        <strong>Keine Treffer bei Ereignissen</strong>
        <p class="empty-state">Hier erscheinen Medikamente, Termine, Impfungen und Erinnerungen, sobald der Suchbegriff dazu passt.</p>
      </div>
    <% } else { %>
      <div class="vstack gap-3">
        <% results.events.forEach((item) => { %>
          <a class="card border text-decoration-none" href="/animals/<%= item.animal_id %>">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-start gap-2">
              <div>
                <strong><%= item.title %></strong>
                <p class="mb-0 text-body-secondary"><%= item.animal_name || 'Ohne Tier' %> | <%= item.kind || '-' %></p>
              </div>
              <span class="small text-body-secondary"><%= formatDateTime(item.at) %></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
    </div>
  </section>
<% } %>

<%- include('../partials/bottom') %>
