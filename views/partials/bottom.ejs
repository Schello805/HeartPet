        </div>
      </main>

      <div class="drawer-shell" id="app-drawer" aria-hidden="true">
        <div class="drawer-backdrop" data-drawer-close></div>
        <aside class="drawer-panel" role="dialog" aria-modal="true" aria-labelledby="drawer-title">
          <div class="drawer-header">
            <strong id="drawer-title">Bearbeiten</strong>
            <button type="button" class="drawer-close" data-drawer-close aria-label="Fenster schließen">×</button>
          </div>
          <div class="drawer-body" data-drawer-body></div>
        </aside>
      </div>

      <nav class="mobile-tabbar" aria-label="Mobile Navigation">
        <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">
          <span class="mobile-tabbar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 10.5 12 4l8 6.5" />
              <path d="M6.5 9.5V20h11V9.5" />
            </svg>
          </span>
          <span class="mobile-tabbar-label">Dashboard</span>
        </a>
        <a class="<%= currentPath.startsWith('/animals') ? 'active' : '' %>" href="/animals">
          <span class="mobile-tabbar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="7.5" cy="8" r="1.8" />
              <circle cx="12" cy="6.4" r="1.8" />
              <circle cx="16.5" cy="8" r="1.8" />
              <path d="M8 18.5c1.1-3.1 6.9-3.1 8 0 0 1.2-.9 1.9-2.3 1.9h-3.4C8.9 20.4 8 19.7 8 18.5Z" />
            </svg>
          </span>
          <span class="mobile-tabbar-label">Tiere</span>
        </a>
        <% if (permissions.canManageAdmin) { %>
          <a class="<%= currentPath.startsWith('/admin') ? 'active' : '' %>" href="/admin/allgemein">
            <span class="mobile-tabbar-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="2.3" />
                <path d="M12 3.8v2.1" />
                <path d="M12 18.1v2.1" />
                <path d="m5.8 5.8 1.5 1.5" />
                <path d="m16.7 16.7 1.5 1.5" />
                <path d="M3.8 12h2.1" />
                <path d="M18.1 12h2.1" />
                <path d="m5.8 18.2 1.5-1.5" />
                <path d="m16.7 7.3 1.5-1.5" />
              </svg>
            </span>
            <span class="mobile-tabbar-label">Verwaltung</span>
          </a>
        <% } %>
        <a class="<%= currentPath === '/hilfe' ? 'active' : '' %>" href="/hilfe">
          <span class="mobile-tabbar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="8.5" />
              <path d="M9.8 9.3a2.4 2.4 0 1 1 3.5 2.1c-.9.5-1.3 1-1.3 1.9" />
              <circle cx="12" cy="16.9" r=".7" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <span class="mobile-tabbar-label">Hilfe</span>
        </a>
        <button type="button" class="mobile-tabbar-action mobile-nav-toggle" aria-expanded="false" aria-controls="sidebar-navigation">
          <span class="mobile-tabbar-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round">
              <circle cx="5" cy="12" r="1.4" />
              <circle cx="12" cy="12" r="1.4" />
              <circle cx="19" cy="12" r="1.4" />
            </svg>
          </span>
          <span class="mobile-tabbar-label">Mehr</span>
        </button>
      </nav>
    </div>
    <footer class="app-footer">
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutzerklärung</a>
      <a href="/kontakt">Kontakt</a>
      <a href="/cookies">Cookie-Hinweise</a>
    </footer>
    <script src="/static/js/app.js"></script>
  </body>
</html>
