<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | <%= appSettings.app_name || "HeartPet" %></title>
    <script>
      try {
        if (sessionStorage.getItem("heartpet-nav-loaded")) {
          document.documentElement.classList.add("no-page-anim");
        }
      } catch (error) {}
    </script>
    <link rel="icon" type="image/png" sizes="any" href="/static/images/logo-heartpet.png" />
    <link rel="shortcut icon" type="image/png" href="/static/images/logo-heartpet.png" />
    <link rel="apple-touch-icon" href="/static/images/logo-heartpet.png" />
    <link rel="stylesheet" href="/static/css/app.css" />
  </head>
  <body>
    <button type="button" class="mobile-nav-toggle" aria-expanded="false" aria-controls="sidebar-navigation">
      Menü
    </button>
    <div class="app-shell">
      <aside class="sidebar" id="sidebar-navigation">
        <div>
          <img class="brand-logo" src="/static/images/logo-heartpet.png" alt="HeartPet Logo" />
          <div class="brand-text">
            <strong><%= appSettings.app_name || "HeartPet" %></strong>
            <span>Tierverwaltung auf einen Blick</span>
          </div>
        </div>

        <nav class="sidebar-nav">
          <% const animalMenu = typeof animalSpeciesMenu !== 'undefined' ? animalSpeciesMenu : []; %>
          <% const queryState = typeof currentQuery !== 'undefined' ? currentQuery : {}; %>
          <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">Dashboard</a>
          <a class="<%= currentPath.startsWith('/animals') ? 'active' : '' %>" href="/animals">Tiere</a>
          <% if (currentPath.startsWith('/animals') && animalMenu.length > 0) { %>
            <div class="sidebar-subnav">
              <% const activeSpeciesId = String(queryState.species_id || ''); %>
              <a class="<%= !activeSpeciesId ? 'active' : '' %>" href="/animals">Alle Tiere</a>
              <% animalMenu.forEach((item) => { %>
                <a class="<%= activeSpeciesId === String(item.id) ? 'active' : '' %>" href="/animals?species_id=<%= item.id %>"><%= item.name %></a>
              <% }) %>
            </div>
          <% } %>
          <% if (permissions.canManageAdmin) { %>
            <a class="<%= currentPath.startsWith('/admin') ? 'active' : '' %>" href="/admin/allgemein">Verwaltung</a>
            <% if (currentPath.startsWith('/admin')) { %>
              <div class="sidebar-subnav">
                <a class="<%= currentPath === '/admin/allgemein' ? 'active' : '' %>" href="/admin/allgemein">Allgemein</a>
                <a class="<%= currentPath === '/admin/benachrichtigungen' || currentPath === '/admin/kommunikation' ? 'active' : '' %>" href="/admin/benachrichtigungen">Benachrichtigungen</a>
                <a class="<%= currentPath === '/admin/stammdaten' ? 'active' : '' %>" href="/admin/stammdaten">Stammdaten</a>
                <a class="<%= currentPath === '/admin/benutzer' ? 'active' : '' %>" href="/admin/benutzer">Benutzer</a>
                <a class="<%= currentPath === '/admin/import' ? 'active' : '' %>" href="/admin/import">Import</a>
                <a class="<%= currentPath === '/admin/systemlog' ? 'active' : '' %>" href="/admin/systemlog">Systemlog</a>
              </div>
            <% } %>
          <% } %>
          <a class="<%= currentPath === '/hilfe' ? 'active' : '' %>" href="/hilfe">Hilfe</a>
        </nav>

        <div class="sidebar-footer">
          <div class="small-label">Eingeloggt als</div>
          <strong><%= currentUser?.name || "-" %></strong>
          <% const roleLabel = currentUser?.role ? getRoleLabel(currentUser.role) : ""; %>
          <% if (roleLabel && String(currentUser?.name || "").trim().toLowerCase() !== String(roleLabel).trim().toLowerCase()) { %>
            <span><%= roleLabel %></span>
          <% } %>
          <form method="post" action="/logout">
            <button type="submit" class="button button-secondary button-full">Abmelden</button>
          </form>
        </div>
      </aside>

      <main class="main-content">
        <header class="page-header">
          <div>
            <p class="eyebrow">HeartPet</p>
            <h1><%= pageTitle %></h1>
          </div>
          <div class="header-actions">
            <% if (permissions.canEditAnimals) { %>
              <a href="/animals/new" class="button">Neues Tier</a>
            <% } %>
          </div>
        </header>

        <% if (currentUser?.mustChangePassword) { %>
          <div class="banner-warning">
            Das Standardpasswort ist noch aktiv. Bitte ändere es im Adminbereich.
          </div>
        <% } %>

        <% if (flash) { %>
          <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
        <% } %>
