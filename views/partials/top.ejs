<!DOCTYPE html>
<html lang="de">
  <head>
    <% const resolvedAppLogoUrl = typeof appLogoUrl !== 'undefined' && appLogoUrl ? appLogoUrl : '/static/images/logo-heartpet.png'; %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | <%= appSettings.app_name || "HeartPet" %></title>
    <script>
      try {
        if (sessionStorage.getItem("heartpet-nav-loaded")) {
          document.documentElement.classList.add("no-page-anim");
        }
      } catch (error) {}
    </script>
    <link rel="icon" type="image/png" sizes="any" href="<%= resolvedAppLogoUrl %>" />
    <link rel="shortcut icon" type="image/png" href="<%= resolvedAppLogoUrl %>" />
    <link rel="apple-touch-icon" href="<%= resolvedAppLogoUrl %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous" />
    <link rel="stylesheet" href="/static/css/app.css" />
  </head>
  <body class="bootstrap-app<%= typeof pageClass !== 'undefined' && pageClass ? ` ${pageClass}` : '' %>" data-bs-theme="dark">
    <div class="app-shell">
      <aside class="app-sidebar d-none d-lg-flex flex-column bg-body border-end">
        <div class="app-sidebar-brand">
          <img class="brand-logo" src="<%= resolvedAppLogoUrl %>" alt="HeartPet Logo" />
          <div class="brand-text">
            <strong><%= appSettings.app_name || "HeartPet" %></strong>
            <span><%= appSettings.organization_name || "Tierverwaltung auf einen Blick" %></span>
          </div>
        </div>

        <div class="app-sidebar-nav-wrap px-3 py-3">
          <%- include('./sidebar-nav', { navScope: 'desktop' }) %>
        </div>

        <div class="app-sidebar-footer mt-auto px-3 py-3 border-top">
          <div class="small-label">Eingeloggt als</div>
          <strong><%= currentUser?.name || "-" %></strong>
          <% const roleLabel = currentUser?.role ? getRoleLabel(currentUser.role) : ""; %>
          <% if (roleLabel && String(currentUser?.name || "").trim().toLowerCase() !== String(roleLabel).trim().toLowerCase()) { %>
            <span><%= roleLabel %></span>
          <% } %>
          <form method="post" action="/logout" class="mt-3">
            <button type="submit" class="btn btn-outline-secondary w-100">Abmelden</button>
          </form>
        </div>
      </aside>

      <div class="app-main">
        <div class="toast-viewport" aria-live="polite" aria-atomic="true">
          <% if (flash) { %>
            <div class="flash toast flash-<%= flash.type %>" data-toast>
              <div class="toast-body">
                <strong class="toast-title"><%= flash.type === 'error' ? 'Fehler' : 'Erfolg' %></strong>
                <div class="toast-message"><%= flash.message %></div>
              </div>
              <button type="button" class="toast-close" data-toast-close aria-label="Meldung schließen">×</button>
            </div>
          <% } %>
        </div>

        <header class="navbar app-mobile-topbar d-lg-none sticky-top px-3 py-2">
          <button class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileNavOffcanvas" aria-controls="mobileNavOffcanvas">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/></svg> Menü
          </button>
          <div class="app-mobile-topbar-brand">
            <strong><%= appSettings.app_name || "HeartPet" %></strong>
            <span><%= pageTitle %></span>
          </div>
          <% if (permissions.canEditAnimals) { %>
            <a href="/animals/new" class="btn btn-primary btn-sm" data-drawer="animal-form">Neu</a>
          <% } %>
        </header>

        <main class="main-content">
          <div class="container-fluid app-main-container">
            <header class="page-header mb-3">
              <div class="page-header-body">
                <div class="page-header-copy">
                  <h1 class="mb-0"><%= pageTitle %></h1>
                </div>
                <div class="header-actions">
                  <% if (permissions.canEditAnimals) { %>
                    <a href="/animals/new" class="btn btn-primary btn-sm px-3" data-drawer="animal-form">Neues Tier</a>
                  <% } %>
                </div>
              </div>
            </header>

            <% if (currentUser?.mustChangePassword) { %>
              <div class="alert alert-warning banner-warning mt-3">
                Das Standardpasswort ist noch aktiv. Bitte ändere es im Adminbereich.
              </div>
            <% } %>

            <div class="main-content-inner">
              <div class="offcanvas offcanvas-start app-mobile-offcanvas d-lg-none" tabindex="-1" id="mobileNavOffcanvas" aria-labelledby="mobileNavOffcanvasLabel">
                <div class="offcanvas-header border-bottom">
                  <div>
                    <h5 class="offcanvas-title mb-1" id="mobileNavOffcanvasLabel"><%= appSettings.app_name || "HeartPet" %></h5>
                    <p class="mb-0 small app-mobile-offcanvas-copy">Bereiche, Verwaltung und Schnellzugriffe</p>
                  </div>
                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Schließen"></button>
                </div>
                <div class="offcanvas-body d-flex flex-column gap-4">
                  <div class="app-sidebar-brand app-sidebar-brand-mobile">
                    <img class="brand-logo" src="<%= resolvedAppLogoUrl %>" alt="HeartPet Logo" />
                    <div class="brand-text">
                      <strong><%= appSettings.app_name || "HeartPet" %></strong>
                      <span><%= appSettings.organization_name || "Tierverwaltung auf einen Blick" %></span>
                    </div>
                  </div>

                  <%- include('./sidebar-nav', { navScope: 'mobile' }) %>

                  <div class="app-mobile-links">
                    <a href="/impressum">Impressum</a>
                    <a href="/datenschutz">Datenschutz</a>
                    <a href="/kontakt">Kontakt</a>
                    <a href="/cookies">Cookies</a>
                  </div>

                  <div class="app-mobile-account mt-auto">
                    <div class="small-label">Eingeloggt als</div>
                    <strong><%= currentUser?.name || "-" %></strong>
                    <form method="post" action="/logout" class="mt-3">
                      <button type="submit" class="btn btn-outline-secondary w-100">Abmelden</button>
                    </form>
                  </div>
                </div>
              </div>
