<% const animalMenu = typeof animalSpeciesMenu !== 'undefined' ? animalSpeciesMenu : []; %>
<% const queryState = typeof currentQuery !== 'undefined' ? currentQuery : {}; %>
<% const activeSpeciesId = String(queryState.species_id || ''); %>

<nav class="nav flex-column gap-2 app-nav" aria-label="Hauptnavigation">
  <a class="nav-link app-nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Dashboard</a>

  <div class="app-nav-group <%= currentPath.startsWith('/animals') ? 'group-active' : '' %>" data-sidebar-group="animals">
    <button type="button" class="app-nav-group-toggle sidebar-group-toggle <%= currentPath.startsWith('/animals') ? 'active' : '' %>" aria-expanded="false">
      <span>Tiere</span>
    </button>
    <div class="app-nav-subnav sidebar-subnav">
      <div class="app-nav-subgroup sidebar-subgroup">
        <a class="nav-link app-nav-sublink <%= currentPath === '/animals' && !activeSpeciesId ? 'active' : '' %>" href="/animals">Aktive Tiere</a>
        <% if (animalMenu.length > 0) { %>
          <div class="app-nav-subspecies sidebar-subsubnav">
            <% animalMenu.forEach((item) => { %>
              <a class="nav-link app-nav-subspecies-link <%= currentPath === '/animals' && activeSpeciesId === String(item.id) ? 'active' : '' %>" href="/animals?species_id=<%= item.id %>"><%= item.name %></a>
            <% }) %>
          </div>
        <% } %>
      </div>
      <a class="nav-link app-nav-sublink <%= currentPath === '/animals/historie' ? 'active' : '' %>" href="/animals/historie">Historie</a>
      <a class="nav-link app-nav-sublink <%= currentPath === '/animals/ruhestaette' ? 'active' : '' %>" href="/animals/ruhestaette">Ruhestätte</a>
    </div>
  </div>

  <% if (permissions.canManageAdmin) { %>
    <div class="app-nav-group <%= currentPath.startsWith('/admin') ? 'group-active' : '' %>" data-sidebar-group="admin">
      <button type="button" class="app-nav-group-toggle sidebar-group-toggle <%= currentPath.startsWith('/admin') ? 'active' : '' %>" aria-expanded="false">
        <span>Verwaltung</span>
      </button>
      <div class="app-nav-subnav sidebar-subnav">
        <a class="nav-link app-nav-sublink <%= currentPath === '/admin/allgemein' ? 'active' : '' %>" href="/admin/allgemein">Allgemein</a>
        <a class="nav-link app-nav-sublink <%= currentPath === '/admin/benachrichtigungen' || currentPath === '/admin/kommunikation' ? 'active' : '' %>" href="/admin/benachrichtigungen">Benachrichtigungen</a>
        <a class="nav-link app-nav-sublink <%= currentPath === '/admin/stammdaten' ? 'active' : '' %>" href="/admin/stammdaten">Stammdaten</a>
        <a class="nav-link app-nav-sublink <%= currentPath === '/admin/benutzer' ? 'active' : '' %>" href="/admin/benutzer">Benutzer</a>
        <a class="nav-link app-nav-sublink <%= currentPath === '/admin/import' ? 'active' : '' %>" href="/admin/import">Import</a>
        <a class="nav-link app-nav-sublink <%= currentPath === '/admin/systemlog' ? 'active' : '' %>" href="/admin/systemlog">Systemlog</a>
      </div>
    </div>
  <% } %>

  <a class="nav-link app-nav-link <%= currentPath === '/hilfe' ? 'active' : '' %>" href="/hilfe">Hilfe</a>
</nav>
